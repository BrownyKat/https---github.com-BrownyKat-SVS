<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SVS — Smart Verification System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
  <style>
    body {
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 2.5rem 1.5rem;
      background:
        radial-gradient(720px 420px at 12% 10%, rgba(250,204,21,.22), transparent 62%),
        radial-gradient(860px 520px at 100% 0, rgba(29,78,216,.18), transparent 64%),
        linear-gradient(180deg, #f7fbff 0%, #ecf4ff 52%, #f8fbff 100%);
    }

    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background-image:
        linear-gradient(rgba(148,163,184,.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(148,163,184,.08) 1px, transparent 1px);
      background-size: 32px 32px;
      mask-image: radial-gradient(circle at center, rgba(0,0,0,.95), rgba(0,0,0,.42));
      pointer-events: none;
    }

    body::after{
      content:'';
      position:fixed; inset:0; z-index:0; pointer-events:none;
      background:
        radial-gradient(380px 220px at 82% 76%, rgba(220,38,38,.08), transparent 70%),
        radial-gradient(420px 280px at 18% 88%, rgba(29,78,216,.08), transparent 72%);
    }

    .landing {
      position: relative; z-index: 1; max-width: 1080px; width: 100%; text-align: center;
      padding: 2.35rem clamp(1.1rem, 2vw, 2rem);
      background: rgba(255,255,255,.52);
      border: 1px solid rgba(191,213,238,.72);
      border-radius: 32px;
      box-shadow: 0 24px 60px rgba(15,23,42,.10), inset 0 1px 0 rgba(255,255,255,.75);
      backdrop-filter: blur(14px) saturate(135%);
      overflow: hidden;
    }
    .landing::before{
      content:'';
      position:absolute; inset:auto auto 0 0;
      width: 280px; height: 280px; border-radius: 50%;
      background: radial-gradient(circle, rgba(250,204,21,.18), transparent 70%);
      transform: translate(-28%, 26%);
      pointer-events:none;
    }
    .landing::after{
      content:'';
      position:absolute; top:0; right:0;
      width: 320px; height: 320px; border-radius: 50%;
      background: radial-gradient(circle, rgba(29,78,216,.14), transparent 72%);
      transform: translate(28%, -28%);
      pointer-events:none;
    }

    .hero-brand {
      display: flex; align-items: center; justify-content: center;
      gap: 16px; margin-bottom: 1.9rem;
      position: relative;
    }
    .hero-logo {
      width: 110px; height: 110px; object-fit: contain;
      display: block;
      filter: drop-shadow(0 14px 24px rgba(29,78,216,.10));
    }
    .hero-copy { text-align: left; }
    .hero-name { font-weight: 900; font-size: 1.65rem; letter-spacing: -0.8px; line-height: 1.05; }
    .hero-name em { font-style: normal; color: var(--amber-dark); }
    .hero-sub  {
      display:inline-flex; align-items:center; gap:8px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.64rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-top: 8px;
      padding: .42rem .68rem; background: rgba(255,255,255,.72);
      border: 1px solid rgba(191,213,238,.78); border-radius: 999px;
      box-shadow: var(--shadow-xs);
    }
    .hero-sub::before{
      content:'';
      width:8px; height:8px; border-radius:50%;
      background: linear-gradient(135deg, var(--amber), var(--orange));
      box-shadow: 0 0 0 4px rgba(250,204,21,.16);
    }

    h1 { font-weight: 900; font-size: clamp(2.35rem, 4vw, 3.8rem); letter-spacing: -2px; line-height: 1.02; margin-bottom: .85rem; }
    h1 span { color: var(--amber-dark); }
    .subtitle {
      color: var(--text2); font-size: 1rem; line-height: 1.8; margin: 0 auto 2.5rem;
      max-width: 640px;
    }

    .role-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

    .role-card {
      display: flex; flex-direction: column; align-items: flex-start; text-align: left;
      padding: 1.9rem 1.6rem 1.55rem;
      background: linear-gradient(180deg, rgba(255,255,255,.92), rgba(244,248,255,.92));
      border: 1px solid rgba(191,213,238,.92);
      border-radius: 26px;
      text-decoration: none; color: inherit;
      box-shadow: 0 12px 34px rgba(15,23,42,.07), inset 0 1px 0 rgba(255,255,255,.72);
      transition: transform .22s, box-shadow .22s, border-color .22s, background .22s;
      position: relative; overflow: hidden;
      min-height: 248px;
    }
    .role-card::after {
      content: '';
      position: absolute; inset: auto -8% -26% auto; width: 180px; height: 180px;
      border-radius: 50%;
      opacity: .34; transition: transform .22s, opacity .22s;
    }
    .role-card.reporter::after { background: radial-gradient(circle, rgba(250,204,21,.34), transparent 68%); }
    .role-card.dispatcher::after { background: radial-gradient(circle, rgba(29,78,216,.28), transparent 68%); }
    .role-card.admin::after { background: radial-gradient(circle, rgba(37,99,235,.26), transparent 68%); }
    .role-card:hover { transform: translateY(-6px); box-shadow: 0 24px 50px rgba(15,23,42,.12); }
    .role-card.reporter:hover  { border-color: var(--amber-border); }
    .role-card.dispatcher:hover{ border-color: var(--blue-border);  }
    .role-card.admin:hover{ border-color: var(--green-border);  }
    .role-card:hover::after { opacity: .48; transform: scale(1.08); }

    .role-icon-box {
      width: 54px; height: 54px; border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.2rem;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.65);
    }
    .role-icon-box svg { width: 24px; height: 24px; stroke-width: 1.75; fill: none; stroke-linecap: round; stroke-linejoin: round; }
    .reporter  .role-icon-box { background: var(--amber-light); border: 1.5px solid var(--amber-border); }
    .reporter  .role-icon-box svg { stroke: var(--amber-dark); }
    .dispatcher .role-icon-box { background: var(--blue-light); border: 1.5px solid var(--blue-border); }
    .dispatcher .role-icon-box svg { stroke: var(--blue); }
    .admin .role-icon-box { background: var(--green-light); border: 1.5px solid var(--green-border); }
    .admin .role-icon-box svg { stroke: var(--green); }

    .role-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: .6rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
      margin-bottom: 4px;
    }
    .reporter  .role-tag { color: var(--amber-dark); }
    .dispatcher .role-tag { color: var(--blue); }
    .admin .role-tag { color: var(--green); }

    .role-title { font-weight: 800; font-size: 1.1rem; margin-bottom: .48rem; letter-spacing: -.3px; }
    .role-desc  { font-size: .87rem; color: var(--muted); line-height: 1.65; font-weight: 400; flex: 1; max-width: 28ch; }

    .role-cta {
      display: flex; align-items: center; gap: 5px;
      margin-top: 1.4rem;
      font-size: .79rem; font-weight: 800;
      padding: .65rem .9rem;
      border-radius: 999px;
      background: rgba(255,255,255,.72);
      border: 1px solid rgba(191,213,238,.8);
    }
    .role-cta svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; transition: transform .2s; }
    .role-card:hover .role-cta svg { transform: translateX(4px); }
    .reporter  .role-cta { color: var(--amber-dark); }
    .dispatcher .role-cta { color: var(--blue); }
    .admin .role-cta { color: var(--green); }

    .footer {
      margin-top: 2rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: .64rem; font-weight: 700;
      letter-spacing: .8px; color: var(--muted2);
      display:inline-flex; align-items:center; justify-content:center;
      padding: .8rem 1rem; border-radius: 999px;
      background: rgba(255,255,255,.7);
      border: 1px solid rgba(191,213,238,.84);
    }

    @media (max-width: 920px) {
      .role-grid { grid-template-columns: 1fr 1fr; }
      .landing { padding: 1.5rem 1rem; border-radius: 26px; }
    }
    @media (max-width: 560px) {
      .role-grid { grid-template-columns: 1fr; }
      .hero-brand { flex-direction: column; }
      .hero-copy { text-align: center; }
      h1 { font-size: 2rem; }
      .subtitle { font-size: .92rem; }
    }
  </style>
</head>
<body>
<div class="landing">

  <div class="hero-brand">
    <img class="hero-logo" src="/images/logo.png" alt="MDRRMO SVS Logo">
    <div class="hero-copy">
      <div class="hero-name">SVS</div>
      <div class="hero-sub">Smart Verification System</div>
    </div>
  </div>

  <h1>Select your <span>role</span></h1>
  <p class="subtitle">Choose the interface that matches your role. Reports submitted by citizens appear on the dispatcher console in real time.</p>

  <div class="role-grid">

    <a href="/report" class="role-card reporter">
      <div class="role-icon-box">
        <!-- Heroicon: document-text -->
        <svg viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      </div>
      <div class="role-tag">Citizen</div>
      <div class="role-title">Report an Emergency</div>
      <div class="role-desc">Submit an incident report or send an instant Panic SOS to SVS dispatchers.</div>
      <div class="role-cta">
        Open Report Form
        <!-- Heroicon: arrow-right -->
        <svg viewBox="0 0 24 24"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </div>
    </a>

    <a href="/dispatcher/login?force=1" class="role-card dispatcher">
      <div class="role-icon-box">
        <!-- Heroicon: squares-2x2 -->
        <svg viewBox="0 0 24 24"><path d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
      </div>
      <div class="role-tag">Dispatcher</div>
      <div class="role-title">Operations Dashboard</div>
      <div class="role-desc">Monitor live reports, verify incidents, dispatch response teams, and track resolutions.</div>
      <div class="role-cta">
        Dispatcher Login
        <svg viewBox="0 0 24 24"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </div>
    </a>

    <a href="/login?force=1" class="role-card admin">
      <div class="role-icon-box">
        <svg viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75m6-3.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
      </div>
      <div class="role-tag">Admin</div>
      <div class="role-title">Admin Console</div>
      <div class="role-desc">View all reports, manage dispatchers, and export report data by date range.</div>
      <div class="role-cta">
        Admin Login
        <svg viewBox="0 0 24 24"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </div>
    </a>

  </div>

  <div class="footer">v1.0 &nbsp;·&nbsp; Real-time via Pusher &nbsp;·&nbsp; SVS (Smart Verification System)</div>

</div>
</body>
</html>

