<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - SVS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#fff1f2;
      --surface:#fff7ed;
      --surface-2:#ffffff;
      --border:#f5c08a;
      --border-strong:#f59e0b;
      --text:#3f1d1d;
      --muted:#7f1d1d;
      --red:#dc2626;
      --yellow:#facc15;
      --shadow:0 14px 30px rgba(127,29,29,.16);
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:'Outfit',sans-serif;
      color:var(--text);
      display:flex;
      min-height:100vh;
      align-items:center;
      justify-content:center;
      background:
        radial-gradient(620px 320px at 100% 0,rgba(220,38,38,.24),transparent 64%),
        radial-gradient(480px 280px at 0 100%,rgba(250,204,21,.30),transparent 66%),
        var(--bg);
      padding:18px;
      position:relative;
      overflow:hidden;
    }
    body::before,body::after{content:'';position:fixed;border-radius:50%;pointer-events:none}
    body::before{width:300px;height:300px;left:-110px;top:-70px;background:rgba(250,204,21,.14);filter:blur(8px)}
    body::after{width:360px;height:360px;right:-120px;bottom:-110px;background:rgba(220,38,38,.10);filter:blur(10px)}
    .card{
      width:min(460px,94vw);
      background:linear-gradient(180deg,rgba(255,247,237,.96),rgba(255,255,255,.96));
      border:1px solid rgba(245,192,138,.92);
      border-radius:24px;
      padding:28px;
      box-shadow:0 24px 58px rgba(127,29,29,.18);
      animation:fadeUp .4s ease both;
      position:relative;
      overflow:hidden;
      backdrop-filter:blur(12px);
    }
    .card::before{
      content:'';
      position:absolute;left:0;right:0;top:0;height:5px;
      background:linear-gradient(90deg,var(--red),var(--yellow));
    }
    .card::after{
      content:'';
      position:absolute;right:-58px;top:-58px;width:180px;height:180px;border-radius:50%;
      background:radial-gradient(circle, rgba(250,204,21,.18), transparent 68%);
      pointer-events:none;
    }
    h1{margin:0 0 10px;font-size:28px;letter-spacing:-.8px}
    p{margin:0 0 20px;color:var(--muted);font-size:14px;line-height:1.7}
    label{
      display:block;font-size:11px;font-weight:800;margin:12px 0 7px;
      text-transform:uppercase;color:var(--muted);letter-spacing:1px;
      font-family:'JetBrains Mono',monospace
    }
    input{
      width:100%;padding:13px 14px;border:1px solid var(--border-strong);border-radius:14px;font-size:14px;
      background:#fff;transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;
      font-family:'Outfit',sans-serif
    }
    input:focus{
      outline:none;border-color:var(--red);box-shadow:0 0 0 4px rgba(220,38,38,.12);transform:translateY(-1px)
    }
    .btn{
      margin-top:18px;width:100%;padding:13px 14px;border:0;border-radius:14px;
      background:linear-gradient(135deg,var(--red),#f59e0b);
      color:#fff;font-weight:800;cursor:pointer;
      font-family:'Outfit',sans-serif;
      transition:transform .2s ease, box-shadow .2s ease;
    }
    .btn:hover{transform:translateY(-1px);box-shadow:0 8px 18px rgba(220,38,38,.25)}
    .err{
      background:#fef2f2;border:1px solid #fca5a5;color:#b91c1c;padding:11px 12px;border-radius:12px;
      margin-bottom:12px;font-size:13px;font-weight:600
    }
    @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    @media(max-width:460px){.card{padding:20px;border-radius:18px}h1{font-size:24px}}
  </style>
</head>
<body>
  <form class="card" method="post" action="/admin/login" id="adminLoginForm">
    <h1>Admin Login</h1>
    <p>Sign in to manage dispatchers and report exports.</p>
    <% if (error) { %><div class="err"><%= error %></div><% } %>
    <label for="username">Username</label>
    <input id="username" name="username" required autocomplete="username">
    <label for="password">Password</label>
    <input id="password" name="password" type="password" required autocomplete="current-password">
    <button class="btn" type="submit">Login</button>
  </form>
  <script>
    try {
      const q = new URLSearchParams(window.location.search);
      if (q.get('force') === '1') {
        sessionStorage.removeItem('svs_admin_window_ok');
      }
      const f = document.getElementById('adminLoginForm');
      if (f) {
        f.addEventListener('submit', function () {
          sessionStorage.setItem('svs_admin_window_ok', String(Date.now()));
          sessionStorage.removeItem('svs_dispatcher_window_ok');
        });
      }
    } catch (_e) {}
  </script>
</body>
</html>
