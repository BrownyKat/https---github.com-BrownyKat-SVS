<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/favicon') %>
  <%- include('partials/typography') %>
  <title>Admin Login - SVS</title>
  <style>
    :root{
      --blue:#1d4ed8; --blue-dark:#1e3a8a; --blue-light:#dbeafe; --blue-border:#93c5fd;
      --amber:#facc15; --amber-light:#fef3c7; --red:#dc2626; --red-light:#fef2f2;
      --text:#0f172a; --muted:#475569; --surface:#ffffff; --border:#bfd6f5;
      --shadow:0 24px 58px rgba(15,23,42,.14);
    }
    *{box-sizing:border-box}
    body{
      margin:0; min-height:100vh; padding:20px;
      display:flex; align-items:center; justify-content:center;
      font-family:var(--font-body); color:var(--text);
      background:
        radial-gradient(620px 340px at 100% 0,rgba(29,78,216,.22),transparent 64%),
        radial-gradient(460px 280px at 0 100%,rgba(250,204,21,.24),transparent 66%),
        linear-gradient(180deg,#f4f8ff 0%,#e8f1ff 100%);
      position:relative; overflow:hidden;
    }
    body::before,body::after{content:'';position:fixed;border-radius:50%;pointer-events:none;filter:blur(8px)}
    body::before{width:320px;height:320px;left:-110px;top:-80px;background:rgba(250,204,21,.14)}
    body::after{width:360px;height:360px;right:-120px;bottom:-110px;background:rgba(29,78,216,.12)}
    .shell{width:min(1000px,100%);display:grid;grid-template-columns:minmax(320px,460px);justify-content:center;align-items:stretch}
    .intro,.card{
      background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(244,248,255,.95));
      border:1px solid var(--border); border-radius:26px; box-shadow:var(--shadow); backdrop-filter:blur(12px);
      position:relative; overflow:hidden;
    }
    .intro::before,.card::before{content:'';position:absolute;inset:0 0 auto 0;height:5px;background:linear-gradient(90deg,var(--blue),var(--amber),var(--red));}
    .intro{padding:28px;display:flex;flex-direction:column;justify-content:space-between}
    .eyebrow{display:inline-flex;align-items:center;gap:8px;width:max-content;padding:8px 12px;border-radius:999px;background:var(--blue-light);color:var(--blue-dark);font-size:12px;font-weight:800;letter-spacing:.4px;text-transform:uppercase}
    .eyebrow::before{content:'';width:8px;height:8px;border-radius:50%;background:#16a34a;box-shadow:0 0 0 4px rgba(22,163,74,.15)}
    .intro h1{margin:18px 0 10px;font-size:36px;line-height:1.05;letter-spacing:-1.2px}
    .intro p{margin:0;color:var(--muted);font-size:15px;line-height:1.7}
    .points{display:grid;gap:12px;margin-top:22px}
    .point{padding:14px 15px;border-radius:18px;background:rgba(255,255,255,.72);border:1px solid rgba(147,197,253,.8)}
    .point strong{display:block;margin-bottom:4px;font-size:14px;color:var(--blue-dark)}
    .point span{font-size:13px;color:var(--muted);line-height:1.55}
    .quick-link{display:inline-flex;align-items:center;justify-content:center;margin-top:18px;width:max-content;padding:12px 16px;border-radius:14px;text-decoration:none;background:#fff;color:var(--blue-dark);border:1px solid var(--blue-border);font-weight:700}
    .card{padding:28px}
    .logo-wrap{text-align:center;margin-bottom:12px}
    .logo{width:186px;max-width:60vw;height:auto;object-fit:contain;display:inline-block;filter:drop-shadow(0 12px 22px rgba(29,78,216,.12))}
    .role-badge{display:inline-flex;align-items:center;gap:8px;padding:7px 12px;border-radius:999px;background:var(--amber-light);color:#92400e;font-size:11px;font-weight:800;letter-spacing:1px;text-transform:uppercase}
    .role-badge::before{content:'Admin';font-family:var(--font-subtitle)}
    h2{margin:14px 0 8px;font-size:30px;letter-spacing:-.9px;color:var(--red)}
    .subtext{margin:0 0 18px;color:var(--muted);font-size:14px;line-height:1.7}
    .err{background:var(--red-light);border:1px solid #fca5a5;color:#b91c1c;padding:12px 13px;border-radius:14px;margin-bottom:14px;font-size:13px;font-weight:700}
    .field-header{display:flex;align-items:center;justify-content:space-between;gap:12px}
    label{display:block;font-size:11px;font-weight:800;margin:14px 0 7px;text-transform:uppercase;color:var(--blue-dark);letter-spacing:1px;font-family:var(--font-subtitle)}
    .meta{font-size:12px;color:var(--muted)}
    input{
      width:100%;padding:14px 15px;border:1px solid var(--blue-border);border-radius:15px;font-size:14px;
      background:rgba(255,255,255,.94);font-family:var(--font-body);
      transition:border-color .18s ease,box-shadow .18s ease,transform .18s ease;
    }
    input:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 4px rgba(29,78,216,.12);transform:translateY(-1px)}
    .password-wrap{position:relative}
    .password-toggle{
      position:absolute;right:10px;top:50%;transform:translateY(-50%);border:0;background:transparent;color:var(--blue-dark);
      font-size:12px;font-weight:800;cursor:pointer;padding:8px 10px;border-radius:10px;
    }
    .password-toggle:hover{background:rgba(219,234,254,.7)}
    .actions{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:12px}
    .tip{font-size:12px;color:var(--muted);line-height:1.5}
    .btn{
      margin-top:18px;width:100%;padding:14px 16px;border:0;border-radius:15px;background:linear-gradient(135deg,var(--blue),#2563eb);
      color:#fff;font-weight:800;cursor:pointer;font-family:var(--font-body);letter-spacing:.2px;box-shadow:0 14px 30px rgba(29,78,216,.24);
      transition:transform .2s ease,box-shadow .2s ease,filter .2s ease
    }
    .btn:hover{transform:translateY(-2px);box-shadow:0 18px 34px rgba(29,78,216,.28);filter:saturate(1.05)}
    .helper-row{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:14px;flex-wrap:wrap}
    .helper-link{font-size:13px;color:var(--blue-dark);font-weight:700;text-decoration:none}
    .helper-link:hover{text-decoration:underline}
    .hint{font-size:12px;color:var(--muted)}
    @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    .intro,.card{animation:fadeUp .4s ease both}
    
    @media(max-width:460px){body{padding:14px}.card{padding:22px;border-radius:20px}h2{font-size:26px}.logo{width:160px}}
  </style>
</head>
<body>
  <div class="shell">
    <form class="card" method="post" action="/admin/login" id="adminLoginForm">
      <div class="logo-wrap"><img class="logo" src="/images/logo.png" alt="MDRRMO SVS Logo"></div>
      <span class="role-badge" aria-hidden="true"></span>
      <h2>Admin Login</h2>
      <% if (error) { %><div class="err"><%= error %></div><% } %>

      <div class="field-header">
        <label for="username">Username</label>
      </div>
      <input id="username" name="username" placeholder="Enter your admin username" required autocomplete="username" autofocus>

      <div class="field-header">
        <label for="password">Password</label>
      </div>
      <div class="password-wrap">
        <input id="password" name="password" type="password" placeholder="Enter your password" required autocomplete="current-password">
        <button class="password-toggle" type="button" data-toggle-password="password">Show</button>
      </div>

      <button class="btn" type="submit">Sign In</button>
    </form>
  </div>

  <script>
    try {
      const q = new URLSearchParams(window.location.search);
      if (q.get('force') === '1') {
        sessionStorage.removeItem('svs_admin_window_ok');
      }
      const f = document.getElementById('adminLoginForm');
      if (f) {
        f.addEventListener('submit', function () {
          sessionStorage.setItem('svs_admin_window_ok', String(Date.now()));
          sessionStorage.removeItem('svs_dispatcher_window_ok');
        });
      }
      document.querySelectorAll('[data-toggle-password]').forEach(function (button) {
        button.addEventListener('click', function () {
          const input = document.getElementById(button.getAttribute('data-toggle-password'));
          if (!input) return;
          const isHidden = input.type === 'password';
          input.type = isHidden ? 'text' : 'password';
          button.textContent = isHidden ? 'Hide' : 'Show';
        });
      });
    } catch (_e) {}
  </script>
</body>
</html>
