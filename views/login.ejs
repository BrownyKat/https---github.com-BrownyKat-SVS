<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - SVS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --blue:#1e3a8a; --blue-dark:#0f172a; --blue-light:#e2e8ff; --blue-border:#b8c7ff;
      --amber:#f59e0b; --amber-light:#fff7e6; --red:#dc2626; --red-light:#fef2f2;
      --text:#0b1224; --muted:#4b5563; --muted-2:#6b7280;
      --surface:#ffffff; --border:#d8e1f5; --shadow:0 12px 28px rgba(15,23,42,.12);
    }
    *{box-sizing:border-box}
    body{
      margin:0; min-height:100vh; padding:24px;
      display:flex; align-items:center; justify-content:center;
      font-family:'Outfit',sans-serif; color:var(--text);
      background:linear-gradient(150deg,#f8fbff 0%,#eef2ff 45%,#fdf6eb 100%);
      position:relative; overflow:hidden;
    }
    body::before,body::after{content:'';position:fixed;border-radius:50%;pointer-events:none;filter:blur(16px);opacity:.45}
    body::before{width:320px;height:320px;left:-110px;top:-90px;background:rgba(190,214,255,.55)}
    body::after{width:340px;height:340px;right:-120px;bottom:-110px;background:rgba(255,214,165,.4)}
    .shell{width:min(960px,100%);display:grid;grid-template-columns:minmax(320px,460px);justify-content:center;align-items:stretch}
    .card{
      background:linear-gradient(180deg,#ffffff 0%,#f7f9ff 100%);
      border:1px solid var(--border); border-radius:20px; box-shadow:var(--shadow); backdrop-filter:blur(10px);
      position:relative; overflow:hidden;
    }
    .card::before{content:'';position:absolute;inset:0 0 auto 0;height:4px;background:linear-gradient(90deg,var(--blue),var(--amber));}
    .card{padding:30px 28px}
    .logo-wrap{text-align:center;margin-bottom:8px}
    .logo{width:186px;max-width:60vw;height:auto;object-fit:contain;display:inline-block;filter:drop-shadow(0 12px 22px rgba(29,78,216,.12))}
    .role-badge{display:inline-flex;align-items:center;gap:8px;padding:7px 12px;border-radius:999px;background:linear-gradient(135deg,#fff3e0,#e8edff);color:#7a2e0c;font-size:11px;font-weight:800;letter-spacing:1px;text-transform:uppercase}
    .role-badge::before{content:'Admin';font-family:'JetBrains Mono',monospace}
    h2{margin:12px 0 4px;font-size:29px;letter-spacing:-.8px;color:var(--blue-dark);text-align:center}
    .subtext{margin:0 0 16px;color:var(--muted-2);font-size:15px;line-height:1.55;text-align:center}
    .err{background:var(--red-light);border:1px solid #fca5a5;color:#b91c1c;padding:12px 13px;border-radius:14px;margin-bottom:14px;font-size:13px;font-weight:700}
    label{display:block;font-size:11px;font-weight:800;margin:12px 0 6px;text-transform:uppercase;color:var(--blue);letter-spacing:1px;font-family:'JetBrains Mono',monospace}
    input{
      width:100%;padding:13px 14px;border:1px solid var(--blue-border);border-radius:14px;font-size:15px;
      background:#fdfefe;font-family:'Outfit',sans-serif;color:var(--text);
      transition:border-color .18s ease,box-shadow .18s ease,transform .18s ease;
    }
    input:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 4px rgba(30,58,138,.16);transform:translateY(-1px)}
    .password-wrap{position:relative}
    .password-toggle{
      position:absolute;right:10px;top:50%;transform:translateY(-50%);border:0;background:transparent;color:var(--blue-dark);
      font-size:12px;font-weight:800;cursor:pointer;padding:8px 10px;border-radius:10px;
    }
    .password-toggle:hover{background:rgba(219,234,254,.7)}
    .password-wrap input{padding-right:86px;}
    .btn{
      margin-top:18px;width:100%;padding:14px 16px;border:0;border-radius:15px;background:linear-gradient(135deg,var(--blue),#1d4ed8);
      color:#fff;font-weight:800;cursor:pointer;font-family:'Outfit',sans-serif;letter-spacing:.2px;box-shadow:0 12px 24px rgba(29,78,216,.2);
      transition:transform .18s ease,box-shadow .18s ease,filter .18s ease
    }
    .btn:hover{transform:translateY(-2px);box-shadow:0 16px 28px rgba(29,78,216,.24);filter:saturate(1.05)}
    @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    .card{animation:fadeUp .4s ease both}
    @media(max-width:460px){body{padding:16px}.card{padding:22px;border-radius:18px}h2{font-size:26px}.logo{width:160px}}
  </style>
</head>
<body>
  <div class="shell">
    <form class="card" method="post" action="/login" id="adminLoginForm">
      <div class="logo-wrap"><img class="logo" src="/images/logo.png" alt="MDRRMO SVS Logo"></div>
      <span class="role-badge" aria-hidden="true"></span>
      <h2>Admin Login</h2>
      <p class="subtext">Sign in with your assigned admin credentials to access the SVS control panel.</p>
      <% if (error) { %><div class="err"><%= error %></div><% } %>

      <label for="username">Username</label>
      <input id="username" name="username" placeholder="Enter your admin username" required autocomplete="username" autofocus>

      <label for="password">Password</label>
      <div class="password-wrap">
        <input id="password" name="password" type="password" placeholder="Enter your password" required autocomplete="current-password">
        <button class="password-toggle" type="button" data-toggle-password="password">Show</button>
      </div>

      <button class="btn" type="submit">Sign In</button>
    </form>
  </div>

  <script>
    try {
      const q = new URLSearchParams(window.location.search);
      if (q.get('force') === '1') {
        sessionStorage.removeItem('svs_admin_window_ok');
      }
      const f = document.getElementById('adminLoginForm');
      if (f) {
        f.addEventListener('submit', function () {
          sessionStorage.setItem('svs_admin_window_ok', String(Date.now()));
          sessionStorage.removeItem('svs_dispatcher_window_ok');
        });
      }
      document.querySelectorAll('[data-toggle-password]').forEach(function (button) {
        button.addEventListener('click', function () {
          const input = document.getElementById(button.getAttribute('data-toggle-password'));
          if (!input) return;
          const isHidden = input.type === 'password';
          input.type = isHidden ? 'text' : 'password';
          button.textContent = isHidden ? 'Hide' : 'Show';
        });
      });
    } catch (_e) {}
  </script>
</body>
</html>
