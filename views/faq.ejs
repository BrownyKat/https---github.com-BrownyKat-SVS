<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SVS - FAQ</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(37,99,235,0.1),_transparent_34%),radial-gradient(circle_at_bottom_right,_rgba(239,68,68,0.09),_transparent_30%),linear-gradient(180deg,#f4f8ff_0%,#fff8ef_82%,#ffffff_100%)] text-slate-900 antialiased [font-family:'Outfit',sans-serif]">
  <%
    const faqs = [
      {
        q: 'What counts as an emergency?',
        a: 'Immediate threats to life, safety, health, or critical infrastructure such as fire, major flooding, serious injuries, trapped people, road crashes, collapsed structures, hazardous spills, or urgent evacuation needs.',
      },
      {
        q: 'How does SVS reduce prank or low-quality reports?',
        a: 'SVS encourages validated contact numbers, structured fields, location capture, photos, and dispatcher review so responders receive clearer, more credible reports.',
      },
      {
        q: 'Can I submit without GPS?',
        a: 'Yes. You can still report using barangay, street, and landmark details. If GPS becomes available later, the platform can add it to help dispatch locate the scene faster.',
      },
      {
        q: 'What if my connection drops while reporting?',
        a: 'The report flow is built to be retry-friendly. If the request cannot send immediately, the client can keep the report queued locally and try again when the connection returns.',
      },
      {
        q: 'When should I use SOS instead of the report form?',
        a: 'Use SOS for the fastest one-tap alert when you need immediate dispatcher attention. Use the full report form when you can safely provide more details, landmarks, or a photo.',
      },
    ];
    const feedbackState = (typeof feedbackStatus === 'string' ? feedbackStatus : '').trim();
    const faqCount = faqs.length;
  %>

  <%- include('partials/navbar', { active: 'faq', timeId: 'faqTime' }) %>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <section class="overflow-hidden rounded-[2.2rem] border border-slate-200/80 bg-[linear-gradient(145deg,rgba(255,255,255,0.94),rgba(238,246,255,0.9))] shadow-[0_28px_70px_rgba(15,23,42,0.12)]">
      <div class="grid gap-8 px-6 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(300px,0.9fr)] lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-white/90 px-3 py-1 font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-blue-700">
            Frequently Asked Questions
          </div>
          <h1 class="mt-5 max-w-3xl text-3xl font-black leading-[1.02] tracking-tight text-slate-950 sm:text-[3.3rem]">
            Straight answers for urgent reporting, GPS, and dispatch flow.
          </h1>
          <p class="mt-5 max-w-3xl text-base leading-8 text-slate-700 sm:text-lg">
            This page covers the most common questions about emergency reporting in SVS so users can move with confidence and dispatchers can receive clearer incident information.
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="rounded-full border border-blue-200 bg-blue-50 px-3 py-1.5 text-sm font-black text-blue-700"><%= faqCount %> key questions</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">Verified callers</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">GPS-first</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">Retry-friendly</span>
          </div>
        </div>

        <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)] backdrop-blur">
          <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-slate-500">Need help now?</div>
          <div class="mt-4 space-y-4">
            <a href="/sos" class="flex items-start justify-between gap-4 rounded-[1.4rem] border border-red-200 bg-red-50 px-5 py-4 transition hover:border-red-300 hover:bg-red-100">
              <div>
                <div class="text-sm font-black uppercase tracking-[0.18em] text-red-600">Immediate action</div>
                <p class="mt-2 text-sm leading-7 text-slate-700">Use SOS for the fastest one-tap emergency alert.</p>
              </div>
              <span class="shrink-0 rounded-full bg-white px-3 py-1 text-sm font-black text-red-600">SOS</span>
            </a>
            <a href="/report" class="flex items-start justify-between gap-4 rounded-[1.4rem] border border-blue-200 bg-blue-50 px-5 py-4 transition hover:border-blue-300 hover:bg-blue-100">
              <div>
                <div class="text-sm font-black uppercase tracking-[0.18em] text-blue-700">Detailed report</div>
                <p class="mt-2 text-sm leading-7 text-slate-700">Add location details, scene context, and a photo when safe.</p>
              </div>
              <span class="shrink-0 rounded-full bg-white px-3 py-1 text-sm font-black text-blue-700">Report</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <% if (feedbackState === 'success') { %>
      <div class="mt-6 rounded-[1.6rem] border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-bold text-emerald-700 shadow-[0_14px_28px_rgba(16,185,129,0.08)]">
        Feedback received. Thank you for helping improve SVS.
      </div>
    <% } else if (feedbackState === 'error') { %>
      <div class="mt-6 rounded-[1.6rem] border border-red-200 bg-red-50 px-5 py-4 text-sm font-bold text-red-700 shadow-[0_14px_28px_rgba(239,68,68,0.08)]">
        We could not save your feedback right now. Please try again in a moment.
      </div>
    <% } %>

    <section class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)]">
      <div class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#eff6ff_0%,#ffffff_100%)] p-5 shadow-[0_20px_44px_rgba(15,23,42,0.1)] sm:p-6">
        <div class="space-y-4">
          <% faqs.forEach(function(item, index) { %>
            <details class="group rounded-[1.6rem] border border-slate-200 bg-white px-5 py-4 shadow-[0_12px_24px_rgba(15,23,42,0.06)] open:border-blue-200 open:shadow-[0_18px_34px_rgba(37,99,235,0.12)]" <%= index === 0 ? 'open' : '' %>>
              <summary class="flex cursor-pointer list-none items-center gap-4 text-left">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-slate-900 text-sm font-black text-white">?</span>
                <span class="text-base font-black text-slate-950 sm:text-lg"><%= item.q %></span>
                <span class="ml-auto text-xl font-black text-blue-600 transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-4 pl-14 text-sm leading-7 text-slate-700 sm:text-base"><%= item.a %></p>
            </details>
          <% }) %>
        </div>
      </div>

      <aside class="space-y-6">
        <section class="rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)]">
          <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-amber-600">Best practice</div>
          <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950">How to help dispatch faster</h2>
          <div class="mt-4 space-y-3 text-sm leading-7 text-slate-700">
            <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 px-4 py-3">Keep your callback number accurate and reachable.</div>
            <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 px-4 py-3">Use barangay, street, and landmark details even if GPS is present.</div>
            <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 px-4 py-3">Attach a photo only when it is safe to do so.</div>
          </div>
          <div class="mt-4 rounded-[1.4rem] border border-blue-100 bg-blue-50 px-4 py-3 text-sm leading-7 text-slate-700">
            If the answer you need is not here, the fastest paths are still <a href="/sos" class="font-black text-red-600">SOS</a> for immediate attention and <a href="/report" class="font-black text-blue-700">Report</a> for detailed incident context.
          </div>
        </section>

        <section class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#fff8ef_0%,#ffffff_100%)] p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)]">
          <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-red-600">Feedback</div>
          <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950">Tell us what needs work.</h2>
          <p class="mt-3 text-sm leading-7 text-slate-700 sm:text-base">
            If something felt unclear or hard to use, send feedback here. Short, specific notes are the most helpful.
          </p>

          <form class="mt-5 space-y-4" method="post" action="/faq/feedback">
            <div>
              <label class="mb-2 block text-xs font-black uppercase tracking-[0.22em] text-slate-500" for="feedbackText">Your feedback</label>
              <textarea
                id="feedbackText"
                name="feedback"
                rows="6"
                required
                maxlength="1000"
                class="w-full rounded-[1.4rem] border border-slate-300 bg-white px-4 py-4 text-sm leading-7 text-slate-900 outline-none transition focus:border-blue-400 focus:ring-4 focus:ring-blue-100"
                placeholder="Example: The map was clear, but the GPS button text felt too long on mobile."
              ></textarea>
              <div class="mt-2 text-xs font-bold uppercase tracking-[0.16em] text-slate-400">Short, specific feedback is easiest to act on.</div>
            </div>
            <button class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-slate-900 px-5 py-3 text-sm font-black uppercase tracking-[0.18em] text-white transition hover:-translate-y-0.5" type="submit">
              Submit feedback
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 2 11 13"/>
                <path d="m22 2-7 20-4-9-9-4Z"/>
              </svg>
            </button>
          </form>
        </section>
      </aside>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    function updateTime(elId){
      const el=document.getElementById(elId); if(!el) return;
      const clock=el.querySelector('.clock-text'); const date=el.querySelector('.date-text');
      const now=new Date(); const pad=n=>String(n).padStart(2,'0'); const h24=now.getHours(); const h=h24%12||12; const ampm=h24>=12?'PM':'AM';
      clock.textContent=`${pad(h)}:${pad(now.getMinutes())}:${pad(now.getSeconds())} ${ampm}`;
      const days=['SUN','MON','TUE','WED','THU','FRI','SAT'];
      date.textContent=`${days[now.getDay()]} ${pad(now.getMonth()+1)}/${pad(now.getDate())}/${now.getFullYear()}`;
    }
    updateTime('faqTime'); setInterval(()=>updateTime('faqTime'),1000);
  </script>
</body>
</html>
