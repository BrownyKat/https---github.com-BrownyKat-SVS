<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/favicon') %>
  <%- include('partials/typography') %>
  <title>Admin Dashboard</title>
  <style>
    :root{
      --amber:#FACC15;
      --amber-soft:#FEFCE8;
      --amber-dark:#EAB308;
      --amber-strong:#CA8A04;
      --blue:#1D4ED8;
      --blue-deep:#1E3A8A;
      --blue-soft:#EFF6FF;
      --blue-border:#BFD6F5;
      --red-border:#FCA5A5;
      --bg:#f5f7ff;
      --card:#ffffff;
      --card-soft:#F4F8FF;
      --border:#BFD6F5;
      --border-strong:#97BDE9;
      --text:#0F172A;
      --text2:#1E3A8A;
      --muted:#334155;
      --muted2:#64748B;
      --accent:#dc2626;
      --accent-deep:#991B1B;
      --accent-soft:#FEF2F2;
      --green:#166534;
      --red:#DC2626;
      --shadow-sm:0 1px 3px rgba(15,23,42,.08),0 1px 2px rgba(15,23,42,.05);
      --shadow-md:0 12px 30px rgba(15,23,42,.10),0 4px 14px rgba(15,23,42,.06);
      --r-md:12px;
      --r-lg:16px;
      --r-xl:20px;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:var(--font-body);
      color:var(--text);
      background:
        radial-gradient(520px 360px at 120% -20%, rgba(59,130,246,.16), transparent 60%),
        radial-gradient(420px 280px at -10% 120%, rgba(239,68,68,.12), transparent 60%),
        linear-gradient(180deg, #f2f6ff 0%, #fff7ef 82%, #ffffff 100%);
    }
    .layout{display:flex;min-height:100vh;animation:fadeUp .45s ease both}
    @keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
    @media (prefers-reduced-motion: reduce){
      .layout,*{animation:none!important;transition:none!important}
    }
    .side{
      width:240px;flex-shrink:0;
      background:
        radial-gradient(220px 140px at 50% 0, rgba(250,204,21,.18), transparent 78%),
        linear-gradient(180deg, rgba(244,248,255,.94) 0%, rgba(235,243,255,.96) 46%, rgba(255,247,239,.98) 100%);
      border-right:1px solid rgba(191,214,245,.85);
      padding:28px 18px;
      position:sticky;top:0;height:100vh;overflow:auto;
      box-shadow:20px 0 44px rgba(15,23,42,.08);
      backdrop-filter:blur(16px);
    }
    .brand-wrap{
      padding-bottom:14px;
      margin-bottom:14px;
      border-bottom:1px solid rgba(191,214,245,.85);
      text-align:center;
    }
    .brand{
      display:flex;flex-direction:column;align-items:center;gap:6px;
      font-weight:800;font-size:18px;line-height:1.1;color:var(--text);
    }
    .brand-logo{
      width:200px;height:110px;object-fit:contain;display:block;
    }
    .sub{font-size:12px;color:var(--muted2);margin-top:4px;font-weight:700;letter-spacing:.3px;}
    .nav-title{
      font-family:var(--font-subtitle);
      font-size:11px;letter-spacing:1.4px;text-transform:uppercase;color:var(--muted2);
      margin:10px 0 8px;text-align:center;
    }
    .nav{display:flex;flex-direction:column;gap:12px}
    .nav-item,.nav button{
      display:flex;align-items:center;gap:10px;width:100%;
      text-align:left;text-decoration:none;
      background:linear-gradient(180deg,#fff,#f3f7ff);border:1.6px solid rgba(151,189,233,.9);
      border-radius:14px;padding:12px 14px;
      color:var(--text);font-weight:700;font-size:14px;line-height:1.3;cursor:pointer;
      transition:transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
      font-family:var(--font-body);
      position:relative;
      box-shadow:0 9px 18px rgba(15,23,42,.08);
      appearance:none;
      -webkit-appearance:none;
      -webkit-text-fill-color:currentColor;
    }
    .nav-item svg,.nav button svg{
      width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.9;
      stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;
    }
    .nav-label{
      color:inherit;
      display:inline-block;
      -webkit-text-fill-color:currentColor;
    }
    .nav-item:hover,.nav button:hover{
      border-color:var(--blue);background:linear-gradient(180deg,#fff,#eef4ff);transform:translateY(-1px);
      box-shadow:0 12px 24px rgba(29,78,216,.14);color:var(--blue);
    }
    .nav-item.active{
      background:linear-gradient(180deg,#f0f5ff,#dfe9ff);
      border-color:var(--blue);
      color:var(--blue);
      box-shadow:0 12px 26px rgba(29,78,216,.18);
    }
    .logout-item{
      color:var(--accent-deep) !important;
      border-color:rgba(252,165,165,.95) !important;
      background:linear-gradient(180deg,#fff,#fff5f5) !important;
    }
    .logout-item:hover{
      color:var(--red) !important;
      border-color:var(--red) !important;
      background:linear-gradient(180deg,#fff,#fee2e2) !important;
      box-shadow:0 12px 24px rgba(220,38,38,.14) !important;
    }
    .nav-item.active::before{
      content:'';
      position:absolute;left:0;top:0;bottom:0;width:4px;
      background:linear-gradient(180deg,var(--blue),var(--amber));
      border-radius:14px 0 0 14px;
    }
    .main{flex:1;min-width:0;padding:28px 30px 34px}
    .top{
      display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;
      padding:14px 16px;
      border:1px solid rgba(191,214,245,.92);
      border-radius:20px;
      background:rgba(243,247,255,.88);
      box-shadow:0 18px 36px rgba(15,23,42,.12);
      backdrop-filter:blur(14px);
    }
    .top-copy{display:flex;flex-direction:column;gap:6px;min-width:240px}
    .top-kicker{
      display:inline-flex;align-items:center;gap:8px;width:max-content;
      font-family:var(--font-subtitle);font-size:11px;font-weight:700;
      letter-spacing:.9px;text-transform:uppercase;color:var(--muted2);
      background:rgba(255,255,255,.9);border:1px solid rgba(250,204,21,.45);border-radius:999px;padding:7px 11px;
    }
    .top h1{margin:0;font-size:1.5rem;letter-spacing:-.5px}
    .top-sub{
      margin:0;
      color:var(--text2);
      font-size:14px;
      max-width:620px;
      line-height:1.5;
    }
    .admin-dt{
      display:flex;align-items:center;gap:10px;
      padding:.75rem 1.15rem;min-height:68px;
      background:linear-gradient(180deg,#ffffff,#eef3ff);
      border:1.6px solid rgba(191,214,245,.92);
      border-radius:16px;
      color:var(--text);white-space:nowrap;
      box-shadow:0 14px 26px rgba(15,23,42,.08), inset 0 1px 0 rgba(255,255,255,.82);
      backdrop-filter:blur(10px);
    }
    .admin-dt svg{width:24px;height:18px;stroke:var(--blue);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
    .admin-time-block{display:flex;flex-direction:column;line-height:1.05}
    .admin-clock{
      font-family:var(--font-subtitle);
      font-size:1.08rem;font-weight:800;letter-spacing:1px;color:var(--text);
      text-shadow:none;
    }
    .admin-date{
      font-family:var(--font-subtitle);
      font-size:.66rem;font-weight:700;letter-spacing:.7px;color:var(--muted2);
      margin-top:4px;
    }
    .chip{
      display:inline-flex;align-items:center;gap:7px;
      font-size:12px;color:var(--blue-deep);
      background:#fff;border:1px solid var(--border);
      padding:8px 11px;border-radius:999px;text-decoration:none;font-weight:700;
    }
    .chip svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.9}
    .msg{padding:11px 12px;border-radius:10px;margin-top:12px;font-size:13px;font-weight:600}
    .ok{background:var(--blue-soft);border:1px solid var(--blue-border);color:var(--blue-deep)}
    .err{background:var(--accent-soft);border:1px solid var(--red-border);color:var(--accent-deep)}
    .section{
      margin-top:18px;background:linear-gradient(180deg, rgba(248,251,255,.94), rgba(255,255,255,.92));
      border:1px solid var(--border);border-radius:22px;
      padding:18px;box-shadow:0 18px 40px rgba(15,23,42,.10);
      backdrop-filter:blur(12px);
    }
    .section-head{
      display:flex;align-items:center;gap:9px;
      margin:0 0 10px;font-size:1.35rem;letter-spacing:-.4px;
    }
    .section-intro{
      margin:0 0 14px;
      color:var(--muted);
      font-size:14px;
      line-height:1.55;
      max-width:760px;
    }
    .section-bar{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:14px;
      flex-wrap:wrap;
      margin-bottom:14px;
    }
    .section-bar-copy{display:flex;flex-direction:column;min-width:220px}
    .section-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      width:max-content;
      margin-bottom:8px;
      padding:7px 11px;
      border-radius:999px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.78);
      color:var(--muted2);
      font:700 11px var(--font-subtitle);
      letter-spacing:.8px;
      text-transform:uppercase;
    }
    .section-note{
      margin:0;
      padding:12px 14px;
      max-width:360px;
      border:1px solid var(--border);
      border-radius:14px;
      background:rgba(255,255,255,.88);
      color:var(--text);
      font-size:13px;
      line-height:1.5;
      box-shadow:var(--shadow-sm);
    }
    .section-actions{
      display:flex;
      align-items:stretch;
      gap:12px;
      flex-wrap:wrap;
    }
    .alert-mini{
      min-width:260px;
      max-width:420px;
      padding:12px 14px;
      border:1px solid var(--border);
      border-radius:14px;
      background:rgba(255,255,255,.9);
      box-shadow:var(--shadow-sm);
    }
    .alert-mini-label{
      display:block;
      margin-bottom:6px;
      color:var(--muted2);
      font:700 11px var(--font-subtitle);
      letter-spacing:.8px;
      text-transform:uppercase;
    }
    .alert-mini strong{
      display:block;
      margin-bottom:4px;
      color:var(--text);
      font-size:15px;
    }
    .alert-mini p{
      margin:0;
      color:var(--muted);
      font-size:13px;
      line-height:1.45;
    }
    .alert-mini-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top:10px;
    }
    .alert-mini-actions form{margin:0}
    .section-head svg{
      width:22px;height:22px;stroke:var(--amber-strong);fill:none;stroke-width:1.9;
      stroke-linecap:round;stroke-linejoin:round;
      overflow:visible;flex-shrink:0;
    }
    .tab-panel{display:none}
    .tab-panel.active{display:block}
    .stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:11px}
    .kpi{
      border:1px solid var(--border);
      border-radius:18px;padding:14px 12px;background:linear-gradient(180deg,#ffffff,#f3f7ff);
      box-shadow:0 12px 28px rgba(15,23,42,.08);
      position:relative;overflow:hidden;
    }
    .kpi::before{
      content:'';position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:18px 0 0 18px;background:var(--amber-dark);
    }
    .kpi:nth-child(2)::before{background:#60a5fa}
    .kpi:nth-child(3)::before{background:var(--blue)}
    .kpi:nth-child(4)::before{background:var(--accent)}
    .kpi .k{
      font-family:var(--font-subtitle);
      font-size:11px;color:var(--muted2);text-transform:uppercase;font-weight:700;letter-spacing:.8px
    }
    .kpi .v{font-size:30px;font-weight:900;margin-top:4px;line-height:1}
    .chart-grid{
      margin-top:12px;
      display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:11px;
    }
    .chart-card{
      border:1px solid var(--border);
      border-radius:18px;
      padding:14px;
      background:rgba(255,255,255,.92);
      box-shadow:0 12px 28px rgba(15,23,42,.08);
    }
    .chart-title{
      font-family:var(--font-subtitle);
      font-size:11px;text-transform:uppercase;letter-spacing:.8px;color:var(--muted2);font-weight:700;
      margin-bottom:10px;
    }
    .chart-head{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
      flex-wrap:wrap;
    }
    .chart-head .chart-title{margin-bottom:0}
    .chart-controls{
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
    }
    .chart-select{
      min-width:132px;
      padding:8px 10px;
      border:1px solid var(--border);
      border-radius:12px;
      background:var(--bg);
      color:var(--text);
      font:700 12px var(--font-body);
    }
    .chart-canvas{
      width:100%;
      height:250px !important;
      max-height:250px;
      display:block;
    }
    .chart-canvas.compact{height:220px !important;max-height:220px}
    .filters{
      display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;
      padding:14px;border:1px solid var(--border);border-radius:18px;background:rgba(255,255,255,.9);
    }
    .filter-controls{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
      gap:10px;
      flex:1;
      min-width:min(100%,460px);
    }
    .filter-actions{
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
    }
    .filters .f{display:flex;flex-direction:column;gap:4px}
    .filters label{
      font-family:var(--font-subtitle);
      font-size:11px;color:var(--muted2);font-weight:700;text-transform:uppercase;letter-spacing:.8px
    }
    .filters input,.filters select{
      padding:9px;border:1px solid #d8cdbd;border-radius:8px;font-family:var(--font-body)
    }
    .btn{
      padding:9px 12px;border:1px solid #d8cdbd;border-radius:9px;background:#fff;
      cursor:pointer;font-weight:700;text-decoration:none;color:#1f1a12;font-family:var(--font-body)
    }
    .btn:hover{border-color:var(--border-strong);background:#fff7eb}
    .btn.primary{background:var(--amber);border-color:var(--amber);color:#fff}
    .btn.primary:hover{background:#b45309}
    .btn.danger{background:#dc2626;border-color:#dc2626;color:#fff}
    .btn.danger:hover{background:#b91c1c;border-color:#b91c1c}
    .pager{
      margin-top:10px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;
      padding:10px 12px;border:1px solid var(--border);border-radius:18px;background:rgba(255,255,255,.94);
    }
    .pager-meta{
      font-size:13px;color:var(--muted);
      font-family:var(--font-subtitle);
    }
    .pager-links{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .page-link{
      display:inline-flex;align-items:center;justify-content:center;min-width:34px;height:32px;
      padding:0 10px;border:1px solid var(--border);border-radius:8px;background:#fff;
      text-decoration:none;color:var(--text);font-weight:700;font-size:13px;
    }
    .page-link.active{background:var(--blue-soft);border-color:var(--blue);color:var(--blue)}
    .page-link:hover{border-color:var(--blue);background:#eef4ff}
    .table-wrap{
      margin-top:10px;border:1px solid var(--border);border-radius:18px;overflow:auto;background:rgba(255,255,255,.95);
    }
    .pager{
      margin-top:12px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;
      color:var(--muted);font-size:13px;
    }
    .pager-actions{display:flex;align-items:center;gap:8px}
    .pager .btn[aria-disabled="true"]{opacity:.45;pointer-events:none}
    table{width:100%;border-collapse:collapse;min-width:760px}
    th,td{padding:10px;border-bottom:1px solid rgba(15,23,42,.08);text-align:left;font-size:14px;vertical-align:top}
    th{
      font-family:var(--font-subtitle);font-size:11px;text-transform:uppercase;
      color:var(--muted);letter-spacing:.8px;background:#fffaf2;position:sticky;top:0;z-index:1;
    }
    tbody tr:hover{background:rgba(239,246,255,.82)}
    .row-form{
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(160px, 1fr));
      gap:8px;
      align-items:center;
    }
    .row-form > *{min-width:0}
    .row-form input{
      width:100%;
      padding:8px;border:1px solid #d8cdbd;border-radius:8px;font-family:var(--font-body)
    }
    .row-form label{white-space:nowrap}
    .row-form .btn{justify-self:start;white-space:nowrap}
    .dispatchers-top{
      display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;
      margin-bottom:10px;
    }
    .dispatchers-top p{margin:0;color:var(--muted);font-size:14px;line-height:1.5;max-width:620px}
    .dispatcher-grid{
      display:grid;
      grid-template-columns:repeat(auto-fill, minmax(270px, 1fr));
      gap:10px;
    }
    .dispatcher-card{
      background:linear-gradient(180deg, rgba(255,255,255,.96), rgba(243,247,255,.92));border:1px solid var(--border);border-radius:18px;padding:14px;
      box-shadow:0 12px 28px rgba(15,23,42,.08);
    }
    .dispatcher-user{
      display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:10px;
    }
    .dispatcher-badges{
      display:flex;
      flex-direction:column;
      align-items:flex-end;
      gap:6px;
    }
    .dispatcher-meta{
      display:grid;
      gap:8px;
      margin-bottom:12px;
    }
    .dispatcher-meta-item{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:10px 11px;
      border:1px solid rgba(191,214,245,.8);
      border-radius:12px;
      background:#f8fbff;
      font-size:13px;
    }
    .dispatcher-meta-item strong{
      font-family:var(--font-subtitle);
      font-size:11px;
      letter-spacing:.7px;
      text-transform:uppercase;
      color:var(--muted2);
      font-weight:700;
    }
    .dispatcher-name{font-size:19px;font-weight:900;line-height:1.05;margin:0 0 4px}
    .dispatcher-sub{font-size:13px;color:var(--muted);line-height:1.4}
    .dispatcher-pill{
      font-family:var(--font-subtitle);
      font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;
      border-radius:999px;padding:4px 8px;border:1px solid var(--border);
      background:#f8fbff;color:var(--blue-deep);
      white-space:nowrap;
    }
    .dispatcher-pill.off{background:#fef2f2;border-color:#fecaca;color:#991b1b}
    .dispatcher-pill.online{background:#ecfdf3;border-color:#86efac;color:#166534}
    .dispatcher-pill.offline{background:#f3f4f6;border-color:#d1d5db;color:#4b5563}
    .dispatcher-actions{display:flex;gap:8px;flex-wrap:wrap}
    .dispatcher-actions .btn{display:inline-flex;align-items:center;gap:6px}
    .dispatcher-actions .btn svg{
      width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;
      stroke-linecap:round;stroke-linejoin:round;overflow:visible;
    }
    .btn.warn{background:linear-gradient(180deg,#fff,#fff7ed);border-color:#fdba74;color:#c2410c}
    .btn.warn:hover{background:#ffedd5;color:#9a3412}
    .modal-backdrop{
      position:fixed;inset:0;background:rgba(15,23,42,.35);
      display:none;align-items:center;justify-content:center;
      z-index:1200;padding:14px;
    }
    .modal-backdrop.show{display:flex}
    .modal{
      width:min(560px, 100%);
      background:linear-gradient(180deg,#fffdf9,#ffffff);border:1px solid var(--border);
      border-radius:20px;box-shadow:0 18px 42px rgba(15,23,42,.18);
      overflow:hidden;
    }
    .modal-head{
      display:flex;align-items:center;justify-content:space-between;gap:10px;
      padding:12px 14px;border-bottom:1px solid var(--border);background:linear-gradient(180deg,#f8fbff,#eef5ff);
    }
    .modal-title{margin:0;font-size:1.08rem}
    .modal-close{
      border:1px solid var(--border);background:#fff;border-radius:9px;
      padding:6px 10px;cursor:pointer;font-weight:700;
    }
    .modal-close:hover{background:#eef4ff}
    .modal-form{padding:13px 14px 14px;display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .modal-field{display:flex;flex-direction:column;gap:5px}
    .modal-field label{
      font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;
      color:var(--muted2);font-family:var(--font-subtitle);
    }
    .modal-field input,
    .modal-field select,
    .modal-field textarea{width:100%;padding:10px;border:1px solid #d8cdbd;border-radius:9px;font-family:var(--font-body)}
    .modal-field textarea{min-height:110px;resize:vertical}
    .modal-field.full{grid-column:1 / -1}
    .modal-check{grid-column:1 / -1;display:flex;align-items:center;gap:8px;color:var(--text2);font-weight:600}
    .modal-actions{grid-column:1 / -1;display:flex;justify-content:flex-end;gap:8px;padding-top:2px}
    .delete-body{padding:14px}
    .delete-body p{margin:0 0 10px;color:var(--text2)}
    .delete-username{font-weight:900}
    @media(max-width:1120px){
      .stats{grid-template-columns:1fr 1fr}
      .chart-grid{grid-template-columns:1fr}
      .row-form{grid-template-columns:1fr 1fr}
    }
    @media(max-width:860px){
      .layout{flex-direction:column}
      .side{width:100%;height:auto;position:static}
      .main{padding:14px}
      .stats{grid-template-columns:1fr}
      .nav{display:grid;grid-template-columns:1fr 1fr;gap:10px}
      .nav-item,.nav button{padding:13px 12px;font-size:14px}
      .brand-wrap{margin-bottom:10px}
    }
    @media(max-width:560px){
      .layout{flex-direction:column}
      .side{width:100%;height:auto;position:static;border-right:none;box-shadow:none}
      .main{padding:16px}
      .section{padding:14px;border-radius:18px}
      .top{flex-direction:column;align-items:flex-start;padding:14px 16px}
      .top h1{font-size:1.3rem}
      .top-sub{font-size:13px}
      .kpi .v{font-size:24px}
      .chart-canvas{height:220px !important;max-height:220px}
      .chart-canvas.compact{height:200px !important;max-height:200px}
      .nav{grid-template-columns:repeat(2,1fr)}
      .nav-item,.nav button{padding:11px 12px;font-size:13px}
      .row-form,.modal-form{grid-template-columns:1fr}
      .filter-actions{width:100%}
      .filter-actions .btn{flex:1;justify-content:center;text-align:center}
      .section-note{max-width:none;width:100%}
      .dispatcher-meta-item{align-items:flex-start;flex-direction:column}
    }

    /* modern polish */
    body::before{
      content:'';
      position:fixed; inset:0; pointer-events:none; z-index:0;
      background:
        linear-gradient(rgba(255,255,255,.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.06) 1px, transparent 1px);
      background-size: 40px 40px;
      mask-image: radial-gradient(circle at center, rgba(0,0,0,.92), rgba(0,0,0,.24));
    }
    .layout{position:relative; z-index:1}
    .side{
      background:
        radial-gradient(220px 140px at 50% 0, rgba(250,204,21,.18), transparent 78%),
        linear-gradient(180deg, rgba(244,248,255,.94) 0%, rgba(235,243,255,.96) 46%, rgba(255,247,239,.98) 100%);
      box-shadow: 20px 0 44px rgba(15,23,42,.08);
    }
    .brand-wrap{
      padding:10px 12px 18px;
      margin-bottom:18px;
    }
    .nav{gap:10px}
    .nav-item,.nav button{
      box-shadow:0 9px 18px rgba(15,23,42,.08);
    }
    .main{padding:24px 24px 28px}
    .top{
      padding:14px 16px;
      background:rgba(243,247,255,.88);
      border-radius:20px;
      box-shadow:0 18px 36px rgba(15,23,42,.12);
    }
    .section{
      margin-top:18px;
      padding:18px;
      border-radius:22px;
      background:linear-gradient(180deg, rgba(248,251,255,.94), rgba(255,255,255,.92));
      box-shadow:0 18px 40px rgba(15,23,42,.10);
      backdrop-filter: blur(12px);
    }
    .stats{gap:14px}
    .kpi,.chart-card,.filters,.table-wrap,.pager,.dispatcher-card,.modal{
      box-shadow:0 12px 28px rgba(15,23,42,.08);
    }
    .kpi,.chart-card,.filters,.pager,.dispatcher-card{
      border-radius:18px;
    }
    .kpi{
      background:linear-gradient(180deg, rgba(255,255,255,.96), rgba(243,247,255,.92));
    }
    .chart-card{
      padding:14px;
      background:rgba(255,255,255,.92);
    }
    .filters{
      padding:14px;
      background:rgba(255,255,255,.9);
    }
    .btn,.chart-select,.filters input,.row-form input,.modal-field input{
      border-radius:12px;
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, background .18s ease;
    }
    .btn:hover,.chart-select:hover,.filters input:hover,.row-form input:hover,.modal-field input:hover{
      transform:translateY(-1px);
      box-shadow:0 8px 18px rgba(15,23,42,.08);
    }
    .table-wrap{
      background:rgba(255,255,255,.95);
      border-radius:18px;
      overflow:auto;
    }
    .table-wrap table{min-width:860px}
    th{
      background:linear-gradient(180deg,#f8fbff,#eef5ff);
      backdrop-filter: blur(8px);
    }
    td{border-bottom:1px solid rgba(15,23,42,.08)}
    .dispatcher-card{
      padding:14px;
      background:linear-gradient(180deg, rgba(255,255,255,.96), rgba(243,247,255,.92));
    }
    .modal{
      border-radius:20px;
      background:linear-gradient(180deg,#fffdf9,#ffffff);
    }
    .top-copy,.section-bar-copy,.filters,.dispatchers-top{position:relative;z-index:1}
    .section-note strong{color:var(--text)}
    @media(max-width:860px){
      .main{padding:14px}
      .section{border-radius:20px}
      .section-bar{margin-bottom:12px}
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="side">
      <div class="brand-wrap">
        <div class="brand">
          <img class="brand-logo" src="/images/logo.png" alt="MDRRMO SVS Logo">
          <span>SVS Admin Dashboard</span>
        </div>
        <div class="sub">System Administrator</div>
      </div>
      <div class="nav-title">Navigation</div>
      <nav class="nav">
        <button class="nav-item active" type="button" data-tab="dashboard">
          <svg viewBox="0 0 24 24"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
          <span class="nav-label">Dashboard</span>
        </button>
        <button class="nav-item" type="button" data-tab="reports">
          <svg viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25"/></svg>
          <span class="nav-label">Reports</span>
        </button>
        <button class="nav-item" type="button" data-tab="dispatchers">
          <svg viewBox="0 0 24 24"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0M4.5 20.25a7.5 7.5 0 0 1 15 0"/></svg>
          <span class="nav-label">Dispatchers</span>
        </button>
        <button class="nav-item" type="button" data-tab="audit">
          <svg viewBox="0 0 24 24"><path d="M12 6v6l4 2m5-2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          <span class="nav-label">Audit Trail</span>
        </button>
        <form method="get" action="/admin/logout" style="margin:0" id="adminLogoutForm">
          <button class="logout-item" type="submit">
            <svg viewBox="0 0 24 24"><path d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6A2.25 2.25 0 0 0 5.25 5.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3-3-3-3m3 3-3 3m3-3H9"/></svg>
            <span class="nav-label">Logout</span>
          </button>
        </form>
      </nav>
    </aside>

    <main class="main">
      <div class="top">
        <div class="top-copy">
          <span class="top-kicker">Control Center</span>
          <h1>SVS Admin Console</h1>
          <p class="top-sub">Monitor reports, manage dispatchers, and review operational history with a calmer, more polished console that keeps the key controls within reach.</p>
        </div>
        <div class="admin-dt" id="adminDateTime">
          <svg viewBox="0 0 24 24"><path d="M6.75 3v2.25m10.5-2.25v2.25M3.75 9.75h16.5M4.5 5.25h15A1.5 1.5 0 0 1 21 6.75v12A1.5 1.5 0 0 1 19.5 20.25h-15A1.5 1.5 0 0 1 3 18.75v-12A1.5 1.5 0 0 1 4.5 5.25Z"/></svg>
          <div class="admin-time-block">
            <div class="admin-clock" id="adminClock">--:--:--</div>
            <div class="admin-date" id="adminDate">--- --- --/--/----</div>
          </div>
        </div>
      </div>
      <% if (success) { %><div class="msg ok"><%= success %></div><% } %>
      <% if (error) { %><div class="msg err"><%= error %></div><% } %>

      <section class="section tab-panel active" id="dashboard" data-panel="dashboard">
        <div class="section-bar">
          <div class="section-bar-copy">
            <span class="section-badge">Live Overview</span>
            <h2 class="section-head">
              <svg viewBox="0 0 24 24"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
              Dashboard
            </h2>
            <p class="section-intro">Start here for the current system picture. The cards and charts summarize report volume, dispatcher readiness, and false report trends without changing the underlying admin process.</p>
          </div>
          <div class="section-actions">
            <div class="alert-mini">
              <span class="alert-mini-label">Admin Alert</span>
              <% if (latestAlert) { %>
                <strong><%= latestAlert.title || 'Active alert' %></strong>
                <p><%= latestAlert.disasterType || 'General' %> - <%= latestAlert.severity || 'High' %><br><%= latestAlert.message || 'No message provided.' %></p>
                <div class="alert-mini-actions">
                  <button
                    class="btn"
                    type="button"
                    id="editLatestAlertBtn"
                    data-alert-id="<%= latestAlert._id %>"
                    data-alert-title="<%= latestAlert.title || '' %>"
                    data-alert-type="<%= latestAlert.disasterType || 'General' %>"
                    data-alert-severity="<%= latestAlert.severity || 'High' %>"
                    data-alert-message="<%= latestAlert.message || '' %>"
                    data-alert-active="<%= latestAlert.active === false ? '0' : '1' %>">Edit</button>
                  <form method="post" action="/admin/alerts/<%= latestAlert._id %>/delete">
                    <input type="hidden" name="tab" value="dashboard">
                    <input type="hidden" name="reportPage" value="<%= (reportPagination && reportPagination.page) || 1 %>">
                    <input type="hidden" name="auditPage" value="<%= (auditPagination && auditPagination.page) || 1 %>">
                    <button class="btn danger" type="submit">Delete</button>
                  </form>
                </div>
              <% } else { %>
                <strong>No active alert</strong>
                <p>Use the button below to publish a dashboard alert for current operations.</p>
              <% } %>
            </div>
            <div style="display:flex;align-items:flex-start">
              <button class="btn danger" type="button" id="openAlertModal">Send Alert</button>
            </div>
          </div>
        </div>
        <div class="stats">
          <div class="kpi"><div class="k">Reports (Filtered)</div><div class="v" id="statTotalReports"><%= stats.totalReports %></div></div>
          <div class="kpi"><div class="k">Dispatchers</div><div class="v" id="statTotalDispatchers"><%= stats.totalDispatchers %></div></div>
          <div class="kpi"><div class="k">Active Dispatchers</div><div class="v" id="statActiveDispatchers"><%= stats.activeDispatchers %></div></div>
          <div class="kpi"><div class="k">Audit Entries</div><div class="v" id="statAuditCount"><%= stats.auditCount %></div></div>
        </div>
        <div class="chart-grid">
          <div class="chart-card">
            <div class="chart-head">
              <div class="chart-title" id="trendChartTitle">Reports Trend (Daily)</div>
              <div class="chart-controls">
                <select id="trendRangeSelect" class="chart-select" aria-label="Reports trend range">
                  <option value="daily" selected>Daily</option>
                  <option value="last-day">Last Day</option>
                  <option value="weekly">Weekly</option>
                  <option value="last-week">Last Week</option>
                  <option value="monthly">Monthly</option>
                  <option value="last-month">Last Month</option>
                  <option value="yearly">Yearly</option>
                  <option value="last-year">Last Year</option>
                </select>
              </div>
            </div>
            <canvas id="trendChart" class="chart-canvas"></canvas>
          </div>
          <div class="chart-card">
            <div class="chart-head">
              <div class="chart-title" id="severityChartTitle">Emergency Level</div>
              <div class="chart-controls">
                <select id="severityTypeSelect" class="chart-select" aria-label="Emergency level type filter">
                  <option value="all" selected>All Types</option>
                </select>
              </div>
            </div>
            <canvas id="severityChart" class="chart-canvas compact"></canvas>
          </div>
          <div class="chart-card">
            <div class="chart-title">False Reports</div>
            <canvas id="falseChart" class="chart-canvas compact"></canvas>
          </div>
        </div>
      </section>

      <section class="section tab-panel" id="reports" data-panel="reports">
        <div class="section-bar">
          <div class="section-bar-copy">
            <span class="section-badge">Report Records</span>
            <h2 class="section-head">
              <svg viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25"/></svg>
              Reports
            </h2>
            <p class="section-intro">Filter historical reports, review ownership and severity, and export records. The workflow is unchanged, but the controls are grouped to make routine admin work faster.</p>
          </div>
          <p class="section-note"><strong>Use this table when checking accountability.</strong> Keep the row count lean and add more only when needed so live operations stay easy to scan.</p>
        </div>
        <form class="filters" method="get" action="/admin">
          <input type="hidden" name="tab" value="reports">
          <input type="hidden" name="reportPage" value="1">
          <input type="hidden" name="auditPage" value="<%= (auditPagination && auditPagination.page) || 1 %>">
          <div class="filter-controls">
            <div class="f">
              <label for="from">From</label>
              <input id="from" type="date" name="from" value="<%= from || '' %>">
            </div>
            <div class="f">
              <label for="to">To</label>
              <input id="to" type="date" name="to" value="<%= to || '' %>">
            </div>
            <div class="f">
              <label for="reportIdTypeFilter">ID Type</label>
              <select id="reportIdTypeFilter" aria-label="Filter reports by ID type">
                <option value="all" selected>All</option>
                <option value="RPT">RPT</option>
                <option value="SOS">SOS</option>
              </select>
            </div>
          </div>
          <div class="filter-actions">
            <button class="btn" type="submit">Apply</button>
            <a class="btn" href="/admin?tab=reports&auditPage=<%= (auditPagination && auditPagination.page) || 1 %>&reportPage=1">Reset</a>
            <a class="btn" href="/admin/reports/export.xls?tab=reports&from=<%= encodeURIComponent(from || '') %>&to=<%= encodeURIComponent(to || '') %>">Export Excel</a>
            <a class="btn" href="/admin/reports/export.pdf?tab=reports&from=<%= encodeURIComponent(from || '') %>&to=<%= encodeURIComponent(to || '') %>">Export PDF</a>
          </div>
        </form>
        <div class="table-wrap">
          <table>
            <thead><tr><th>ID</th><th>Type</th><th>Status</th><th>Claimed By</th><th>Current Dispatcher</th><th>Pass Count</th><th>Severity</th><th>Reporter</th><th>Location</th><th>Timestamp</th></tr></thead>
            <tbody id="reportsTableBody">
              <% reports.forEach(function(r){ %>
              <% const claimedBy = r.claimedByUsername || r.claimedByName || r.dispatcherName || '-'; %>
              <% const currentDispatcher = r.assignedToUsername || r.assignedToName || '-'; %>
              <% const passCount = Math.max(0, Number(r.passCount) || 0); %>
              <% const reportId = r.reportId || r._id || ''; %>
              <% const reportKind = String(reportId).split('-')[0] || 'OTHER'; %>
              <tr class="report-row" data-report-kind="<%= reportKind %>">
                <td><%= r.reportId || r._id %></td>
                <td><%= r.emergencyType || '-' %></td>
                <td><%= r.status || '-' %></td>
                <td><%= claimedBy %></td>
                <td><%= currentDispatcher %></td>
                <td><%= passCount %></td>
                <td><%= r.severity || '-' %></td>
                <td><%= r.name || '-' %><br><span style="font-size:12px;color:#6f644f"><%= r.contact || '-' %></span></td>
                <td><%= [r.street, r.landmark, r.barangay].filter(Boolean).join(', ') || '-' %></td>
                <td><%= new Date(r.timestamp).toLocaleString() %></td>
              </tr>
              <% }) %>
              <tr id="reportFilterEmptyState" style="display:none">
                <td colspan="10" style="text-align:center;color:#6f644f">No reports match the selected ID type.</td>
              </tr>
            </tbody>
          </table>
        </div>
        <% const rp = reportPagination || { page: 1, totalPages: 1, totalCount: 0, hasPrev: false, hasNext: false }; %>
        <% const reportsBase = '/admin?tab=reports&from=' + encodeURIComponent(from || '') + '&to=' + encodeURIComponent(to || '') + '&auditPage=' + encodeURIComponent((auditPagination && auditPagination.page) || 1); %>
        <div class="pager" id="reportsPager">
          <div id="reportsPagerSummary">Showing page <strong><%= rp.page %></strong> of <strong><%= rp.totalPages %></strong> (<%= rp.totalCount %> reports)</div>
          <div class="pager-actions">
            <a class="btn" id="reportsPrevLink" href="<%= reportsBase %>&reportPage=<%= rp.page - 1 %>" aria-disabled="<%= rp.hasPrev ? 'false' : 'true' %>">Previous</a>
            <a class="btn" id="reportsNextLink" href="<%= reportsBase %>&reportPage=<%= rp.page + 1 %>" aria-disabled="<%= rp.hasNext ? 'false' : 'true' %>">Next</a>
          </div>
        </div>
      </section>

      <section class="section tab-panel" id="dispatchers" data-panel="dispatchers">
        <div class="section-bar">
          <div class="section-bar-copy">
            <span class="section-badge">Account Management</span>
            <h2 class="section-head">
              <svg viewBox="0 0 24 24"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0M4.5 20.25a7.5 7.5 0 0 1 15 0"/></svg>
              Dispatchers
            </h2>
            <p class="section-intro">Manage dispatcher accounts in a cleaner card view. Edit, activate, and remove users without changing the existing account process or modal flows.</p>
          </div>
        </div>
        <div class="dispatchers-top">
          <p>Each card surfaces the most important account details first, so admin changes can be made with less scanning.</p>
          <button class="btn primary" type="button" id="openAddDispatcher">Add Dispatcher</button>
        </div>
        <div class="dispatcher-grid">
          <% dispatchers.forEach(function(d){ %>
          <article class="dispatcher-card" data-dispatcher-card data-dispatcher-id="<%= d._id %>">
            <div class="dispatcher-user">
              <div>
                <h3 class="dispatcher-name"><%= d.username %></h3>
                <div class="dispatcher-sub"><%= d.fullName || '-' %> - <%= d.phone || '-' %></div>
              </div>
              <div class="dispatcher-badges">
                <span class="dispatcher-pill <%= d.isOnline ? 'online' : 'offline' %>" data-dispatcher-online-status><%= d.isOnline ? 'Online' : 'Offline' %></span>
                <span class="dispatcher-pill <%= d.isActive ? '' : 'off' %>"><%= d.isActive ? 'Active' : 'Inactive' %></span>
              </div>
            </div>
            <div class="dispatcher-meta">
              <div class="dispatcher-meta-item">
                <strong>Full Name</strong>
                <span><%= d.fullName || '-' %></span>
              </div>
              <div class="dispatcher-meta-item">
                <strong>Phone</strong>
                <span><%= d.phone || '-' %></span>
              </div>
            </div>
            <div class="dispatcher-actions">
              <button
                class="btn"
                type="button"
                data-action="edit-dispatcher"
                data-id="<%= d._id %>"
                data-username="<%= d.username %>"
                data-fullname="<%= d.fullName || '' %>"
                data-phone="<%= d.phone || '' %>"
                data-active="<%= d.isActive ? '1' : '0' %>">
                <svg viewBox="0 0 24 24"><path d="m16.862 4.487 2.651 2.651M9 20.25H4.5v-4.5L14.69 5.56a1.875 1.875 0 0 1 2.652 0l1.098 1.098a1.875 1.875 0 0 1 0 2.652Z"/></svg>
                Edit
              </button>
              <button
                class="btn warn"
                type="button"
                data-action="delete-dispatcher"
                data-id="<%= d._id %>"
                data-username="<%= d.username %>">
                <svg viewBox="0 0 24 24"><path d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
                Delete
              </button>
            </div>
          </article>
          <% }) %>
        </div>
      </section>

      <section class="section tab-panel" id="audit" data-panel="audit">
        <div class="section-bar">
          <div class="section-bar-copy">
            <span class="section-badge">Action History</span>
            <h2 class="section-head">
              <svg viewBox="0 0 24 24"><path d="M12 6v6l4 2m5-2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              Audit Trail (Dispatcher Actions)
            </h2>
            <p class="section-intro">Review recorded dispatcher actions with a simpler filter area and the same audit data. This view remains read-only and process-safe.</p>
          </div>
          <p class="section-note"><strong>Use this when checking accountability.</strong> Increase rows only when needed to keep the table easier to scan on live operations.</p>
        </div>
        <div class="filters">
          <form method="get" action="/admin" class="row-form" style="width:100%;align-items:flex-end;grid-template-columns:120px 120px 1fr;gap:12px;">
            <input type="hidden" name="tab" value="audit">
            <input type="hidden" name="reportPage" value="<%= (reportPager && reportPager.currentPage) || 1 %>">
            <input type="hidden" name="reportLimit" value="<%= reportLimit || 20 %>">
            <input type="hidden" name="from" value="<%= from || '' %>">
            <input type="hidden" name="to" value="<%= to || '' %>">
            <input type="hidden" name="auditPage" value="1">
            <div class="f" style="min-width:110px;">
              <label for="auditLimitSel">Rows</label>
              <select id="auditLimitSel" name="auditLimit" class="btn" style="min-width:90px;">
                <% [10,20,40,80,100,200].forEach(function(n){ %>
                  <option value="<%= n %>" <%= Number(auditLimit) === n ? 'selected' : '' %>><%= n %></option>
                <% }) %>
              </select>
            </div>
            <div style="align-self:end;">
              <button class="btn primary" type="submit" style="min-width:80px;">Apply</button>
            </div>
          </form>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Timestamp</th><th>Dispatcher</th><th>Action</th><th>Target</th><th>Details</th></tr></thead>
            <tbody id="auditTableBody">
              <% if (auditLogs.length === 0) { %>
                <tr><td colspan="5" style="text-align:center;color:#6f644f">No audit entries found.</td></tr>
              <% } else { %>
                <% auditLogs.slice(0, Number(auditLimit) || 20).forEach(function(a){ %>
                  <tr>
                    <td><%= new Date(a.timestamp).toLocaleString() %></td>
                    <td><%= a.actorName || a.actorId || '-' %></td>
                    <td><%= a.action || '-' %></td>
                    <td><%= a.targetType || '-' %> <%= a.targetId || '' %></td>
                    <td><%= a.details || '-' %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
        <% const ap = auditPagination || { page: 1, totalPages: 1, totalCount: 0, hasPrev: false, hasNext: false }; %>
        <% const auditBase = '/admin?tab=audit&reportPage=' + encodeURIComponent((reportPagination && reportPagination.page) || 1); %>
        <div class="pager" id="auditPager">
          <div id="auditPagerSummary">Showing page <strong><%= ap.page %></strong> of <strong><%= ap.totalPages %></strong> (<%= ap.totalCount %> audit entries)</div>
          <div class="pager-actions">
            <a class="btn" id="auditPrevLink" href="<%= auditBase %>&auditPage=<%= ap.page - 1 %>" aria-disabled="<%= ap.hasPrev ? 'false' : 'true' %>">Previous</a>
            <a class="btn" id="auditNextLink" href="<%= auditBase %>&auditPage=<%= ap.page + 1 %>" aria-disabled="<%= ap.hasNext ? 'false' : 'true' %>">Next</a>
          </div>
        </div>
      </section>
    </main>
  </div>

