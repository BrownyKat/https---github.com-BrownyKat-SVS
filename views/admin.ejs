          </div>
          <div class="f">
            <label for="to">To</label>
            <input id="to" type="date" name="to" value="<%= to || '' %>">
          </div>
          <div class="f">
            <label for="reportIdTypeFilter">ID Type</label>
            <select id="reportIdTypeFilter" class="btn" aria-label="Filter reports by ID type">
              <option value="all" selected>All</option>
              <option value="RPT">RPT</option>
              <option value="SOS">SOS</option>
            </select>
          </div>
          <button class="btn" type="submit">Apply</button>
          <a class="btn" href="/admin?tab=reports&auditPage=<%= (auditPagination && auditPagination.page) || 1 %>&reportPage=1">Reset</a>
