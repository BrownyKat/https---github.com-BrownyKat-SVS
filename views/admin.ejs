  <script id="reportsSeed" type="application/json"><%- JSON.stringify(reports) %></script>
  <script id="auditSeed" type="application/json"><%- JSON.stringify(auditLogs) %></script>
  <script id="realtimeSeed" type="application/json"><%- JSON.stringify(realtime || {}) %></script>
  <script id="reportPaginationSeed" type="application/json"><%- JSON.stringify(reportPagination || { page: 1, totalPages: 1, totalCount: 0, hasPrev: false, hasNext: false }) %></script>
  <script id="auditPaginationSeed" type="application/json"><%- JSON.stringify(auditPagination || { page: 1, totalPages: 1, totalCount: 0, hasPrev: false, hasNext: false }) %></script>
  <script src="https://js.pusher.com/8.4.0/pusher.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    function safeRun(fn) {
      try { fn(); } catch (e) { console.error('[admin-ui]', e); }
    }

    window.addEventListener('pageshow', function (event) {
      if (event.persisted) {
        window.location.reload();
      }
    });

    const navItems = Array.from(document.querySelectorAll('.nav-item[data-tab]'));
    const panels = Array.from(document.querySelectorAll('.tab-panel[data-panel]'));
    const allowedTabs = new Set(navItems.map(n => n.dataset.tab));
    function showTab(tab) {
      const safeTab = allowedTabs.has(tab) ? tab : 'dashboard';
      navItems.forEach(n => n.classList.toggle('active', n.dataset.tab === safeTab));
      panels.forEach(p => p.classList.toggle('active', p.dataset.panel === safeTab));

      const url = new URL(window.location.href);
      url.searchParams.set('tab', safeTab);
      window.history.replaceState({}, '', url.toString());
    }
    navItems.forEach(n => n.addEventListener('click', () => showTab(n.dataset.tab)));
    document.querySelectorAll('[data-tab-link]').forEach(link => {
      link.addEventListener('click', (event) => {
        event.preventDefault();
        showTab(link.getAttribute('data-tab-link') || 'dashboard');
      });
    });
    const initialTab = new URLSearchParams(window.location.search).get('tab');
    if (initialTab) showTab(initialTab);

    function openModal(sel) {
      const el = document.querySelector(sel);
      if (!el) return;
      el.classList.add('show');
      el.setAttribute('aria-hidden', 'false');
    }
    function closeModal(sel) {
      const el = document.querySelector(sel);
      if (!el) return;
      el.classList.remove('show');
      el.setAttribute('aria-hidden', 'true');
    }
    document.querySelectorAll('[data-close-modal]').forEach(btn => {
      btn.addEventListener('click', () => closeModal(btn.getAttribute('data-close-modal')));
    });
    document.querySelectorAll('.modal-backdrop').forEach(backdrop => {
      backdrop.addEventListener('click', (e) => {
        if (e.target === backdrop) closeModal('#' + backdrop.id);
      });
    });
    const alertForm = document.getElementById('alertForm');
    const alertModalTitle = document.getElementById('alertModalTitle');
    const alertSubmitBtn = document.getElementById('alertSubmitBtn');
    const alertTitleInput = document.getElementById('alertTitle');
    const alertTypeInput = document.getElementById('alertType');
    const alertSeverityInput = document.getElementById('alertSeverity');
    const alertMessageInput = document.getElementById('alertMessage');
    const alertActiveInput = document.querySelector('#alertForm input[name="active"]');

    function openCreateAlertModal() {
      if (!alertForm) return;
      alertForm.action = '/admin/alerts';
      if (alertModalTitle) alertModalTitle.textContent = 'Publish Alert';
      if (alertSubmitBtn) alertSubmitBtn.textContent = 'Publish Alert';
      if (alertTitleInput) alertTitleInput.value = '';
      if (alertTypeInput) alertTypeInput.value = 'General';
      if (alertSeverityInput) alertSeverityInput.value = 'High';
      if (alertMessageInput) alertMessageInput.value = '';
      if (alertActiveInput) alertActiveInput.checked = true;
      openModal('#alertModal');
    }

    function openEditAlertModal(btn) {
      if (!btn || !alertForm) return;
      const alertId = btn.getAttribute('data-alert-id');
      if (!alertId) return;
      alertForm.action = '/admin/alerts/' + encodeURIComponent(alertId) + '/update';
      if (alertModalTitle) alertModalTitle.textContent = 'Edit Alert';
      if (alertSubmitBtn) alertSubmitBtn.textContent = 'Save Alert';
      if (alertTitleInput) alertTitleInput.value = btn.getAttribute('data-alert-title') || '';
      if (alertTypeInput) alertTypeInput.value = btn.getAttribute('data-alert-type') || 'General';
      if (alertSeverityInput) alertSeverityInput.value = btn.getAttribute('data-alert-severity') || 'High';
      if (alertMessageInput) alertMessageInput.value = btn.getAttribute('data-alert-message') || '';
      if (alertActiveInput) alertActiveInput.checked = btn.getAttribute('data-alert-active') !== '0';
      openModal('#alertModal');
    }

    document.getElementById('openAddDispatcher')?.addEventListener('click', () => openModal('#addDispatcherModal'));
    document.getElementById('openAlertModal')?.addEventListener('click', openCreateAlertModal);
    document.getElementById('editLatestAlertBtn')?.addEventListener('click', function () {
      openEditAlertModal(this);
    });

    const editForm = document.getElementById('editDispatcherForm');
    const deleteForm = document.getElementById('deleteDispatcherForm');
    const deleteName = document.getElementById('deleteDispatcherName');
    document.querySelectorAll('[data-action="edit-dispatcher"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        if (!id || !editForm) return;
        editForm.action = '/admin/dispatchers/' + encodeURIComponent(id) + '/update?tab=dispatchers';
        document.getElementById('editUsername').value = btn.getAttribute('data-username') || '';
        document.getElementById('editFullName').value = btn.getAttribute('data-fullname') || '';
        document.getElementById('editPhone').value = btn.getAttribute('data-phone') || '';
        document.getElementById('editNewPassword').value = '';
        document.getElementById('editIsActive').checked = btn.getAttribute('data-active') === '1';
        openModal('#editDispatcherModal');
      });
    });
    document.querySelectorAll('[data-action="delete-dispatcher"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const username = btn.getAttribute('data-username') || 'this dispatcher';
        if (!id || !deleteForm) return;
        deleteForm.action = '/admin/dispatchers/' + encodeURIComponent(id) + '/delete?tab=dispatchers';
        if (deleteName) deleteName.textContent = username;
        openModal('#deleteDispatcherModal');
      });
    });
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll('.modal-backdrop.show').forEach(m => closeModal('#' + m.id));
    });

    function parseJsonSeed(id, fallback) {
      try {
        const el = document.getElementById(id);
        if (!el) return fallback;
        return JSON.parse(el.textContent || JSON.stringify(fallback));
      } catch (_e) {
        return fallback;
      }
    }

    const realtimeCfg = parseJsonSeed('realtimeSeed', {});
    const pusher = (realtimeCfg.key && realtimeCfg.cluster && window.Pusher)
      ? new Pusher(realtimeCfg.key, { cluster: realtimeCfg.cluster, forceTLS: true })
      : null;
    const channel = pusher ? pusher.subscribe(realtimeCfg.channel || 'mdrrmo-reports') : null;

    function safeArr(v){ return Array.isArray(v) ? v : []; }
    function escHtml(v) {
      return String(v == null ? '' : v)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }
    function toNum(v) {
      const n = Number(v);
      return Number.isFinite(n) ? n : 0;
    }
    function formatDateTime(value) {
      const d = new Date(value);
      return Number.isNaN(d.getTime()) ? '-' : d.toLocaleString();
    }
    function buildReportLocation(r) {
      const parts = [r && r.street, r && r.landmark, r && r.barangay].filter(Boolean);
      return parts.join(', ') || '-';
    }
    function reportRowHtml(r) {
      const claimedBy = (r && (r.claimedByUsername || r.claimedByName || r.dispatcherName)) || '-';
      const currentDispatcher = (r && (r.assignedToUsername || r.assignedToName)) || '-';
      const passCount = Math.max(0, toNum(r && r.passCount));
      const reportId = (r && (r.reportId || r._id)) || '';
      const reportKind = String(reportId).split('-')[0] || 'OTHER';
      return `
        <tr class="report-row" data-report-kind="${escHtml(reportKind)}">
          <td>${escHtml(reportId || '-')}</td>
          <td>${escHtml((r && r.emergencyType) || '-')}</td>
          <td>${escHtml((r && r.status) || '-')}</td>
          <td>${escHtml(claimedBy)}</td>
          <td>${escHtml(currentDispatcher)}</td>
          <td>${passCount}</td>
          <td>${escHtml((r && r.severity) || '-')}</td>
          <td>${escHtml((r && r.name) || '-')}<br><span style="font-size:12px;color:#6f644f">${escHtml((r && r.contact) || '-')}</span></td>
          <td>${escHtml(buildReportLocation(r))}</td>
          <td>${escHtml(formatDateTime(r && r.timestamp))}</td>
        </tr>`;
    }
    function auditRowHtml(a) {
      return `
        <tr>
          <td>${escHtml(formatDateTime(a && a.timestamp))}</td>
          <td>${escHtml((a && (a.actorName || a.actorId)) || '-')}</td>
          <td>${escHtml((a && a.action) || '-')}</td>
          <td>${escHtml(`${(a && a.targetType) || '-'} ${(a && a.targetId) || ''}`.trim())}</td>
          <td>${escHtml((a && a.details) || '-')}</td>
        </tr>`;
    }

    let reportsData = [];
    try {
      reportsData = JSON.parse(document.getElementById('reportsSeed').textContent || '[]');
    } catch (_e) { reportsData = []; }
    reportsData = safeArr(reportsData);

    let auditLogsData = [];
    try {
      auditLogsData = JSON.parse(document.getElementById('auditSeed').textContent || '[]');
    } catch (_e) { auditLogsData = []; }
    auditLogsData = safeArr(auditLogsData);

    let adminStats = {
      totalReports: toNum(document.getElementById('statTotalReports') && document.getElementById('statTotalReports').textContent),
      totalDispatchers: toNum(document.getElementById('statTotalDispatchers') && document.getElementById('statTotalDispatchers').textContent),
      activeDispatchers: toNum(document.getElementById('statActiveDispatchers') && document.getElementById('statActiveDispatchers').textContent),
      auditCount: toNum(document.getElementById('statAuditCount') && document.getElementById('statAuditCount').textContent),
    };
    let reportPaginationState = parseJsonSeed('reportPaginationSeed', {
      page: 1, totalPages: 1, totalCount: 0, hasPrev: false, hasNext: false
    });
    let auditPaginationState = parseJsonSeed('auditPaginationSeed', {
      page: 1, totalPages: 1, totalCount: 0, hasPrev: false, hasNext: false
    });
    const dispatcherStatusCards = Array.from(document.querySelectorAll('[data-dispatcher-card]'));

    const severityLevels = ['Low', 'Medium', 'High'];
    const trendRangeSelect = document.getElementById('trendRangeSelect');
    const trendChartTitle = document.getElementById('trendChartTitle');
    const severityTypeSelect = document.getElementById('severityTypeSelect');
    const severityChartTitle = document.getElementById('severityChartTitle');
    const reportIdTypeFilter = document.getElementById('reportIdTypeFilter');
    let reportRows = Array.from(document.querySelectorAll('.report-row'));
    let reportFilterEmptyState = document.getElementById('reportFilterEmptyState');

    function applyDispatcherStatuses(items) {
      const statusMap = new Map();
      safeArr(items).forEach((item) => {
        const id = String(item && item.id || '').trim();
        if (id) statusMap.set(id, !!(item && item.isOnline));
      });
      dispatcherStatusCards.forEach((card) => {
        const id = card.getAttribute('data-dispatcher-id') || '';
        const statusEl = card.querySelector('[data-dispatcher-online-status]');
        if (!id || !statusEl || !statusMap.has(id)) return;
        const isOnline = !!statusMap.get(id);
        statusEl.textContent = isOnline ? 'Online' : 'Offline';
        statusEl.classList.toggle('online', isOnline);
        statusEl.classList.toggle('offline', !isOnline);
      });
    }

    let dispatcherStatusPollTimer = null;
    let dispatcherStatusFetchInFlight = false;
    async function refreshDispatcherStatuses() {
      if (dispatcherStatusFetchInFlight) return;
      dispatcherStatusFetchInFlight = true;
      try {
        const res = await fetch(`/api/admin/dispatchers/status?_=${Date.now()}`, {
          cache: 'no-store',
          headers: { 'Accept': 'application/json' },
        });
        if (!res.ok) return;
        const data = await res.json();
        applyDispatcherStatuses(data);
      } catch (err) {
        console.warn('[admin-ui] dispatcher status refresh failed', err);
      } finally {
        dispatcherStatusFetchInFlight = false;
      }
    }

    if (dispatcherStatusCards.length) {
      refreshDispatcherStatuses();
      dispatcherStatusPollTimer = window.setInterval(refreshDispatcherStatuses, 10000);
      window.addEventListener('beforeunload', () => {
        if (dispatcherStatusPollTimer) window.clearInterval(dispatcherStatusPollTimer);
      });
    }
    const reportsTableBody = document.getElementById('reportsTableBody');
    const auditTableBody = document.getElementById('auditTableBody');
    const reportsPagerSummary = document.getElementById('reportsPagerSummary');
    const auditPagerSummary = document.getElementById('auditPagerSummary');
    const reportsPrevLink = document.getElementById('reportsPrevLink');
    const reportsNextLink = document.getElementById('reportsNextLink');
    const auditPrevLink = document.getElementById('auditPrevLink');
    const auditNextLink = document.getElementById('auditNextLink');

    function cleanType(value) {
      return String(value || '').trim() || 'Unknown';
    }

    function cleanSeverity(value) {
      const raw = String(value || '').trim().toLowerCase();
      if (raw === 'low') return 'Low';
      if (raw === 'medium') return 'Medium';
      if (raw === 'high') return 'High';
      return '';
    }

    function isoWeekParts(date) {
      const copy = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
      const day = copy.getUTCDay() || 7;
      copy.setUTCDate(copy.getUTCDate() + 4 - day);
      const yearStart = new Date(Date.UTC(copy.getUTCFullYear(), 0, 1));
      const week = Math.ceil((((copy - yearStart) / 86400000) + 1) / 7);
      return { year: copy.getUTCFullYear(), week };
    }

    function formatTrendModeLabel(range) {
      if (range === 'last-day') return 'Last Day';
      if (range === 'last-week') return 'Last Week';
      if (range === 'last-month') return 'Last Month';
      if (range === 'last-year') return 'Last Year';
      return range.charAt(0).toUpperCase() + range.slice(1);
    }

    function startOfDay(date) {
      return new Date(date.getFullYear(), date.getMonth(), date.getDate());
    }

    function shiftDays(date, days) {
      const next = new Date(date);
      next.setDate(next.getDate() + days);
      return next;
    }

    function shiftMonths(date, months) {
      const next = new Date(date);
      next.setMonth(next.getMonth() + months);
      return next;
    }

    function buildWindowEntries(config) {
      const now = new Date();
      const labels = [];
      const counts = [];
      const indexByKey = {};

      config.labels.forEach((label, idx) => {
        labels.push(label);
        counts.push(0);
        indexByKey[config.keys[idx]] = idx;
      });

      reportsData.forEach(r => {
        const d = new Date(r && r.timestamp);
        if (Number.isNaN(d.getTime()) || d < config.start || d > now) return;
        const key = config.keyFor(d);
        if (indexByKey[key] !== undefined) counts[indexByKey[key]] += 1;
      });

      return labels.map((label, idx) => [label, counts[idx]]);
    }

    function buildTrendEntries(range) {
      const now = new Date();
      if (range === 'last-day') {
        const start = shiftDays(now, -1);
        return buildWindowEntries({
          start,
          labels: ['Last 24 Hours'],
          keys: ['last-24-hours'],
          keyFor: () => 'last-24-hours',
        });
      }
      if (range === 'last-week') {
        const start = startOfDay(shiftDays(now, -6));
        const dates = Array.from({ length: 7 }, (_, idx) => shiftDays(start, idx));
        return buildWindowEntries({
          start,
          labels: dates.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`),
          keys: dates.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`),
          keyFor: (d) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`,
        });
      }
      if (range === 'last-month') {
        const start = startOfDay(shiftDays(now, -29));
        const dates = Array.from({ length: 30 }, (_, idx) => shiftDays(start, idx));
        return buildWindowEntries({
          start,
          labels: dates.map(d => `${d.getMonth() + 1}/${d.getDate()}`),
          keys: dates.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`),
          keyFor: (d) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`,
        });
      }
      if (range === 'last-year') {
        const start = startOfDay(shiftMonths(now, -11));
        const months = Array.from({ length: 12 }, (_, idx) => shiftMonths(new Date(start.getFullYear(), start.getMonth(), 1), idx));
        return buildWindowEntries({
          start,
          labels: months.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`),
          keys: months.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`),
          keyFor: (d) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`,
        });
      }
      const buckets = {};
      reportsData.forEach(r => {
        const d = new Date(r && r.timestamp);
        if (Number.isNaN(d.getTime())) return;

        let key = '';
        if (range === 'weekly') {
          const parts = isoWeekParts(d);
          key = `${parts.year}-W${String(parts.week).padStart(2, '0')}`;
        } else if (range === 'monthly') {
          key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
        } else if (range === 'yearly') {
          key = String(d.getFullYear());
        } else {
          key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        }
        buckets[key] = (buckets[key] || 0) + 1;
      });
      return Object.entries(buckets).sort((a, b) => a[0].localeCompare(b[0]));
    }

    function buildSeverityCounts(typeFilter) {
      const counts = { Low: 0, Medium: 0, High: 0 };
      reportsData.forEach(r => {
        const reportType = cleanType(r && r.emergencyType);
        if (typeFilter !== 'all' && reportType !== typeFilter) return;
        const severity = cleanSeverity(r && r.severity);
        if (counts[severity] !== undefined) counts[severity] += 1;
      });
      return counts;
    }

    function falseCountValue() {
      return reportsData.reduce((count, r) => {
        return count + (String((r && r.status) || '') === 'false-report' ? 1 : 0);
      }, 0);
    }

    function emergencyTypesList() {
      return Array.from(new Set(reportsData.map(r => cleanType(r && r.emergencyType)))).sort((a, b) => a.localeCompare(b));
    }

    function syncSeverityTypeOptions() {
      if (!severityTypeSelect) return;
      const current = severityTypeSelect.value || 'all';
      severityTypeSelect.innerHTML = '<option value="all">All Types</option>';
      emergencyTypesList().forEach(type => {
        const opt = document.createElement('option');
        opt.value = type;
        opt.textContent = type;
        severityTypeSelect.appendChild(opt);
      });
      severityTypeSelect.value = Array.from(severityTypeSelect.options).some(opt => opt.value === current) ? current : 'all';
    }
    syncSeverityTypeOptions();

    function updateStats() {
      const totalReportsEl = document.getElementById('statTotalReports');
      const totalDispatchersEl = document.getElementById('statTotalDispatchers');
      const activeDispatchersEl = document.getElementById('statActiveDispatchers');
      const auditCountEl = document.getElementById('statAuditCount');
      if (totalReportsEl) totalReportsEl.textContent = String(toNum(adminStats.totalReports));
      if (totalDispatchersEl) totalDispatchersEl.textContent = String(toNum(adminStats.totalDispatchers));
      if (activeDispatchersEl) activeDispatchersEl.textContent = String(toNum(adminStats.activeDispatchers));
      if (auditCountEl) auditCountEl.textContent = String(toNum(adminStats.auditCount));
    }

    function updatePager(summaryEl, prevLink, nextLink, baseUrl, pagination, itemLabel, pageParam) {
      if (summaryEl) {
        summaryEl.innerHTML = `Showing page <strong>${pagination.page}</strong> of <strong>${pagination.totalPages}</strong> (${pagination.totalCount} ${itemLabel})`;
      }
      if (prevLink) {
        prevLink.href = `${baseUrl}&${pageParam}=${pagination.page - 1}`;
        prevLink.setAttribute('aria-disabled', pagination.hasPrev ? 'false' : 'true');
      }
      if (nextLink) {
        nextLink.href = `${baseUrl}&${pageParam}=${pagination.page + 1}`;
        nextLink.setAttribute('aria-disabled', pagination.hasNext ? 'false' : 'true');
      }
    }

    function updateReportTable() {
      if (!reportsTableBody) return;
      reportsTableBody.innerHTML = `${reportsData.map(reportRowHtml).join('')}<tr id="reportFilterEmptyState" style="display:none"><td colspan="10" style="text-align:center;color:#6f644f">No reports match the selected ID type.</td></tr>`;
      reportRows = Array.from(document.querySelectorAll('.report-row'));
      reportFilterEmptyState = document.getElementById('reportFilterEmptyState');
      applyReportIdTypeFilter();
    }

    function updateAuditTable() {
      if (!auditTableBody) return;
      auditTableBody.innerHTML = auditLogsData.length
        ? auditLogsData.map(auditRowHtml).join('')
        : '<tr><td colspan="5" style="text-align:center;color:#6f644f">No audit entries yet.</td></tr>';
    }

    function updatePagers() {
      const currentUrl = new URL(window.location.href);
      const reportsBase = `/admin?tab=reports&from=${encodeURIComponent(currentUrl.searchParams.get('from') || '')}&to=${encodeURIComponent(currentUrl.searchParams.get('to') || '')}&auditPage=${encodeURIComponent(String(auditPaginationState.page || 1))}`;
      const auditBase = `/admin?tab=audit&reportPage=${encodeURIComponent(String(reportPaginationState.page || 1))}`;
      updatePager(reportsPagerSummary, reportsPrevLink, reportsNextLink, reportsBase, reportPaginationState, 'reports', 'reportPage');
      updatePager(auditPagerSummary, auditPrevLink, auditNextLink, auditBase, auditPaginationState, 'audit entries', 'auditPage');
    }

    function applyReportIdTypeFilter() {
      if (!reportIdTypeFilter) return;
      const selected = reportIdTypeFilter.value || 'all';
      let visibleCount = 0;
      reportRows.forEach(row => {
        const kind = String(row.getAttribute('data-report-kind') || '').toUpperCase();
        const show = selected === 'all' || kind === selected;
        row.style.display = show ? '' : 'none';
        if (show) visibleCount += 1;
      });
      if (reportFilterEmptyState) {
        reportFilterEmptyState.style.display = visibleCount === 0 ? '' : 'none';
      }
    }

    if (reportIdTypeFilter) {
      reportIdTypeFilter.addEventListener('change', applyReportIdTypeFilter);
      applyReportIdTypeFilter();
    }

    if (window.Chart && document.getElementById('trendChart') && document.getElementById('severityChart') && document.getElementById('falseChart')) {
      let trendChart = null;
      let severityChart = null;

      function renderTrendChart() {
        const range = trendRangeSelect ? trendRangeSelect.value : 'daily';
        const rangeLabel = formatTrendModeLabel(range);
        const trendEntries = buildTrendEntries(range);
        if (trendChartTitle) trendChartTitle.textContent = `Reports Trend (${rangeLabel})`;
        if (trendChart) trendChart.destroy();
        trendChart = new Chart(document.getElementById('trendChart'), {
        type: 'line',
        data: {
          labels: trendEntries.map(x => x[0]),
          datasets: [{
            label: 'Reports',
            data: trendEntries.map(x => x[1]),
            borderColor: '#d97706',
            backgroundColor: 'rgba(217,119,6,0.16)',
            pointBackgroundColor: '#d97706',
            pointRadius: 3,
            tension: 0.3,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: '#6f624f' }, grid: { display: false } },
            y: { beginAtZero: true, ticks: { precision: 0, color: '#6f624f' } }
          }
        }
      });
      }

      function renderSeverityChart() {
        const selectedType = severityTypeSelect ? severityTypeSelect.value : 'all';
        const counts = buildSeverityCounts(selectedType);
        if (severityChartTitle) {
          severityChartTitle.textContent = selectedType === 'all'
            ? 'Emergency Level'
            : `Emergency Level (${selectedType})`;
        }
        if (severityChart) severityChart.destroy();
        severityChart = new Chart(document.getElementById('severityChart'), {
          type: 'bar',
          data: {
            labels: severityLevels,
            datasets: [{
              label: 'Count',
              data: severityLevels.map(level => counts[level]),
              backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
              borderRadius: 8
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { ticks: { color: '#6f624f' }, grid: { display: false } },
              y: { beginAtZero: true, ticks: { precision: 0, color: '#6f624f' } }
            }
          }
        });
      }

      safeRun(renderTrendChart);
      safeRun(renderSeverityChart);
      if (trendRangeSelect) {
        trendRangeSelect.addEventListener('change', () => safeRun(renderTrendChart));
      }
      if (severityTypeSelect) {
        severityTypeSelect.addEventListener('change', () => safeRun(renderSeverityChart));
      }

      let falseChart = null;

      function renderFalseChart() {
        const total = reportsData.length;
        const falseCount = falseCountValue();
        if (falseChart) falseChart.destroy();
        falseChart = new Chart(document.getElementById('falseChart'), {
          type: 'pie',
          data: {
            labels: ['False Reports', 'Other Reports'],
            datasets: [{ data: [falseCount, Math.max(0, total - falseCount)], backgroundColor: ['#ef4444', '#e5dccf'] }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { position: 'bottom', labels: { color: '#6f624f' } },
              tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${ctx.raw}` } }
            }
          }
        });
      }

      safeRun(renderFalseChart);

      window.__adminRefreshCharts = function () {
        safeRun(renderTrendChart);
        safeRun(renderSeverityChart);
        safeRun(renderFalseChart);
      };
    }

    function refreshAdminVisuals() {
      syncSeverityTypeOptions();
      updateStats();
      updateReportTable();
      updateAuditTable();
      updatePagers();
      if (typeof window.__adminRefreshCharts === 'function') {
        window.__adminRefreshCharts();
      }
    }

    function adminSnapshotSignature(snapshot) {
      const reportsSig = safeArr(snapshot && snapshot.reports)
        .map(r => `${(r && (r.reportId || r._id)) || ''}|${(r && r.status) || ''}|${(r && r.timestamp) || ''}|${(r && r.assignedToId) || ''}`)
        .join('||');
      const auditSig = safeArr(snapshot && snapshot.auditLogs)
        .map(a => `${(a && a._id) || ''}|${(a && a.timestamp) || ''}|${(a && a.action) || ''}`)
        .join('||');
      return `${reportsSig}###${auditSig}###${JSON.stringify((snapshot && snapshot.stats) || {})}`;
    }

    let lastAdminSnapshotSig = adminSnapshotSignature({
      reports: reportsData,
      auditLogs: auditLogsData,
      stats: adminStats,
    });

    async function syncAdminLiveData(force) {
      try {
        const current = new URL(window.location.href);
        const liveUrl = new URL('/api/admin/live', window.location.origin);
        current.searchParams.forEach((value, key) => {
          if (key === 'ok' || key === 'err') return;
          liveUrl.searchParams.set(key, value);
        });
        liveUrl.searchParams.set('_', String(Date.now()));
        const res = await fetch(liveUrl.toString(), {
          cache: 'no-store',
          credentials: 'same-origin',
        });
        if (res.status === 401) {
          window.location.assign('/admin/login?force=1');
          return;
        }
        if (!res.ok) return;
        const snapshot = await res.json().catch(() => null);
        if (!snapshot) return;
        const nextSig = adminSnapshotSignature(snapshot);
        if (!force && nextSig === lastAdminSnapshotSig) return;
        reportsData = safeArr(snapshot.reports);
        auditLogsData = safeArr(snapshot.auditLogs);
        adminStats = snapshot.stats || adminStats;
        reportPaginationState = snapshot.reportPagination || reportPaginationState;
        auditPaginationState = snapshot.auditPagination || auditPaginationState;
        lastAdminSnapshotSig = nextSig;
        refreshAdminVisuals();
      } catch (_e) {}
    }

    let adminSyncTimer = null;
    function scheduleAdminSync(delay) {
      clearTimeout(adminSyncTimer);
      adminSyncTimer = setTimeout(() => {
        void syncAdminLiveData(false);
      }, delay);
    }

    function updateAdminDateTime() {
      const clockEl = document.getElementById('adminClock');
      const dateEl = document.getElementById('adminDate');
      if (!clockEl || !dateEl) return;
      const now = new Date();
      const date = now.toLocaleDateString(undefined, {
        weekday: 'short',
        year: 'numeric',
        month: 'short',
        day: '2-digit'
      });
      const time = now.toLocaleTimeString(undefined, {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      });
      clockEl.textContent = time;
      dateEl.textContent = date;
    }
    updateAdminDateTime();
    setInterval(updateAdminDateTime, 1000);
    refreshAdminVisuals();
    void syncAdminLiveData(true);
    const ADMIN_LIVE_POLL_MS = 3000;
    setInterval(() => {
      if (document.hidden) return;
      void syncAdminLiveData(false);
    }, ADMIN_LIVE_POLL_MS);
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) scheduleAdminSync(250);
    });
    if (channel) {
      ['new-report', 'report-updated', 'report-details-updated', 'report-assignment-updated', 'reports-cleared', 'audit-log-created']
        .forEach(eventName => channel.bind(eventName, () => scheduleAdminSync(300)));
    }

    window.addEventListener('unhandledrejection', (event) => {
      console.error('[admin-ui] unhandled rejection', event && event.reason ? event.reason : event);
    });
    window.addEventListener('error', (event) => {
      console.error('[admin-ui] runtime error', event && event.error ? event.error : event);
    });
  </script>
</body>
</html>

