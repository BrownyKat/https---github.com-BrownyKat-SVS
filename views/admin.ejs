  <script id="reportsSeed" type="application/json"><%- JSON.stringify(reports) %></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    try {
      if (!sessionStorage.getItem('svs_admin_window_ok')) {
        window.location.replace('/login?force=1');
      }
    } catch (_e) {
      window.location.replace('/login?force=1');
    }

    function safeRun(fn) {
      try { fn(); } catch (e) { console.error('[admin-ui]', e); }
    }

    window.addEventListener('pageshow', function (event) {
      if (event.persisted) {
        window.location.replace('/admin/login');
      }
    });

    const navItems = Array.from(document.querySelectorAll('.nav-item[data-tab]'));
    const panels = Array.from(document.querySelectorAll('.tab-panel[data-panel]'));
    const allowedTabs = new Set(navItems.map(n => n.dataset.tab));
    function showTab(tab) {
      const safeTab = allowedTabs.has(tab) ? tab : 'dashboard';
      navItems.forEach(n => n.classList.toggle('active', n.dataset.tab === safeTab));
      panels.forEach(p => p.classList.toggle('active', p.dataset.panel === safeTab));

      const url = new URL(window.location.href);
      url.searchParams.set('tab', safeTab);
      window.history.replaceState({}, '', url.toString());
    }
    navItems.forEach(n => n.addEventListener('click', () => showTab(n.dataset.tab)));
    const initialTab = new URLSearchParams(window.location.search).get('tab');
    if (initialTab) showTab(initialTab);

    function openModal(sel) {
      const el = document.querySelector(sel);
      if (!el) return;
      el.classList.add('show');
      el.setAttribute('aria-hidden', 'false');
    }
    function closeModal(sel) {
      const el = document.querySelector(sel);
      if (!el) return;
      el.classList.remove('show');
      el.setAttribute('aria-hidden', 'true');
    }
    document.querySelectorAll('[data-close-modal]').forEach(btn => {
      btn.addEventListener('click', () => closeModal(btn.getAttribute('data-close-modal')));
    });
    document.querySelectorAll('.modal-backdrop').forEach(backdrop => {
      backdrop.addEventListener('click', (e) => {
        if (e.target === backdrop) closeModal('#' + backdrop.id);
      });
    });
    document.getElementById('openAddDispatcher')?.addEventListener('click', () => openModal('#addDispatcherModal'));

    const editForm = document.getElementById('editDispatcherForm');
    const deleteForm = document.getElementById('deleteDispatcherForm');
    const deleteName = document.getElementById('deleteDispatcherName');
    document.querySelectorAll('[data-action="edit-dispatcher"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        if (!id || !editForm) return;
        editForm.action = '/admin/dispatchers/' + encodeURIComponent(id) + '/update?tab=dispatchers';
        document.getElementById('editUsername').value = btn.getAttribute('data-username') || '';
        document.getElementById('editFullName').value = btn.getAttribute('data-fullname') || '';
        document.getElementById('editPhone').value = btn.getAttribute('data-phone') || '';
        document.getElementById('editNewPassword').value = '';
        document.getElementById('editIsActive').checked = btn.getAttribute('data-active') === '1';
        openModal('#editDispatcherModal');
      });
    });
    document.querySelectorAll('[data-action="delete-dispatcher"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const username = btn.getAttribute('data-username') || 'this dispatcher';
        if (!id || !deleteForm) return;
        deleteForm.action = '/admin/dispatchers/' + encodeURIComponent(id) + '/delete?tab=dispatchers';
        if (deleteName) deleteName.textContent = username;
        openModal('#deleteDispatcherModal');
      });
    });
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll('.modal-backdrop.show').forEach(m => closeModal('#' + m.id));
    });

    function safeArr(v){ return Array.isArray(v) ? v : []; }

    let reportsData = [];
    try {
      reportsData = JSON.parse(document.getElementById('reportsSeed').textContent || '[]');
    } catch (_e) { reportsData = []; }
    reportsData = safeArr(reportsData);

    const severityLevels = ['Low', 'Medium', 'High'];
    const trendRangeSelect = document.getElementById('trendRangeSelect');
    const trendChartTitle = document.getElementById('trendChartTitle');
    const severityTypeSelect = document.getElementById('severityTypeSelect');
    const severityChartTitle = document.getElementById('severityChartTitle');
    const reportIdTypeFilter = document.getElementById('reportIdTypeFilter');
    const reportRows = Array.from(document.querySelectorAll('.report-row'));
    const reportFilterEmptyState = document.getElementById('reportFilterEmptyState');

    function cleanType(value) {
      return String(value || '').trim() || 'Unknown';
    }

    function cleanSeverity(value) {
      const raw = String(value || '').trim().toLowerCase();
      if (raw === 'low') return 'Low';
      if (raw === 'medium') return 'Medium';
      if (raw === 'high') return 'High';
      return '';
    }

    function isoWeekParts(date) {
      const copy = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
      const day = copy.getUTCDay() || 7;
      copy.setUTCDate(copy.getUTCDate() + 4 - day);
      const yearStart = new Date(Date.UTC(copy.getUTCFullYear(), 0, 1));
      const week = Math.ceil((((copy - yearStart) / 86400000) + 1) / 7);
      return { year: copy.getUTCFullYear(), week };
    }

    function formatTrendModeLabel(range) {
      if (range === 'last-day') return 'Last Day';
      if (range === 'last-week') return 'Last Week';
      if (range === 'last-month') return 'Last Month';
      if (range === 'last-year') return 'Last Year';
      return range.charAt(0).toUpperCase() + range.slice(1);
    }

    function startOfDay(date) {
      return new Date(date.getFullYear(), date.getMonth(), date.getDate());
    }

    function shiftDays(date, days) {
      const next = new Date(date);
      next.setDate(next.getDate() + days);
      return next;
    }

    function shiftMonths(date, months) {
      const next = new Date(date);
      next.setMonth(next.getMonth() + months);
      return next;
    }

    function buildWindowEntries(config) {
      const now = new Date();
      const labels = [];
      const counts = [];
      const indexByKey = {};

      config.labels.forEach((label, idx) => {
        labels.push(label);
        counts.push(0);
        indexByKey[config.keys[idx]] = idx;
      });

      reportsData.forEach(r => {
        const d = new Date(r && r.timestamp);
        if (Number.isNaN(d.getTime()) || d < config.start || d > now) return;
        const key = config.keyFor(d);
        if (indexByKey[key] !== undefined) counts[indexByKey[key]] += 1;
      });

      return labels.map((label, idx) => [label, counts[idx]]);
    }

    function buildTrendEntries(range) {
      const now = new Date();
      if (range === 'last-day') {
        const start = shiftDays(now, -1);
        return buildWindowEntries({
          start,
          labels: ['Last 24 Hours'],
          keys: ['last-24-hours'],
          keyFor: () => 'last-24-hours',
        });
      }
      if (range === 'last-week') {
        const start = startOfDay(shiftDays(now, -6));
        const dates = Array.from({ length: 7 }, (_, idx) => shiftDays(start, idx));
        return buildWindowEntries({
          start,
          labels: dates.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`),
          keys: dates.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`),
          keyFor: (d) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`,
        });
      }
      if (range === 'last-month') {
        const start = startOfDay(shiftDays(now, -29));
        const dates = Array.from({ length: 30 }, (_, idx) => shiftDays(start, idx));
        return buildWindowEntries({
          start,
          labels: dates.map(d => `${d.getMonth() + 1}/${d.getDate()}`),
          keys: dates.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`),
          keyFor: (d) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`,
        });
      }
      if (range === 'last-year') {
        const start = startOfDay(shiftMonths(now, -11));
        const months = Array.from({ length: 12 }, (_, idx) => shiftMonths(new Date(start.getFullYear(), start.getMonth(), 1), idx));
        return buildWindowEntries({
          start,
          labels: months.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`),
          keys: months.map(d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`),
          keyFor: (d) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`,
        });
      }
      const buckets = {};
      reportsData.forEach(r => {
        const d = new Date(r && r.timestamp);
        if (Number.isNaN(d.getTime())) return;

        let key = '';
        if (range === 'weekly') {
          const parts = isoWeekParts(d);
          key = `${parts.year}-W${String(parts.week).padStart(2, '0')}`;
        } else if (range === 'monthly') {
          key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
        } else if (range === 'yearly') {
          key = String(d.getFullYear());
        } else {
          key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        }
        buckets[key] = (buckets[key] || 0) + 1;
      });
      return Object.entries(buckets).sort((a, b) => a[0].localeCompare(b[0]));
    }

    function buildSeverityCounts(typeFilter) {
      const counts = { Low: 0, Medium: 0, High: 0 };
      reportsData.forEach(r => {
        const reportType = cleanType(r && r.emergencyType);
        if (typeFilter !== 'all' && reportType !== typeFilter) return;
        const severity = cleanSeverity(r && r.severity);
        if (counts[severity] !== undefined) counts[severity] += 1;
      });
      return counts;
    }

    const falseCount = reportsData.reduce((count, r) => {
      return count + (String((r && r.status) || '') === 'false-report' ? 1 : 0);
    }, 0);

    const emergencyTypes = Array.from(new Set(reportsData.map(r => cleanType(r && r.emergencyType)))).sort((a, b) => a.localeCompare(b));
    if (severityTypeSelect) {
      emergencyTypes.forEach(type => {
        const opt = document.createElement('option');
        opt.value = type;
        opt.textContent = type;
        severityTypeSelect.appendChild(opt);
      });
    }

    function applyReportIdTypeFilter() {
      if (!reportIdTypeFilter) return;
      const selected = reportIdTypeFilter.value || 'all';
      let visibleCount = 0;
      reportRows.forEach(row => {
        const kind = String(row.getAttribute('data-report-kind') || '').toUpperCase();
        const show = selected === 'all' || kind === selected;
        row.style.display = show ? '' : 'none';
        if (show) visibleCount += 1;
      });
      if (reportFilterEmptyState) {
        reportFilterEmptyState.style.display = visibleCount === 0 ? '' : 'none';
      }
    }

    if (reportIdTypeFilter) {
      reportIdTypeFilter.addEventListener('change', applyReportIdTypeFilter);
      applyReportIdTypeFilter();
    }

    if (window.Chart && document.getElementById('trendChart') && document.getElementById('severityChart') && document.getElementById('falseChart')) {
      let trendChart = null;
      let severityChart = null;

      function renderTrendChart() {
        const range = trendRangeSelect ? trendRangeSelect.value : 'daily';
        const rangeLabel = formatTrendModeLabel(range);
        const trendEntries = buildTrendEntries(range);
        if (trendChartTitle) trendChartTitle.textContent = `Reports Trend (${rangeLabel})`;
        if (trendChart) trendChart.destroy();
        trendChart = new Chart(document.getElementById('trendChart'), {
        type: 'line',
        data: {
          labels: trendEntries.map(x => x[0]),
          datasets: [{
            label: 'Reports',
            data: trendEntries.map(x => x[1]),
            borderColor: '#d97706',
            backgroundColor: 'rgba(217,119,6,0.16)',
            pointBackgroundColor: '#d97706',
            pointRadius: 3,
            tension: 0.3,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: '#6f624f' }, grid: { display: false } },
            y: { beginAtZero: true, ticks: { precision: 0, color: '#6f624f' } }
          }
        }
      });
      }

      function renderSeverityChart() {
        const selectedType = severityTypeSelect ? severityTypeSelect.value : 'all';
        const counts = buildSeverityCounts(selectedType);
        if (severityChartTitle) {
          severityChartTitle.textContent = selectedType === 'all'
            ? 'Emergency Level'
            : `Emergency Level (${selectedType})`;
        }
        if (severityChart) severityChart.destroy();
        severityChart = new Chart(document.getElementById('severityChart'), {
          type: 'bar',
          data: {
            labels: severityLevels,
            datasets: [{
              label: 'Count',
              data: severityLevels.map(level => counts[level]),
              backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
              borderRadius: 8
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { ticks: { color: '#6f624f' }, grid: { display: false } },
              y: { beginAtZero: true, ticks: { precision: 0, color: '#6f624f' } }
            }
          }
        });
      }

      safeRun(renderTrendChart);
      safeRun(renderSeverityChart);
      if (trendRangeSelect) {
        trendRangeSelect.addEventListener('change', () => safeRun(renderTrendChart));
      }
      if (severityTypeSelect) {
        severityTypeSelect.addEventListener('change', () => safeRun(renderSeverityChart));
      }

      const total = reportsData.length;
      safeRun(() => new Chart(document.getElementById('falseChart'), {
        type: 'pie',
        data: {
          labels: ['False Reports', 'Other Reports'],
          datasets: [{ data: [falseCount, Math.max(0, total - falseCount)], backgroundColor: ['#ef4444', '#e5dccf'] }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { color: '#6f624f' } },
            tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${ctx.raw}` } }
          }
        }
      }));
    }

    function updateAdminDateTime() {
      const clockEl = document.getElementById('adminClock');
      const dateEl = document.getElementById('adminDate');
      if (!clockEl || !dateEl) return;
      const now = new Date();
      const date = now.toLocaleDateString(undefined, {
        weekday: 'short',
        year: 'numeric',
        month: 'short',
        day: '2-digit'
      });
      const time = now.toLocaleTimeString(undefined, {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      });
      clockEl.textContent = time;
      dateEl.textContent = date;
    }
    updateAdminDateTime();
    setInterval(updateAdminDateTime, 1000);

    window.addEventListener('unhandledrejection', (event) => {
      console.error('[admin-ui] unhandled rejection', event && event.reason ? event.reason : event);
    });
    window.addEventListener('error', (event) => {
      console.error('[admin-ui] runtime error', event && event.error ? event.error : event);
    });
  </script>
</body>
</html>

