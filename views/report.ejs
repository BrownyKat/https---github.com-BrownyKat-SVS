    <p>Enter your phone number <strong>once</strong>. The Panic Button will remember it so you never need to type again in an emergency.</p>
    <input type="tel" id="panicInput" placeholder="+63 917 123 4567" inputmode="tel" autocomplete="tel" maxlength="16">
    <button class="modal-save" onclick="savePanic()">Save &amp; Activate Panic Button</button>
    <button class="modal-cancel" onclick="closePanicModal()">Cancel</button>
  </div>
