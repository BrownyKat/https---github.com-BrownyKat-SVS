  function toIntlPhone(v) {
    const digits = String(v || '').replace(/\D/g, '');
    if (/^09\d{9}$/.test(digits)) return `+63${digits.slice(1)}`;
    if (/^63\d{10}$/.test(digits)) return `+${digits}`;
    if (/^9\d{9}$/.test(digits)) return `+63${digits}`;
    return null;
  }

  function formatPhoneForDisplay(v) {
    const intl = toIntlPhone(v);
    if (!intl) {
      const digits = String(v || '').replace(/\D/g, '');
      let partial = digits;
      if (partial.startsWith('0')) partial = partial.slice(1);
      else if (partial.startsWith('63')) partial = partial.slice(2);
      partial = partial.replace(/\D/g, '').slice(0, 10);
      if (!partial) return '';
      if (partial.length <= 3) return `+63 ${partial}`;
      if (partial.length <= 6) return `+63 ${partial.slice(0, 3)} ${partial.slice(3)}`;
      return `+63 ${partial.slice(0, 3)} ${partial.slice(3, 6)} ${partial.slice(6)}`;
    }
    const local = intl.slice(3); // 9XXXXXXXXX
    return `+63 ${local.slice(0, 3)} ${local.slice(3, 6)} ${local.slice(6, 10)}`;
  }

  function debounce(fn, wait = 250) {
    let t;
    return (...args) => {
      clearTimeout(t);
      t = setTimeout(() => fn(...args), wait);
    };
  }

  function isDataUri(img) {
    return /^data:image\/(png|jpe?g|webp);base64,/i.test(String(img || '').trim());
  }

  function dataUriToBlob(dataUri) {
    const parts = String(dataUri).split(',');
    const mime = parts[0].match(/data:(.*);base64/i)[1] || 'image/jpeg';
    const bin = atob(parts[1]);
    const len = bin.length;
    const arr = new Uint8Array(len);
    for (let i = 0; i < len; i++) arr[i] = bin.charCodeAt(i);
    return new Blob([arr], { type: mime });
  }

  async function uploadPhotoToSupabase(dataUri, index = 0) {
    if (!HAS_SUPABASE || !isDataUri(dataUri)) return null;
    try {
      const blob = dataUriToBlob(dataUri);
      const fileName = `reports/${Date.now()}-${index}-${Math.random().toString(36).slice(2)}.jpg`;
      const res = await fetch(`${SUPABASE_URL}/storage/v1/object/${encodeURIComponent(SUPABASE_BUCKET)}/${fileName}`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          'apikey': SUPABASE_ANON_KEY,
          'Content-Type': blob.type || 'image/jpeg',
          'x-upsert': 'true',
        },
        body: blob,
      });
      if (!res.ok) throw new Error('Upload failed');
      // public URL
      return `${SUPABASE_URL}/storage/v1/object/public/${SUPABASE_BUCKET}/${fileName}`;
    } catch (_e) {
      return null;
    }
  }

  async function ensurePhotosToSupabase(payload) {
    if (!HAS_SUPABASE || !Array.isArray(payload.photos) || !payload.photos.length) return payload;
    const uploaded = [];
    for (let i = 0; i < payload.photos.length; i++) {
      const p = payload.photos[i];
      if (isDataUri(p)) {
        const url = await uploadPhotoToSupabase(p, i);
        uploaded.push(url || p);
      } else {
        uploaded.push(p);
      }
    }
    return { ...payload, photos: uploaded, photo: uploaded[0] || null };
  }

  function getPendingQueue() {
    try {
      const raw = localStorage.getItem(PENDING_KEY);
      const arr = raw ? JSON.parse(raw) : [];
      return Array.isArray(arr) ? arr : [];
    } catch (_e) { return []; }
  }

  function enqueuePending(payload, attempts = 0, createdAt = Date.now()) {
    try {
      const arr = getPendingQueue();
      arr.push({ payload, createdAt, attempts });
      localStorage.setItem(PENDING_KEY, JSON.stringify(arr.slice(-50)));
      updatePendingCount();
    } catch (_e) {}
  }

  function schedulePendingFlush(delay = PENDING_RETRY_MS) {
    if (pendingRetryTimer) return;
    pendingRetryTimer = setTimeout(() => {
      pendingRetryTimer = null;
      void flushPendingQueue();
    }, delay);
  }

  async function flushPendingQueue() {
    if (isFlushingPending) return;
    if (!navigator.onLine) {
      schedulePendingFlush();
      return;
    }
    isFlushingPending = true;
    clearTimeout(pendingRetryTimer);
    pendingRetryTimer = null;
    let queue = getPendingQueue();
    while (queue.length) {
      const next = queue.shift();
      const attempts = Number(next.attempts || 0);
      localStorage.setItem(PENDING_KEY, JSON.stringify(queue));
      try {
        const supaPayload = await ensurePhotosToSupabase(next.payload || {});
        const { res, data: d } = await fetchJson('/api/report', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify(supaPayload)
        }, 12000);
        const ok = res && res.ok && d && d.success;
        if (!ok) {
          const retryable = res ? res.status >= 500 || res.status === 0 : true;
          const errMsg = (d && d.error) || (res && res.statusText) || 'Send failed';
          if (!retryable || attempts + 1 >= MAX_PENDING_ATTEMPTS) {
            toast('Skipped queued report', `${errMsg || 'Invalid data.'} (dropped after retries)`);
          } else {
            queue.unshift({ payload: next.payload || {}, createdAt: next.createdAt || Date.now(), attempts: attempts + 1 });
            localStorage.setItem(PENDING_KEY, JSON.stringify(queue));
            schedulePendingFlush();
            break;
          }
        } else {
          toast('Sent pending report', `Queued report delivered${d.id ? ` (ID ${d.id})` : ''}.`);
        }
      } catch (_e) {
        if (attempts + 1 >= MAX_PENDING_ATTEMPTS) {
          toast('Skipped queued report', 'Dropped after multiple failed retries.');
        } else {
          queue.unshift({ payload: next.payload || {}, createdAt: next.createdAt || Date.now(), attempts: attempts + 1 });
          localStorage.setItem(PENDING_KEY, JSON.stringify(queue));
          schedulePendingFlush();
          break;
        }
        localStorage.setItem(PENDING_KEY, JSON.stringify(queue));
      }
      queue = getPendingQueue();
      updatePendingCount();
    }
    updatePendingCount();
    isFlushingPending = false;
  }

  function updatePendingCount() {
    const el = document.getElementById('pendingCount');
    if (el) el.textContent = String(getPendingQueue().length);
  }

  function alertQueued() {
    const c = getPendingQueue().length;
