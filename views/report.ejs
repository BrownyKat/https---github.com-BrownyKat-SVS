<script>
  window.supaConfig = <%- JSON.stringify(supaConfig || { url: '', anonKey: '', bucket: 'svs_photo' }) %>;
</script>
<script>
  let selType_ = '', selSev_ = '', photoDataList = [];
  let selectedTags = [];
  const TAG_OPTIONS = ['people_trapped','injured','road_blocked','power_out','rising_water','fire_spreading','hazmat','structure_damage','blocked_access','missing_persons','medical_needed','evac_needed'];
  let panicNum = '';
  const MAP_MIN_ZOOM = 6;
  const MAP_MAX_ZOOM = 20;
  const mapState = { lat: null, lng: null, zoom: 16, view: 'map' };
  const MAP_TYPE_CODES = { map: 'm', satellite: 'k' };
  const API_TIMEOUT_MS = 15000;
  const PENDING_KEY = 'svs_pending_reports_v1';
  const PENDING_RETRY_MS = 8000;
  const MAX_PENDING_ATTEMPTS = 3;
  const SUPA_RAW = window.supaConfig || {};
  const SUPA = {
    url: String(SUPA_RAW.url || '').trim().replace(/\/+$/, ''),
    anonKey: String(SUPA_RAW.anonKey || '').trim(),
    bucket: String(SUPA_RAW.bucket || 'svs_photo').trim(),
  };
  const SUPABASE_URL = SUPA.url;
  const SUPABASE_ANON_KEY = SUPA.anonKey;
  const SUPABASE_BUCKET = SUPA.bucket;
  const HAS_SUPABASE = !!(SUPABASE_URL && SUPABASE_ANON_KEY && SUPABASE_BUCKET);
  let pendingRetryTimer = null;
  let isFlushingPending = false;
  const REQUIRED_ERROR_CLASSES = ['border-red-400', 'ring-4', 'ring-red-100'];
  const TYPE_SELECTED_CLASSES = ['border-blue-400', 'shadow-lg', '-translate-y-0.5', 'ring-4', 'ring-blue-100', '[&_.etype-icon]:shadow-sm', '[&_.etype-copy>strong]:text-blue-700', '[&_.etype-copy>span]:text-blue-600'];
  const SEV_SELECTED = {
    Low: ['border-emerald-300', 'bg-emerald-50', 'ring-4', 'ring-emerald-100', 'shadow-md', '-translate-y-0.5'],
    Medium: ['border-amber-300', 'bg-amber-50', 'ring-4', 'ring-amber-100', 'shadow-md', '-translate-y-0.5'],
    High: ['border-red-300', 'bg-red-50', 'ring-4', 'ring-red-100', 'shadow-md', '-translate-y-0.5'],
  };
  const TAG_SELECTED_CLASSES = ['border-blue-200', 'bg-blue-50', 'text-blue-700', 'shadow-md'];
  const GPS_READY_CLASSES = ['border-blue-300', 'bg-blue-50', 'text-blue-700', 'shadow-md'];
  const MAP_TOGGLE_ACTIVE_CLASSES = ['border-blue-200', 'bg-blue-50', 'text-blue-700'];
  const TOAST_SHOW_CLASSES = ['translate-x-0', 'opacity-100', 'pointer-events-auto'];
  const TOAST_HIDE_CLASSES = ['translate-x-[calc(100%+2rem)]', 'opacity-0', 'pointer-events-none'];
  const fy = document.getElementById('footerYear');
  if (fy) fy.textContent = String(new Date().getFullYear());
  try { panicNum = localStorage.getItem('mdrrmo_panic') || ''; } catch(e) {}
  panicNum = toIntlPhone(panicNum) || '';
  bindInputSecurity();
  bindRequiredFieldWatchers();
  flushPendingQueue();
  updatePendingCount();
  window.addEventListener('online', flushPendingQueue);
  window.addEventListener('focus', flushPendingQueue);
  document.addEventListener('visibilitychange', () => { if (!document.hidden) flushPendingQueue(); });
  if (panicNum) {
    initPanicUI();
    const sosField = document.getElementById('iPanicContact');
    if (sosField) sosField.value = formatPhoneForDisplay(panicNum);
    const status = document.getElementById('panicSavedStatus');
    if (status) {
      status.textContent = 'Saved';
      status.classList.remove('text-slate-500');
      status.classList.add('text-blue-700');
    }
  }

  function addClasses(el, classes = []) {
    if (!el) return;
    el.classList.add(...classes);
  }

  function removeClasses(el, classes = []) {
    if (!el) return;
    el.classList.remove(...classes);
  }

  function toggleClasses(el, classes = [], active = false) {
    if (!el) return;
    classes.forEach(cls => el.classList.toggle(cls, !!active));
  }

  function showOverlay(id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('hidden');
    el.classList.add('flex');
  }

  function hideOverlay(id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('flex');
    el.classList.add('hidden');
  }

  function showElement(el, displayClass = 'flex') {
    if (!el) return;
    el.classList.remove('hidden');
    el.classList.add(displayClass);
  }

  function hideElement(el, displayClass = 'flex') {
    if (!el) return;
    el.classList.remove(displayClass);
    el.classList.add('hidden');
  }

  function defaultGpsButtonHtml() {
    return `<svg class="h-4 w-4 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M9.348 14.651a3.75 3.75 0 0 1 0-5.303m5.304-.001a3.75 3.75 0 0 1 0 5.304m-7.425 2.122a6.75 6.75 0 0 1 0-9.546m9.546 0a6.75 6.75 0 0 1 0 9.546M5.106 18.894c-3.808-3.808-3.808-9.98 0-13.789m13.788 0c3.808 3.808 3.808 9.981 0 13.79M12 12h.008v.007H12V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg> Auto-detect My Location (GPS)`;
  }

  function loadingGpsButtonHtml(label = 'Detecting...') {
    return `<svg class="h-4 w-4 animate-spin stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg> ${label}`;
  }

  function detectedGpsButtonHtml(lat, lng, accuracy, plusMinus = '+/-') {
    return `<svg class="h-4 w-4 stroke-current fill-none [stroke-width:2]" viewBox="0 0 24 24"><path d="M4.5 12.75l6 6 9-13.5"/></svg> Detected: ${lat.toFixed(4)}, ${lng.toFixed(4)} (${plusMinus}${Math.round(accuracy || 0)}m)`;
