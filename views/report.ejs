        padding:.95rem;
      }
      .report-shell{
        gap:.85rem;
      }
      .card-topline{
        flex-direction:column;
        gap:.75rem;
      }
      .card{
        padding:.8rem;
      }
      .dashboard-form-card{
        padding:.65rem !important;
        border-radius:14px !important;
      }
      .form-head h1{
        font-size:1.95rem;
        line-height:1.02;
      }
      .form-head p{
        font-size:.88rem;
      }
      .card-head{
        gap:.85rem;
      }
      .card-icon{
        width:46px;
        height:46px;
      }
      .etype-grid{
        grid-template-columns:repeat(2,minmax(0,1fr));
        gap:.7rem;
      }
      .etype-btn{
        min-height:132px;
        padding:1rem .55rem .9rem;
      }
      .etype-copy span{
        max-width:none;
      }
      .field-note{
        font-size:.74rem;
      }
      textarea{
        min-height:150px;
      }
      .sev-row{
        grid-template-columns:1fr;
      }
      .sev-btn{
        justify-content:flex-start;
        padding:1rem;
      }
      .map-callout{
        gap:.6rem;
      }
      .step-links{
        grid-template-columns:1fr;
      }
      .step-link{
        padding:.78rem .85rem;
      }
      .panic-btn{
        width:164px;
        height:164px;
      }
      .action-chip{
        flex-basis:100%;
      }
      .nav-links{
        display:grid;
        grid-template-columns:repeat(2,minmax(0,1fr));
        width:100%;
      }
      .nav-btn{
        width:100%;
        padding:.6rem .8rem;
        font-size:.82rem;
      }
      .main-datetime{padding:.68rem .85rem;gap:.7rem;}
      .main-datetime svg{width:20px;height:20px;}
      .clock-text{font-size:.95rem;letter-spacing:.7px;}
      .date-text{font-size:.6rem;letter-spacing:.45px;}
    }
    @media(max-width:1100px){
      .card-step{
        font-size:.68rem;
      }
      .card-title{
        font-size:1.5rem;
      }
      .card-sub{
        max-width:none;
      }
      .etype-grid{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }
      .sev-row{
        grid-template-columns:1fr;
      }
      .severity-guide{
        grid-template-columns:1fr;
      }
      .submit-panel{
        padding:1rem;
      }
    }
    @media(max-width:767px){
      body{
        padding-top:var(--header-h);
      }
      .dashboard-main{
        min-height:auto;
      }
      .dashboard-layout{
        min-height:auto;
        overflow:visible;
      }
      .report-form-panel{
        position:relative;
        top:auto;
        margin-left:0;
        height:auto;
      }
      .dashboard-form-card{
        min-height:auto;
        height:auto;
        max-height:none;
      }
      .report-map-panel{
        display:none !important;
      }
    }
  </style>
  <%- include('partials/typography') %>
</head>
<body>

<%- include('partials/navbar', { active: 'report', timeId: 'reportTime' }) %>

<main class="dashboard-main">
<div class="dashboard-layout">
  <div class="report-form-panel custom-scrollbar">
    <div class="form-wrap dashboard-form-wrap" id="report-form">
      <div class="bg-white rounded-3xl shadow-lg p-8 dashboard-form-card">
  <div class="dashboard-form-scroll custom-scrollbar">
  <div class="form-head dashboard-form-head">
    <div class="form-eyebrow">
      <!-- Heroicon: document-text -->
      <svg viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      SVS Emergency Report System
    </div>
    <h1>Report an <em>Emergency</em></h1>
    <p>Your report will be received immediately by SVS dispatchers. Provide as much detail as possible for a faster response.</p>
    <div class="head-actions">
      <button class="chip-btn" type="button" onclick="alertQueued()">Offline Queue (<span id="pendingCount">0</span>)</button>
    </div>
  </div>
  <div class="alert-strip">
    <!-- Heroicon: exclamation-triangle -->
    <svg viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
    <span><strong>For life-threatening emergencies, call 911 immediately.</strong><br>This form is for reporting incidents and requesting assistance through SVS.</span>
  </div>

  <div class="card-stack dashboard-card-stack">
  <!-- STEP 01 -->
  <div class="card" id="step-reporter">
    <div class="card-topline">
      <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: user -->
        <svg viewBox="0 0 24 24"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
      </div>
      <div>
        <div class="card-step">Step 01</div>
        <div class="card-title">Your Information</div>
        <div class="card-sub">Who is making this report?</div>
      </div>
      </div>
      <div class="step-badge">Required</div>
    </div>
    <div class="row2">
      <div class="field">
        <label>Full Name *</label>
        <div class="input-wrap has-icon">
          <svg class="field-icon" viewBox="0 0 24 24"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
          <input type="text" id="iName" placeholder="Juan dela Cruz" required>
        </div>
        <div class="field-note">Use the name responders or dispatchers can ask for during verification.</div>
      </div>
      <div class="field">
        <label>Contact Number *</label>
        <div class="input-wrap has-icon">
          <svg class="field-icon" viewBox="0 0 24 24"><path d="M2.25 6.338c0 7.5 6.089 13.587 13.589 13.587l.682-.002a1.124 1.124 0 0 0 1.12-1.065l.254-3.223a1.125 1.125 0 0 0-.89-1.207l-2.98-.67a1.125 1.125 0 0 0-1.264.597l-.75 1.5a11.775 11.775 0 0 1-4.955-4.955l1.5-.75a1.125 1.125 0 0 0 .597-1.264l-.67-2.98a1.125 1.125 0 0 0-1.207-.89l-3.223.254a1.124 1.124 0 0 0-1.065 1.12L2.25 6.338Z"/></svg>
          <input type="tel" id="iContact" placeholder="+63 917 123 4567" inputmode="tel" autocomplete="tel" maxlength="16" required>
        </div>
        <div class="field-note">Use an active PH mobile number so dispatchers can call or text back immediately.</div>
        <div class="sos-save-row">
          <label for="iPanicContact">SOS number (for one-tap panic):</label>
          <input type="tel" id="iPanicContact" placeholder="+63 9XX XXX XXXX" inputmode="tel" maxlength="16">
          <button type="button" id="btnSavePanic" onclick="savePanicNumber()">Save SOS</button>
          <span class="pill-status" id="panicSavedStatus"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- STEP 02 -->
  <div class="card" id="step-type">
    <div class="card-topline">
      <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: exclamation-circle -->
        <svg viewBox="0 0 24 24"><path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
      </div>
      <div>
        <div class="card-step">Step 02</div>
        <div class="card-title">Type of Emergency</div>
        <div class="card-sub">Select the category that best describes the incident</div>
      </div>
      </div>
      <div class="step-badge">Choose one</div>
    </div>
    <div class="etype-grid" id="typeGrid">
      <div class="etype-btn" onclick="selType(this,'Fire')">
        <div class="etype-icon">
          <!-- Heroicon: fire -->
          <svg viewBox="0 0 24 24"><path d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/><path d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/></svg>
        </div>
        <div class="etype-copy"><strong>Fire</strong><span>House, building, grass, or electrical fire</span></div>
      </div>
      <div class="etype-btn" onclick="selType(this,'Flood')">
        <div class="etype-icon">
          <!-- Heroicon: cloud -->
          <svg viewBox="0 0 24 24"><path d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z"/></svg>
        </div>
        <div class="etype-copy"><strong>Flood</strong><span>Rising water, overflow, or stranded areas</span></div>
      </div>
      <div class="etype-btn" onclick="selType(this,'Medical')">
        <div class="etype-icon">
          <!-- Heroicon: heart -->
          <svg viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z"/></svg>
        </div>
        <div class="etype-copy"><strong>Medical</strong><span>Injury, illness, collapse, or urgent rescue</span></div>
      </div>
      <div class="etype-btn" onclick="selType(this,'Accident')">
        <div class="etype-icon">
          <!-- Heroicon: truck -->
          <svg viewBox="0 0 24 24"><path d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M8.25 18.75V3.375c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v.75"/></svg>
        </div>
        <div class="etype-copy"><strong>Accident</strong><span>Vehicle crash, impact, or road incident</span></div>
      </div>
      <div class="etype-btn" onclick="selType(this,'Landslide')">
        <div class="etype-icon">
          <!-- Heroicon: chart-bar -->
          <svg viewBox="0 0 24 24"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>
        </div>
        <div class="etype-copy"><strong>Landslide</strong><span>Soil movement, collapse, or debris fall</span></div>
      </div>
      <div class="etype-btn" onclick="selType(this,'Other')">
        <div class="etype-icon">
          <!-- Heroicon: ellipsis-horizontal-circle -->
          <svg viewBox="0 0 24 24"><path d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        </div>
        <div class="etype-copy"><strong>Other</strong><span>Use when no listed category fits the incident</span></div>
      </div>
    </div>
    <input type="hidden" id="iType">
  </div>

  <!-- STEP 03 -->
  <div class="card" id="step-severity">
    <div class="card-topline">
      <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: bolt -->
        <svg viewBox="0 0 24 24"><path d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>
      </div>
      <div>
        <div class="card-step">Step 03</div>
        <div class="card-title">Severity Level</div>
        <div class="card-sub">How serious is the situation right now?</div>
      </div>
      </div>
      <div class="step-badge">Priority</div>
    </div>
    <div class="sev-row" id="sevGrid">
      <button class="sev-btn low" type="button" onclick="selSev(this,'Low')">
        <!-- Heroicon: check-circle -->
        <svg viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Low
      </button>
      <button class="sev-btn med" type="button" onclick="selSev(this,'Medium')">
        <!-- Heroicon: exclamation-circle -->
        <svg viewBox="0 0 24 24"><path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>Medium
      </button>
      <button class="sev-btn high" type="button" onclick="selSev(this,'High')">
        <!-- Heroicon: exclamation-triangle -->
        <svg viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>High
      </button>
    </div>
    <div class="severity-guide">
      <div class="severity-note low"><strong>Low</strong><span>Stable incident, no immediate life threat, responders can approach normally.</span></div>
      <div class="severity-note med"><strong>Medium</strong><span>Urgent situation with possible escalation or people needing prompt assistance.</span></div>
      <div class="severity-note high"><strong>High</strong><span>Immediate danger to life, active hazard, trapped victims, or rapidly worsening conditions.</span></div>
    </div>
    <input type="hidden" id="iSev">
  </div>

  <!-- STEP 04 -->
  <div class="card" id="step-location">
    <div class="card-topline">
      <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: map-pin -->
        <svg viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
      </div>
      <div>
        <div class="card-step">Step 04</div>
        <div class="card-title">Location</div>
        <div class="card-sub">Where is the emergency happening?</div>
      </div>
      </div>
      <div class="step-badge">GPS first</div>
    </div>
    <button class="gps-btn" id="gpsBtn" type="button" onclick="detectGPS()">
      <!-- Heroicon: signal -->
      <svg viewBox="0 0 24 24"><path d="M9.348 14.651a3.75 3.75 0 0 1 0-5.303m5.304-.001a3.75 3.75 0 0 1 0 5.304m-7.425 2.122a6.75 6.75 0 0 1 0-9.546m9.546 0a6.75 6.75 0 0 1 0 9.546M5.106 18.894c-3.808-3.808-3.808-9.98 0-13.789m13.788 0c3.808 3.808 3.808 9.981 0 13.79M12 12h.008v.007H12V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
      Auto-detect My Location (GPS)
    </button>
    <div class="gps-meta">
      <div class="gps-meta-pill">
        <svg viewBox="0 0 24 24"><path d="M12 6v6l4 2.25"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        Best used at the scene
      </div>
      <div class="gps-meta-pill">
        <svg viewBox="0 0 24 24"><path d="M2.25 12.76c0 1.6 1.123 2.994 2.67 3.337l2.315.514a48.59 48.59 0 0 0 9.53 0l2.314-.514a3.417 3.417 0 0 0 2.671-3.337V9.24a3.417 3.417 0 0 0-2.67-3.337l-2.315-.514a48.591 48.591 0 0 0-9.53 0l-2.314.514A3.417 3.417 0 0 0 2.25 9.24v3.52Z"/><path d="M12 9v3.75"/></svg>
        Auto-fills nearby details when available
      </div>
    </div>
    <div class="map-callout">
      <svg viewBox="0 0 24 24"><path d="M12 2.25c-3.728 0-6.75 3.022-6.75 6.75 0 5.444 6.75 12.75 6.75 12.75S18.75 14.444 18.75 9c0-3.728-3.022-6.75-6.75-6.75Z"/><path d="M12 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z"/></svg>
      <div>
        <strong>Use the map on the right as a confirmation step</strong>
        <span>After GPS detection, check whether the pin matches the actual incident scene before submitting. If it looks off, update the barangay, landmark, and street fields manually.</span>
      </div>
    </div>
    <input type="hidden" id="iGPS">
    <input type="hidden" id="iGPSAt">
    <input type="hidden" id="iGPSAcc">
    <div class="row2">
      <div class="field">
        <label>Barangay *</label>
        <div class="input-wrap has-icon">
          <svg class="field-icon" viewBox="0 0 24 24"><path d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z"/></svg>
          <input type="text" id="iBarangay" placeholder="e.g. Barangay Rizal" required>
        </div>
        <div class="field-note">Keep this specific so responders can route the report to the correct area.</div>
      </div>
      <div class="field">
        <label>Nearest Landmark *</label>
        <div class="input-wrap has-icon">
          <svg class="field-icon" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
          <input type="text" id="iLandmark" placeholder="e.g. Near Municipal Hall" required>
        </div>
        <div class="field-note">Use a building, crossing, school, bridge, or any place responders can spot quickly.</div>
      </div>
    </div>
    <div class="field">
      <label>Street / Additional Details *</label>
      <div class="input-wrap has-icon">
        <svg class="field-icon" viewBox="0 0 24 24"><path d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5"/></svg>
        <input type="text" id="iStreet" placeholder="Street name or additional details" required>
      </div>
      <div class="field-note">Include purok, road direction, blocked access, or any detail that helps the team approach safely.</div>
    </div>
  </div>

  <!-- STEP 05 -->
  <div class="card" id="step-details">
    <div class="card-topline">
      <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: pencil-square -->
        <svg viewBox="0 0 24 24"><path d="M16.862 4.487 18.55 2.8a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/></svg>
      </div>
      <div>
        <div class="card-step">Step 05</div>
        <div class="card-title">Incident Details</div>
        <div class="card-sub">Describe the situation and attach a photo if possible</div>
      </div>
      </div>
      <div class="step-badge">Context</div>
    </div>
    <div class="field">
      <label>Description (optional)</label>
      <textarea id="iDesc" placeholder="Describe what is happening. Include: number of people affected, current situation, any danger present..."></textarea>
      <div class="field-note">Optional but helpful: injuries, trapped people, hazards, flooding depth, fire spread, or anything changing fast.</div>
    </div>
    <div class="field">
      <label>Upload Photo (optional)</label>
      <label class="upload-area" for="iPhoto">
        <svg viewBox="0 0 24 24"><path d="M3 16.5V7.75A2.75 2.75 0 0 1 5.75 5h2.086a1.5 1.5 0 0 0 1.06-.44l.604-.603A1.5 1.5 0 0 1 10.56 3.5h2.88a1.5 1.5 0 0 1 1.06.44l.604.603a1.5 1.5 0 0 0 1.06.44h2.086A2.75 2.75 0 0 1 21 7.75v8.75A2.75 2.75 0 0 1 18.25 19H5.75A2.75 2.75 0 0 1 3 16.25v.25Z"/><path d="M9 12.5a3 3 0 1 0 6 0 3 3 0 0 0-6 0Z"/></svg>
        <div class="upload-label">Click or tap to upload a photo</div>
        <div class="upload-hint">JPG, PNG, or WEBP up to 10 MB</div>
        <input id="iPhoto" type="file" accept="image/png,image/jpeg,image/webp" onchange="handleReportPhotoChange(event)">
      </label>
      <div class="upload-meta" id="uploadMeta">
        <img class="upload-thumb" id="uploadThumb" alt="Selected upload preview">
        <div class="upload-file">
          <strong id="uploadFileName">No file selected</strong>
