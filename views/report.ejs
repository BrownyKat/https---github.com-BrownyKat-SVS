    area.innerHTML = '';
    const grid = document.createElement('div');
    grid.className = 'upload-grid flex flex-wrap gap-3';
    photoDataList.forEach((src, idx) => {
      const wrap = document.createElement('div');
      wrap.className = 'upload-thumb relative h-[110px] w-[110px] overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm';
      const img = document.createElement('img');
      img.className = 'h-full w-full object-cover';
