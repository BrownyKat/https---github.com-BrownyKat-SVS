<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SVS - Report Emergency</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="overflow-x-hidden bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.08),_transparent_35%),linear-gradient(180deg,#f8fafc_0%,#eef4ff_100%)] font-['Outfit'] text-slate-900 antialiased selection:bg-blue-100 selection:text-blue-800">

<!-- HEADER -->
<%- include('partials/navbar', { active: 'report', timeId: 'reportTime' }) %>

<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8" id="report-form">
  <div class="grid items-start justify-items-center gap-8">
    <div class="w-full max-w-5xl min-w-0">
      <section class="mb-8 overflow-hidden rounded-[30px] border border-slate-200 bg-white/90 p-6 shadow-[0_24px_60px_rgba(15,23,42,0.08)] backdrop-blur sm:p-8">
        <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_260px] xl:items-start">
          <div>
            <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-blue-100 bg-blue-50 px-3 py-1 font-['JetBrains_Mono'] text-[0.7rem] font-bold uppercase tracking-wider text-blue-700">
              <!-- Heroicon: document-text -->
              <svg class="h-4 w-4 stroke-current fill-none [stroke-width:1.8]" viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
              SVS Emergency Report System
            </div>
            <h1 class="max-w-3xl text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-[2.7rem]">Report an <span class="text-blue-600">Emergency</span></h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">Send the most important details first, confirm the scene location, and help dispatchers act faster with a cleaner report.</p>
            <div class="mt-5 flex flex-wrap gap-3">
              <button class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm transition hover:bg-slate-50 hover:text-blue-700" type="button" onclick="alertQueued()">
                <svg class="h-4 w-4 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M12 6v6l4 2.25"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                Offline Queue (<span id="pendingCount">0</span>)
              </button>
              <div class="inline-flex items-center gap-2 rounded-full border border-emerald-100 bg-emerald-50 px-4 py-2 text-sm font-medium text-emerald-700">
                <svg class="h-4 w-4 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M4.5 12.75l6 6 9-13.5"/></svg>
                Mobile-friendly form layout
              </div>
            </div>
          </div>
          <div class="rounded-[28px] border border-slate-200 bg-slate-50/80 p-5">
            <div class="font-['JetBrains_Mono'] text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500">Response Ready</div>
            <div class="mt-4 space-y-4">
              <div class="flex items-start gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-blue-100 text-blue-700">
                  <svg class="h-5 w-5 stroke-current fill-none [stroke-width:1.8]" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">Pin the scene clearly</div>
                  <p class="mt-1 text-sm leading-6 text-slate-500">GPS helps most when you are physically near the incident.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
                  <svg class="h-5 w-5 stroke-current fill-none [stroke-width:1.8]" viewBox="0 0 24 24"><path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">Lead with the risk</div>
                  <p class="mt-1 text-sm leading-6 text-slate-500">Mention injuries, fire spread, blocked roads, or active hazards first.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
                  <svg class="h-5 w-5 stroke-current fill-none [stroke-width:1.8]" viewBox="0 0 24 24"><path d="M2.25 6.338c0 7.5 6.089 13.587 13.589 13.587l.682-.002a1.124 1.124 0 0 0 1.12-1.065l.254-3.223a1.125 1.125 0 0 0-.89-1.207l-2.98-.67a1.125 1.125 0 0 0-1.264.597l-.75 1.5a11.775 11.775 0 0 1-4.955-4.955l1.5-.75a1.125 1.125 0 0 0 .597-1.264l-.67-2.98a1.125 1.125 0 0 0-1.207-.89l-3.223.254a1.124 1.124 0 0 0-1.065 1.12L2.25 6.338Z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">Stay reachable</div>
                  <p class="mt-1 text-sm leading-6 text-slate-500">Dispatchers may call right away to verify and coordinate response.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="h-full rounded-[26px] border border-slate-200 bg-[linear-gradient(145deg,#ffffff,#eff6ff)] p-5 shadow-sm">
            <div class="mb-4 flex items-start gap-4">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-blue-100 text-blue-700">
                <svg class="h-5 w-5 stroke-current fill-none [stroke-width:1.8]" viewBox="0 0 24 24"><path d="M12 6v6l4 2.25"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-slate-900">How to report</h3>
                <p class="text-sm text-slate-500">Focus on the details that change response time.</p>
              </div>
            </div>
            <div class="space-y-2.5">
              <div class="flex items-start gap-3 text-sm text-slate-600"><div class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500"></div><span><strong>Pin location:</strong> Use GPS if safe.</span></div>
              <div class="flex items-start gap-3 text-sm text-slate-600"><div class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500"></div><span><strong>Describe risk:</strong> Mention injuries or hazards.</span></div>
              <div class="flex items-start gap-3 text-sm text-slate-600"><div class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500"></div><span><strong>Stay reachable:</strong> We may call you back.</span></div>
            </div>
          </div>
          <div class="h-full rounded-[26px] border border-slate-200 bg-[linear-gradient(145deg,#ffffff,#fff7ed)] p-5 shadow-sm">
            <div class="mb-4 flex items-start gap-4">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
                <svg class="h-5 w-5 stroke-current fill-none [stroke-width:1.8]" viewBox="0 0 24 24"><path d="M3.75 12h16.5M12 3.75v16.5"/><path d="M4.5 4.5h15v15h-15z"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-slate-900">What happens next</h3>
                <p class="text-sm text-slate-500">Know what dispatchers will do with your report.</p>
              </div>
            </div>
            <div class="space-y-2.5">
              <div class="flex items-start gap-3 text-sm text-slate-600"><div class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500"></div><span><strong>Instant alert:</strong> Dispatchers see your report immediately.</span></div>
              <div class="flex items-start gap-3 text-sm text-slate-600"><div class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500"></div><span><strong>Verification:</strong> We may call you to confirm details.</span></div>
            </div>
          </div>
        </div>
      </section>

  <div class="mb-8 flex items-start gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-800">
    <!-- Heroicon: exclamation-triangle -->
    <svg class="mt-0.5 h-5 w-5 shrink-0 stroke-red-600" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
    <span><strong>For life-threatening emergencies, call 911 immediately.</strong><br>This form is for reporting incidents and requesting assistance through SVS.</span>
  </div>

  <div class="space-y-6">
  <!-- STEP 01 -->
  <div class="scroll-mt-28 rounded-xl border border-slate-200 bg-white p-6 shadow-sm" id="step-reporter">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-4">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-blue-50 text-blue-600 ring-4 ring-blue-50/50">
        <!-- Heroicon: user -->
        <svg class="h-6 w-6 stroke-current" viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
      </div>
      <div>
        <div class="text-xs font-bold uppercase tracking-wider text-slate-400">Step 01</div>
        <h2 class="text-lg font-bold text-slate-900">Your Information</h2>
      </div>
      </div>
      <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-slate-500">Required</div>
    </div>
    <div class="grid gap-6 sm:grid-cols-2">
      <div class="space-y-2">
        <label class="block text-sm font-semibold text-slate-700">Full Name *</label>
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="h-5 w-5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
          </div>
          <input class="block w-full rounded-lg border-slate-300 py-2.5 pl-10 text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20" type="text" id="iName" placeholder="Juan dela Cruz" required>
        </div>
      </div>
      <div class="space-y-2">
        <label class="block text-sm font-semibold text-slate-700">Contact Number *</label>
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="h-5 w-5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.25 6.338c0 7.5 6.089 13.587 13.589 13.587l.682-.002a1.124 1.124 0 0 0 1.12-1.065l.254-3.223a1.125 1.125 0 0 0-.89-1.207l-2.98-.67a1.125 1.125 0 0 0-1.264.597l-.75 1.5a11.775 11.775 0 0 1-4.955-4.955l1.5-.75a1.125 1.125 0 0 0 .597-1.264l-.67-2.98a1.125 1.125 0 0 0-1.207-.89l-3.223.254a1.124 1.124 0 0 0-1.065 1.12L2.25 6.338Z"/></svg>
          </div>
          <input class="block w-full rounded-lg border-slate-300 py-2.5 pl-10 text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20" type="tel" id="iContact" placeholder="+63 917 123 4567" inputmode="tel" autocomplete="tel" maxlength="16" required>
        </div>
        <div class="mt-4 flex flex-wrap items-center gap-3 rounded-lg border border-slate-200 bg-slate-50 p-3">
          <label class="text-xs font-bold uppercase tracking-wide text-slate-500" for="iPanicContact">Quick SOS #</label>
          <input class="w-[160px] max-w-full rounded-md border-slate-300 px-3 py-1.5 text-sm text-slate-900 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" type="tel" id="iPanicContact" placeholder="+63 9XX" inputmode="tel" maxlength="16">
          <button class="rounded-md bg-white px-3 py-1.5 text-xs font-semibold text-blue-700 shadow-sm ring-1 ring-slate-200 hover:bg-slate-50 hover:text-blue-800" type="button" onclick="savePanicNumber()">Save</button>
          <span class="pill-status text-sm font-semibold text-slate-500" id="panicSavedStatus"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- STEP 02 -->
  <div class="scroll-mt-28 rounded-xl border border-slate-200 bg-white p-6 shadow-sm" id="step-type">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-4">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-amber-50 text-amber-600 ring-4 ring-amber-50/50">
        <!-- Heroicon: exclamation-circle -->
        <svg class="h-6 w-6 stroke-current" viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
      </div>
      <div>
        <div class="text-xs font-bold uppercase tracking-wider text-slate-400">Step 02</div>
        <h2 class="text-lg font-bold text-slate-900">Type of Emergency</h2>
      </div>
      </div>
      <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-slate-500">Choose one</div>
    </div>
    <div class="grid gap-4 md:grid-cols-2 2xl:grid-cols-3" id="typeGrid">
      <div class="etype-btn group flex h-full cursor-pointer items-start gap-4 rounded-2xl border border-slate-200 bg-white p-4 text-left transition duration-200 hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-sm" onclick="selType(this,'Fire')">
        <div class="etype-icon flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-rose-100 bg-rose-50 text-rose-600 transition">
          <!-- Heroicon: fire -->
          <svg class="h-6 w-6 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/><path d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/></svg>
        </div>
        <div class="etype-copy min-w-0">
          <strong class="block text-sm font-bold text-slate-900">Fire</strong>
          <span class="mt-1 block text-xs leading-5 text-slate-500">Flames, smoke, electrical sparks, or explosion risk.</span>
        </div>
      </div>
      <div class="etype-btn group flex h-full cursor-pointer items-start gap-4 rounded-2xl border border-slate-200 bg-white p-4 text-left transition duration-200 hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-sm" onclick="selType(this,'Flood')">
        <div class="etype-icon flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-sky-100 bg-sky-50 text-sky-600 transition">
          <!-- Heroicon: cloud -->
          <svg class="h-6 w-6 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z"/></svg>
        </div>
        <div class="etype-copy min-w-0">
          <strong class="block text-sm font-bold text-slate-900">Flood</strong>
          <span class="mt-1 block text-xs leading-5 text-slate-500">Rising water, trapped residents, or fast-changing road access.</span>
        </div>
      </div>
      <div class="etype-btn group flex h-full cursor-pointer items-start gap-4 rounded-2xl border border-slate-200 bg-white p-4 text-left transition duration-200 hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-sm" onclick="selType(this,'Medical')">
        <div class="etype-icon flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-emerald-100 bg-emerald-50 text-emerald-600 transition">
          <!-- Heroicon: heart -->
          <svg class="h-6 w-6 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z"/></svg>
        </div>
        <div class="etype-copy min-w-0">
          <strong class="block text-sm font-bold text-slate-900">Medical</strong>
          <span class="mt-1 block text-xs leading-5 text-slate-500">Urgent illness, injury, unconscious person, or breathing issue.</span>
        </div>
      </div>
      <div class="etype-btn group flex h-full cursor-pointer items-start gap-4 rounded-2xl border border-slate-200 bg-white p-4 text-left transition duration-200 hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-sm" onclick="selType(this,'Accident')">
        <div class="etype-icon flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-amber-100 bg-amber-50 text-amber-600 transition">
          <!-- Heroicon: truck -->
          <svg class="h-6 w-6 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M8.25 18.75V3.375c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v.75"/></svg>
        </div>
        <div class="etype-copy min-w-0">
          <strong class="block text-sm font-bold text-slate-900">Accident</strong>
          <span class="mt-1 block text-xs leading-5 text-slate-500">Vehicular crash, road incident, or impact with possible injuries.</span>
        </div>
      </div>
      <div class="etype-btn group flex h-full cursor-pointer items-start gap-4 rounded-2xl border border-slate-200 bg-white p-4 text-left transition duration-200 hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-sm" onclick="selType(this,'Landslide')">
        <div class="etype-icon flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-stone-200 bg-stone-100 text-stone-700 transition">
          <!-- Heroicon: chart-bar -->
          <svg class="h-6 w-6 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>
        </div>
        <div class="etype-copy min-w-0">
          <strong class="block text-sm font-bold text-slate-900">Landslide</strong>
          <span class="mt-1 block text-xs leading-5 text-slate-500">Slope movement, collapsed ground, or blocked evacuation routes.</span>
        </div>
      </div>
      <div class="etype-btn group flex h-full cursor-pointer items-start gap-4 rounded-2xl border border-slate-200 bg-white p-4 text-left transition duration-200 hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-sm" onclick="selType(this,'Other')">
        <div class="etype-icon flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-slate-200 bg-slate-100 text-slate-600 transition">
          <!-- Heroicon: ellipsis-horizontal-circle -->
          <svg class="h-6 w-6 stroke-current fill-none [stroke-width:1.75]" viewBox="0 0 24 24"><path d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        </div>
        <div class="etype-copy min-w-0">
          <strong class="block text-sm font-bold text-slate-900">Other</strong>
