  const PHOTO_LIMIT = 10;

  async function handlePhoto(input) {
    const files = Array.from((input && input.files) || []);
    if (!files.length) return;
    let added = 0;
    for (const file of files) {
      if (photoDataList.length >= PHOTO_LIMIT) { toast('Limit reached', 'You can attach up to 10 photos.', 'warn'); break; }
      if (!/^image\/(png|jpe?g|webp)$/i.test(file.type || '')) { toast('Invalid image', 'Use PNG, JPG, or WEBP only.', 'warn'); continue; }
      if (file.size > 10 * 1024 * 1024) { toast('Image too large', 'Each image must be under 10 MB.', 'warn'); continue; }
      const result = await new Promise((resolve, reject) => {
        const r = new FileReader();
        r.onload = e => resolve(String((e && e.target && e.target.result) || '').trim());
        r.onerror = () => reject(new Error('Could not read file'));
        r.readAsDataURL(file);
      }).catch(() => null);
      if (!result || !isSafeImageDataUrl(result)) { toast('Invalid image', 'Could not process this photo safely.', 'warn'); continue; }
      photoDataList.push(result);
      added++;
    }
    if (input) input.value = '';
    if (added) renderPhotoArea();
  }

  function renderPhotoArea() {
    const area = document.getElementById('uploadArea');
    if (!area) return;
    if (!photoDataList.length) {
      area.innerHTML = emptyUploadAreaHtml();
      return;
