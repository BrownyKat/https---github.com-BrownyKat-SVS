  // Image verification modal
  const imgModal = document.getElementById('imgModal');
  const imgPrev = document.getElementById('imgModalPreview');
  const imgReport = document.getElementById('imgModalReport');
  const imgName = document.getElementById('imgModalName');
  const imgNotes = document.getElementById('imgModalNotes');
  const imgPrevBtn = document.getElementById('imgPrevBtn');
  const imgNextBtn = document.getElementById('imgNextBtn');
  let imgModalState = { reportId: '', name: '', photos: [], index: 0 };

  // mic permission
  const permModal = document.getElementById('permModal');
  const permStatus = document.getElementById('permStatus');
  let micPermissionGranted = false;
  let micPermissionPromise = null;
  let pendingCallAction = null;

  function openImgModal(photos, index = 0, reportId, name) {
    if (!Array.isArray(photos) || !photos.length) return;
    const idx = Math.max(0, Math.min(index, photos.length - 1));
    imgPrev.src = photos[idx];
    imgReport.textContent = reportId || 'Report';
    imgName.textContent = name || '-';
    imgNotes.value = '';
    imgModalState = { reportId, name, photos, index: idx };
    updateImgNav();
    imgModal.classList.add('show');
  }
  function closeImgModal() {
    imgModal.classList.remove('show');
    imgPrev.src = '';
    imgNotes.value = '';
    imgModalState = { reportId: '', name: '', photos: [], index: 0 };
  }
  function updateImgNav() {
    const total = imgModalState.photos.length;
    imgPrevBtn.disabled = imgModalState.index <= 0;
    imgNextBtn.disabled = imgModalState.index >= total - 1;
  }
  function stepImg(delta) {
    const total = imgModalState.photos.length;
    if (!total) return;
    const next = Math.max(0, Math.min(total - 1, imgModalState.index + delta));
    imgModalState.index = next;
    imgPrev.src = imgModalState.photos[next];
    updateImgNav();
  }
  function openPermModal(message = '') {
    if (permStatus) permStatus.textContent = message || '';
    permModal.classList.add('show');
  }
  function closePermModal() { permModal.classList.remove('show'); }

  async function requestMicPermission() {
    if (micPermissionPromise) return micPermissionPromise;
    micPermissionPromise = (async () => {
      try {
        if (permStatus) permStatus.textContent = '';
        const isSecure = location.protocol === 'https:' || location.hostname === 'localhost' || location.hostname === '127.0.0.1';
        if (!isSecure) {
          if (permStatus) permStatus.textContent = 'Microphone access requires HTTPS (or localhost). Please open the secure version of this site.';
          throw new Error('Insecure context');
        }
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
        micPermissionGranted = true;
        if (permStatus) permStatus.textContent = 'Mic allowed. Connecting…';
        closePermModal();
        const action = pendingCallAction;
        pendingCallAction = null;
        if (typeof action === 'function') action();
        return stream;
      } catch (e) {
        micPermissionGranted = false;
        const code = (e && e.name) || '';
        if (permStatus) {
          permStatus.textContent = code === 'NotAllowedError'
            ? 'Permission denied. Click "Allow mic" again and accept the browser prompt (or unblock mic in your address bar).'
            : 'Could not access mic. Check browser permission and try again.';
        }
        throw e;
      } finally {
        micPermissionPromise = null;
      }
    })();
    return micPermissionPromise;
  }

  document.addEventListener('click', (e)=>{
    const launch = e.target.closest('.photo-launch');
    if (launch) {
      const reportId = launch.dataset.report || '';
      const reportName = launch.dataset.name || '';
      loadReportMedia(reportId)
        .then(photos => {
          if (!Array.isArray(photos) || !photos.length) {
            toast_('No photos', 'No report photos are available right now.', 'warn');
            return;
          }
          openImgModal(photos, 0, reportId, reportName);
        })
        .catch(err => {
          toast_('Photos unavailable', err && err.message ? err.message : 'Could not load report photos.', 'warn');
        });
      return;
    }
    const stack = e.target.closest('.photo-stack');
    if (stack) {
      let photos = [];
      try{ photos = JSON.parse(stack.dataset.photos || '[]'); }catch(_e){}
      if (!Array.isArray(photos) || !photos.length) return;
      const idx = Number(e.target.dataset.index || 0);
      openImgModal(photos, isNaN(idx)?0:idx, stack.dataset.report, stack.dataset.name);
    }
  });
  document.addEventListener('keydown', (e)=>{
    if (e.key === 'Escape' && imgModal.classList.contains('show')) closeImgModal();
  });

    const WEB_CALL_POLL_MS = 1500;
  let webCallPc = null;
  let webCallLocalStream = null;
  let webCallReportId = "";
  let webCallRole = "";
  let webCallAppliedOffer = 0;
  let webCallAppliedAnswer = 0;
  let webCallPollTimer = null;
  const webCallRemoteAudio = new Audio();
  webCallRemoteAudio.autoplay = true;
  const webCallPanel = document.getElementById("webCallPanel");
  const webCallStatusEl = document.getElementById("webCallStatus");
  const webCallLabelEl = document.getElementById("webCallReportLabel");
  const webCallAcceptBtn = document.getElementById("webCallAcceptBtn");
  const webCallHangBtn = document.getElementById("webCallHangBtn");

  function setWebCallUI(label, status, opts = {}) {
    const show = opts.show !== false;
    if (webCallPanel) webCallPanel.classList.toggle("hidden", !show);
    if (webCallLabelEl) webCallLabelEl.textContent = label || "Idle";
    if (webCallStatusEl) webCallStatusEl.textContent = status || "";
    if (webCallAcceptBtn) webCallAcceptBtn.disabled = !opts.enableAccept;
    if (webCallHangBtn) webCallHangBtn.disabled = !opts.enableHang;
  }

  async function clearWebCall(notifyServer = false) {
    const prevId = webCallReportId;
    try {
      if (webCallPollTimer) clearTimeout(webCallPollTimer);
      webCallPollTimer = null;
      if (webCallPc) {
        webCallPc.onicecandidate = null;
        webCallPc.ontrack = null;
        webCallPc.onconnectionstatechange = null;
        webCallPc.close();
      }
      if (webCallLocalStream) webCallLocalStream.getTracks().forEach(t => t.stop());
      if (notifyServer && webCallReportId) {
        try { await fetch(`/api/call/${encodeURIComponent(webCallReportId)}`, { method: "DELETE", credentials: "same-origin" }); } catch (_e) {}
      }
    } finally {
      webCallPc = null;
      webCallLocalStream = null;
      webCallRole = "";
      webCallReportId = "";
      webCallAppliedOffer = 0;
      webCallAppliedAnswer = 0;
      setWebCallUI("Idle", "Not connected", { show: false, enableAccept: false, enableHang: false });
      if (prevId) callStartedIds.delete(prevId);
      render();
    }
  }

  async function ensureLocalAudio(userInitiated = false) {
    if (webCallLocalStream) return webCallLocalStream;
    if (!micPermissionGranted) {
      if (!userInitiated) {
        openPermModal('Click "Allow mic" to proceed.');
        pendingCallAction = null;
        throw new Error('awaiting user mic permission');
      }
      openPermModal();
      await requestMicPermission();
    }
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
    webCallLocalStream = stream;
    return stream;
  }

  async function sendCandidate(reportId, role, candidate) {
    try {
      await fetch(`/api/call/${encodeURIComponent(reportId)}/candidate`, {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ role, candidate }),
      });
    } catch (_e) {}
  }

  async function fetchSignal(reportId) {
    const res = await fetch(`/api/call/${encodeURIComponent(reportId)}/signal`, { credentials: "same-origin" });
    if (!res.ok) return null;
    return res.json().catch(() => null);
  }

  async function pollWebCallSignals() {
    if (!webCallReportId || !webCallPc) return;
    try {
      const sig = await fetchSignal(webCallReportId);
      if (!sig) return;
      if (webCallRole === "offer" && sig.answer && sig.answer.sdp && !webCallPc.currentRemoteDescription) {
        await webCallPc.setRemoteDescription({ type: sig.answer.type || "answer", sdp: sig.answer.sdp });
        setWebCallUI("Report " + webCallReportId, "Connected", { show: true, enableHang: true });
      }
      const list = webCallRole === "offer" ? (sig.answerCandidates || []) : (sig.offerCandidates || []);
      const applied = webCallRole === "offer" ? webCallAppliedAnswer : webCallAppliedOffer;
      const newOnes = list.slice(applied);
      for (const c of newOnes) {
        try { await webCallPc.addIceCandidate(new RTCIceCandidate(c)); } catch (_e) {}
      }
      if (webCallRole === "offer") webCallAppliedAnswer = list.length; else webCallAppliedOffer = list.length;
    } finally {
      if (webCallReportId) webCallPollTimer = setTimeout(pollWebCallSignals, WEB_CALL_POLL_MS);
    }
  }

  async function setupPeer(reportId, role, remoteOffer = null) {
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      toast_("Web call unsupported", "This browser cannot start a web call.", "warn");
      return false;
    }
    await clearWebCall(false);
    webCallReportId = reportId;
    webCallRole = role;
    setWebCallUI("Report " + reportId, role === "offer" ? "Calling…" : "Joining call…", { show: true, enableHang: true, enableAccept: false });

    const pc = new RTCPeerConnection({ iceServers: [{ urls: "stun:stun.l.google.com:19302" }] });
    webCallPc = pc;
    pc.onconnectionstatechange = () => {
      const st = pc.connectionState;
      if (st === "failed" || st === "disconnected" || st === "closed") {
        setWebCallUI("Report " + reportId, "Call ended", { show: true, enableHang: false });
        clearWebCall(false);
      }
    };
    pc.ontrack = (event) => {
      const stream = event.streams && event.streams[0];
      if (stream) webCallRemoteAudio.srcObject = stream;
    };
    pc.onicecandidate = (event) => {
      if (event.candidate) void sendCandidate(reportId, role, event.candidate);
    };

    const stream = await ensureLocalAudio(true);
    stream.getTracks().forEach(track => pc.addTrack(track, stream));

    if (role === "offer") {
      const offer = await pc.createOffer({ offerToReceiveAudio: true, offerToReceiveVideo: false });
      await pc.setLocalDescription(offer);
      await fetch(`/api/call/${encodeURIComponent(reportId)}/offer`, {
        method: "POST", credentials: "same-origin", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ sdp: offer.sdp, type: offer.type }),
      });
      webCallAppliedOffer = 0; webCallAppliedAnswer = 0;
      pollWebCallSignals();
    } else {
      if (!remoteOffer || !remoteOffer.sdp) {
        toast_("Web call", "Offer is missing or expired.", "warn");
        return false;
      }
      await pc.setRemoteDescription({ type: remoteOffer.type || "offer", sdp: remoteOffer.sdp });
      const answer = await pc.createAnswer();
      await pc.setLocalDescription(answer);
      await fetch(`/api/call/${encodeURIComponent(reportId)}/answer`, {
        method: "POST", credentials: "same-origin", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ sdp: answer.sdp, type: answer.type }),
      });
      pollWebCallSignals();
    }
    return true;
  }

  async function startWebCall(reportId) {
    if (!reportId) return;
    if (webCallReportId && webCallReportId !== reportId) await clearWebCall(false);
    try {
      if (!micPermissionGranted) {
        pendingCallAction = () => { startWebCall(reportId); };
        openPermModal('Click "Allow mic" to start the call.');
        return;
      }
      const sig = await fetchSignal(reportId);
      const existingOffer = sig && sig.offer && sig.offer.sdp ? sig.offer : null;
      const alreadyAnswered = sig && sig.answer && sig.answer.sdp;
      if (existingOffer && !alreadyAnswered && String(existingOffer.fromId || "") !== currentUserId) {
        setWebCallUI("Report " + reportId, "Incoming web call – connecting…", { show: true, enableHang: true });
        await setupPeer(reportId, "answer", existingOffer);
        const rep = reports.find(r => normalizeId(r.id || r.reportId || r._id || '') === reportId);
        if (rep && String(rep.assignedToId || '') === currentUserId && String(rep.status || '') === 'new') {
          callStartedIds.add(reportId);
          render();
        }
        return;
      }
      await setupPeer(reportId, "offer", null);
      const rep = reports.find(r => normalizeId(r.id || r.reportId || r._id || '') === reportId);
      if (rep && String(rep.assignedToId || '') === currentUserId && String(rep.status || '') === 'new') {
        callStartedIds.add(reportId);
        render();
      }
    } catch (e) {
      toast_("Web call", e && e.message ? e.message : "Could not start web call.", "warn");
      await clearWebCall(false);
    }
  }

  if (webCallHangBtn) webCallHangBtn.addEventListener("click", () => { void clearWebCall(true); });
  if (webCallAcceptBtn) webCallAcceptBtn.addEventListener("click", async () => {
    if (!webCallReportId) return;
    const sig = await fetchSignal(webCallReportId);
    if (sig && sig.offer && sig.offer.sdp) {
      if (!micPermissionGranted) {
        pendingCallAction = () => { void webCallAcceptBtn.click(); };
        openPermModal('Click "Allow mic" to join the call.');
        return;
      }
      try{
        await ensureLocalAudio(true);
        await setupPeer(webCallReportId, "answer", sig.offer);
      }catch(_e){}
    }
  });

  // Realtime events
  if (channel) channel.bind('new-report', r => {
    const nr = normalizeReport(r);
    if (!canSeeReport(nr)) return;
    upsertReport(nr);
    render();
    void hydrateLegacyPanicLocations();
    if (nr.isPanic || nr.emergencyType === 'PANIC SOS') addNotification('PANIC SOS', `${nr.barangay || 'Unknown area'} - panic received`, 'alert');
    checkHotspot(nr);
    toast_(nr.isPanic?'PANIC SOS':'New Report', `${nr.emergencyType} â€” ${nr.barangay}`);
    requestAnimationFrame(()=>{
      const el=document.getElementById(`card-${nr.id}`);
      if (el){el.classList.add('card-flash');setTimeout(()=>el.classList.remove('card-flash'),1800);}
    });
  });
  if (channel) channel.bind('report-updated', updated => {
    const id = updated && updated.id ? updated.id : '';
    const r = reports.find(x=>x.id===id);
    if (!r) return;
    r.status = updated && updated.status ? updated.status : r.status;
    if (Object.prototype.hasOwnProperty.call(updated || {}, 'assignedToId')) {
      r.assignedToId = String(updated.assignedToId || '');
      r.assignedToName = String((updated && updated.assignedToName) || '');
      r.assignedAt = (updated && updated.assignedAt) || null;
      if (!canSeeReport(r)) {
        reports = reports.filter(x => x.id !== id);
      }
    }
    lastReportsSig = reportsSignature(reports);
    render();
  });
  if (channel) channel.bind('report-details-updated', updated => {
    const u = normalizeReport(updated);
    if (canSeeReport(u)) upsertReport(u);
    else reports = reports.filter(x => x.id !== u.id);
    lastReportsSig = reportsSignature(reports);
    render();
    pendingClaims.delete(u.id || (updated && updated.id) || '');
  });
  if (channel) channel.bind('report-assignment-updated', updated => {
    const u = normalizeReport(updated);
    const reportIdToMatch = u.id || u.reportId || u._id || (updated && updated.id) || '';
    if (!reportIdToMatch) return; // Skip if no ID
    
    if (canSeeReport(u)) {
      upsertReport(u);
    } else {
      // Remove report if current user can no longer see it
      reports = reports.filter(x => {
        const xId = x.id || x.reportId || x._id || '';
        return xId !== reportIdToMatch;
      });
    }
    lastReportsSig = reportsSignature(reports);
    render();
    if (updated && updated.lastPassedByName) {
      addNotification('Report passed', `${updated.lastPassedByName} passed ${reportIdToMatch} to ${updated.assignedToName || 'dispatcher'}.`, 'info');
    }
  });
  if (channel) channel.bind('reports-cleared', ()=>{ reports=[]; lastReportsSig = reportsSignature(reports); render(); });

  let refreshInFlight = false;
  async function refreshDashboardNow(forceRender = false) {
    if (refreshInFlight) return;
    refreshInFlight = true;
    try {
      await Promise.all([
        syncReportsFromServer(forceRender),
        syncActiveDispatchers(),
      ]);
    } finally {
      refreshInFlight = false;
    }
  }

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') {
      void refreshDashboardNow(true);
    }
  });
  window.addEventListener('focus', () => { void refreshDashboardNow(true); });
  window.addEventListener('online', () => { void refreshDashboardNow(true); });

  // initial render
  render();
  // kick an immediate sync to avoid any stale first view
  void refreshDashboardNow(true);
  setInterval(() => { void syncReportsFromServer(); }, REPORTS_POLL_MS);
  setInterval(() => { void syncActiveDispatchers(); }, ACTIVE_DISPATCHERS_POLL_MS);
  updateDateTime();
  setInterval(updateDateTime, 1000);
  loadWeather();
  setInterval(loadWeather, 600000);
</script>
</body>
</html>
