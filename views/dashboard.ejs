<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SVS - Dispatcher Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --amber:        #FACC15;
      --amber-dark:   #EAB308;
      --amber-deep:   #CA8A04;
      --amber-light:  #FEFCE8;
      --amber-border: #FDE047;
      --orange:       #DC2626;
      --orange-light: #FEF2F2;
      --orange-border:#FCA5A5;
      --red:          #DC2626;
      --red-light:    #FEF2F2;
      --red-border:   #FCA5A5;
      --green:        #2563EB;
      --green-light:  #E8F0FF;
      --green-border: #C4DAFF;
      --blue:         #1D4ED8;
      --blue-light:   #EEF2F6;
      --blue-border:  #CBD5E1;
      --indigo:       #1E3A8A;
      --bg:           #f5f7fb;
      --surface:      #ffffff;
      --surface2:     #f8fafc;
      --border:       #e5e7eb;
      --border-mid:   #d4d7dd;
      --text:         #0f172a;
      --text2:        #0f172a;
      --muted:        #4b5563;
      --muted2:       #6b7280;
      --shadow-xs: 0 1px 2px rgba(15,23,42,.04);
      --shadow-sm: 0 2px 6px rgba(15,23,42,.06);
      --shadow-md: 0 8px 18px rgba(15,23,42,.08);
      --shadow-lg: 0 16px 34px rgba(15,23,42,.1);
      --shadow-xl: 0 28px 48px rgba(15,23,42,.12);
      --r-sm:8px;--r-md:12px;--r-lg:16px;--r-xl:20px;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    body{
      font-family:'Outfit',sans-serif;color:var(--text);-webkit-font-smoothing:antialiased;
      min-height:100vh;display:flex;flex-direction:column;overflow:hidden;
      background:linear-gradient(180deg,#f8fafc 0%,#f5f7fb 100%);
    }
    ::-webkit-scrollbar{width:5px;height:5px;} ::-webkit-scrollbar-track{background:transparent;} ::-webkit-scrollbar-thumb{background:var(--border-mid);border-radius:99px;}

    /* Ã¢â€â‚¬Ã¢â€â‚¬ HEADER Ã¢â€â‚¬Ã¢â€â‚¬ */
    .header{
      height:82px;flex-shrink:0;
      display:flex;align-items:center;justify-content:space-between;
      padding:0 1.5rem;
      background:var(--surface);
      backdrop-filter:blur(12px);
      border-bottom:1px solid var(--border);
      box-shadow:var(--shadow-sm);
      position:sticky;top:0;
      z-index:220;
    }
    .brand{display:flex;align-items:center;gap:0;text-decoration:none;color:inherit;}
    .brand-logo{
      width:164px;height:134px;object-fit:contain;display:block;flex-shrink:0;
    }
    .brand-text{margin-left:-38px;}
    .brand-name{font-weight:800;font-size:1.2rem;letter-spacing:-.2px;line-height:1.1;color:var(--text);}
    .brand-name em{font-style:normal;color:var(--amber-dark);}
    .brand-sub{font-family:'JetBrains Mono',monospace;font-size:.68rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);}
    .header-right{display:flex;align-items:center;gap:.65rem;}
    .header-weather{
      display:flex;align-items:center;gap:8px;
      padding:.38rem .92rem;min-height:38px;
      background:var(--blue-light);border:1.5px solid var(--blue-border);border-radius:999px;
      font-family:'Outfit',sans-serif;font-size:.82rem;font-weight:700;color:var(--blue);
      white-space:nowrap;
    }
    .header-weather svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
    .nav-btn{
      display:inline-flex;align-items:center;gap:6px;
      padding:.44rem .95rem;border:1.5px solid var(--border-mid);border-radius:999px;
      background:rgba(255,255,255,.9);color:var(--muted);
      font-family:'Outfit',sans-serif;font-size:.8rem;font-weight:700;
      cursor:pointer;text-decoration:none;transition:all .18s;
      box-shadow:var(--shadow-xs);
    }
    .nav-btn:hover{border-color:var(--blue-border);color:var(--text2);background:var(--surface);}
    .nav-btn:focus-visible{outline:2px solid var(--blue);outline-offset:2px;}
    .nav-btn.danger{color:var(--red);border-color:var(--red-border);background:var(--red-light);}
    .nav-btn.danger:hover{border-color:var(--red);background:#FEE2E2;}
    .nav-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .online-pill{
      display:flex;align-items:center;gap:6px;padding:.28rem .75rem;
      background:var(--green-light);border:1px solid var(--green-border);border-radius:99px;
      font-family:'JetBrains Mono',monospace;font-size:.6rem;font-weight:700;
      letter-spacing:1px;text-transform:uppercase;color:var(--green);
    }
    .online-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 2s ease-in-out infinite;}
    @keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.7)}}

    /* Ã¢â€â‚¬Ã¢â€â‚¬ BODY LAYOUT Ã¢â€â‚¬Ã¢â€â‚¬ */
    .body{display:flex;flex:1;min-height:0;height:calc(100vh - 84px);overflow:hidden;}
    .header,.sidebar,.main-inner{animation:uiFade .45s ease both;}
    .sidebar{animation-delay:.08s;}
    .main-inner{animation-delay:.14s;}
    @keyframes uiFade{
      from{opacity:0;transform:translateY(10px);}
      to{opacity:1;transform:translateY(0);}
    }
    @media (prefers-reduced-motion: reduce){
      .header,.sidebar,.main-inner,.rcard,.filter-item,.user-greet{animation:none!important;transition:none!important;}
    }

    /* Ã¢â€â‚¬Ã¢â€â‚¬ SIDEBAR Ã¢â€â‚¬Ã¢â€â‚¬ */
    .sidebar {
      width: 300px;
      flex-shrink: 0;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 82px;
      align-self: flex-start;
      min-height: calc(100vh - 82px);
      height: auto;
      overflow: visible;
      box-shadow: inset -1px 0 0 rgba(0,0,0,.02);
    }
    .sidebar-top{
      padding:1.25rem 1.1rem .9rem;
      border-bottom:1px solid var(--border);
      background:linear-gradient(180deg,rgba(250,204,21,.24),rgba(255,255,255,0));
    }
    .sidebar-heading{font-weight:800;font-size:.88rem;color:var(--text);margin-bottom:2px;}
    .sidebar-sub{font-size:.72rem;color:var(--muted);}

    .filter-list {
      padding: .9rem .9rem;
      display: flex;
      flex-direction: column;
      gap: .4rem;
      flex: 1 1 auto;
      overflow: visible;
      max-height: none;
    }

    .filter-item{
      display:flex;align-items:center;gap:10px;
      padding:.75rem .95rem;border-radius:var(--r-md);
      border:1px solid var(--border);
      cursor:pointer;transition:all .18s ease;
      background:var(--surface2);
      box-shadow:none;
    }
    .filter-item:hover{
      background:var(--surface2);
      border-color:var(--amber-border);
      transform:translateX(2px);
    }
    .filter-item.active{
      background:#f1f5f9;
      border-color:var(--blue-border);
      box-shadow:var(--shadow-xs);
      transform:translateX(1px);
    }

    .fi-icon{
      width:34px;height:34px;border-radius:9px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
    }
    .fi-icon svg{width:17px;height:17px;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .fi-all    .fi-icon{background:#F1F5F9;} .fi-all    .fi-icon svg{stroke:var(--muted);}
    .fi-new    .fi-icon{background:var(--red-light);}    .fi-new    .fi-icon svg{stroke:var(--red);}
    .fi-sos    .fi-icon{background:var(--red-light);}    .fi-sos    .fi-icon svg{stroke:var(--red);}
    .fi-report .fi-icon{background:var(--blue-light);}   .fi-report .fi-icon svg{stroke:var(--blue);}
    .fi-verify .fi-icon{background:var(--amber-light);}  .fi-verify .fi-icon svg{stroke:var(--amber-dark);}
    .fi-disp   .fi-icon{background:var(--orange-light);} .fi-disp   .fi-icon svg{stroke:var(--orange);}
    .fi-res    .fi-icon{background:var(--green-light);}  .fi-res    .fi-icon svg{stroke:var(--green);}
    .fi-false  .fi-icon{background:#F1F5F9;}             .fi-false  .fi-icon svg{stroke:var(--muted);}
    .fi-all.active    .fi-icon{background:var(--amber-light);} .fi-all.active    .fi-icon svg{stroke:var(--amber-dark);}

    .fi-label{font-weight:600;font-size:.84rem;color:var(--text2);flex:1;}
    .filter-item.active .fi-label{color:var(--amber-deep);font-weight:800;}

    .fi-count{
      font-family:'JetBrains Mono',monospace;font-weight:700;font-size:.92rem;min-width:22px;text-align:right;
    }
    .fi-new .fi-count{color:var(--red);}
    .fi-sos .fi-count{color:var(--red);}
    .fi-report .fi-count{color:var(--blue);}
    .fi-verify .fi-count{color:var(--amber-dark);}
    .fi-disp .fi-count{color:var(--orange);}
    .fi-res .fi-count{color:var(--green);}
    .fi-false .fi-count{color:var(--muted);}
    .fi-all .fi-count{color:var(--muted);}

    .sidebar-footer{
      padding:1rem 1.1rem;border-top:1px solid var(--border);margin-top:auto;
      display:grid;gap:.55rem;
      background:linear-gradient(180deg, rgba(255,255,255,.2), rgba(255,255,255,0));
    }
    .rf-brand{display:flex;align-items:center;gap:.55rem;}
    .rf-logo{
      width:56px;height:48px;object-fit:contain;display:block;flex-shrink:0;
    }
    .rf-copy{min-width:0;}
    .rf-name{font-weight:800;font-size:.82rem;line-height:1.15;color:var(--text2);}
    .rf-sub{
      font-family:'JetBrains Mono',monospace;
      font-size:.56rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted2);
      margin-top:3px;
    }
    .rf-text{font-size:.7rem;color:var(--muted2);line-height:1.55;margin:0;}

    /* Ã¢â€â‚¬Ã¢â€â‚¬ MAIN Ã¢â€â‚¬Ã¢â€â‚¬ */
    .main{flex:1;min-width:0;height:calc(100vh - 84px);overflow-y:auto;overflow-x:hidden;display:flex;flex-direction:column;}
    .main-inner{padding:1.5rem 1.75rem 3rem;display:flex;flex-direction:column;gap:1.25rem;flex:1;}

    .main-header{
      display:flex;align-items:flex-end;justify-content:space-between;gap:1rem;flex-wrap:wrap;
      background:rgba(236,245,255,.82);
      border:1px solid var(--border);
      border-radius:16px;
      padding:1rem 1.1rem;
      box-shadow:var(--shadow-sm);
      backdrop-filter:blur(8px);
    }
    .main-head-copy{flex:1 1 360px;min-width:0;}
    .main-title{font-weight:900;font-size:1.55rem;letter-spacing:-.75px;line-height:1.1;}
    .main-sub{font-size:.78rem;color:var(--muted);margin-top:3px;}
    .main-quick-filters{display:flex;gap:.5rem;margin-top:.65rem;flex-wrap:wrap;}
    .quick-filter-btn{
      display:inline-flex;align-items:center;gap:7px;
      padding:.42rem .8rem;border-radius:999px;
      border:1.5px solid var(--border-mid);background:var(--surface);
      color:var(--text2);font-family:'Outfit',sans-serif;font-size:.74rem;font-weight:700;
      cursor:pointer;transition:all .18s;
    }
    .quick-filter-btn:hover{border-color:var(--amber-border);background:var(--amber-light);color:var(--amber-dark);}
    .quick-filter-btn.active{background:var(--amber-light);border-color:var(--amber-border);color:var(--amber-deep);box-shadow:0 6px 16px rgba(245,158,11,.22);}
    .quick-count{
      font-family:'JetBrains Mono',monospace;font-size:.72rem;font-weight:800;line-height:1;
      padding:2px 6px;border-radius:999px;background:rgba(255,255,255,.7);border:1px solid var(--border);
    }
    .main-head-tools{display:flex;flex:0 0 340px;flex-direction:column;align-items:flex-end;gap:.55rem;justify-content:flex-end;width:100%;max-width:360px;}
    .search-bar{
      width:100%;
      display:flex;align-items:center;gap:8px;
      background:#fff;
      border:1.5px solid var(--border-mid);
      border-radius:14px;
      padding:.4rem .65rem;
      box-shadow:var(--shadow-xs);
    }
    .search-bar svg{width:16px;height:16px;stroke:var(--muted);flex-shrink:0;}
    .search-input{
      flex:1;border:0;background:transparent;font-family:'Outfit',sans-serif;
      font-size:.85rem;color:var(--text);
      padding:.35rem 0;
      outline:none;
    }
    .search-go{
      border:0;border-radius:10px;padding:.36rem .7rem;
      background:linear-gradient(135deg,var(--blue),#1d4ed8);
      color:#fff;font-weight:800;font-size:.78rem;cursor:pointer;
      box-shadow:0 8px 18px rgba(29,78,216,.16);
      transition:transform .16s,box-shadow .16s,filter .16s;
    }
    .search-go:hover{transform:translateY(-1px);box-shadow:0 12px 22px rgba(29,78,216,.18);filter:saturate(1.05);}
    .search-clear{
      border:0;background:transparent;color:var(--muted2);font-weight:700;font-size:.78rem;cursor:pointer;padding:.2rem .3rem;
    }
    .search-clear:hover{color:var(--text2);}
    .main-datetime{
      display:flex;align-items:center;gap:10px;
      width:100%;padding:.62rem 1.05rem;min-height:66px;
      background:
        linear-gradient(180deg,rgba(255,255,255,.94),rgba(239,246,255,.96)) padding-box,
        linear-gradient(135deg,rgba(29,78,216,.95),rgba(59,130,246,.95)) border-box;
      border:1.5px solid transparent;border-radius:16px;
      color:var(--text2);white-space:nowrap;
      box-shadow:0 12px 24px rgba(15,23,42,.08), inset 0 1px 0 rgba(255,255,255,.75);
      transition:transform .2s ease, box-shadow .2s ease;
      backdrop-filter:blur(10px);
    }
    .main-datetime:hover{
      transform:translateY(-1px);
      box-shadow:0 16px 30px rgba(15,23,42,.11), inset 0 1px 0 rgba(255,255,255,.82);
    }
    .main-datetime svg{width:24px;height:18px;stroke:var(--blue);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
    .time-block{display:flex;flex-direction:column;line-height:1.05;min-width:0;}
    .clock-text{
      font-family:'Orbitron','JetBrains Mono',monospace;
      font-size:1.2rem;font-weight:700;letter-spacing:1.1px;color:var(--text2);
      text-shadow:none;
      overflow-wrap:anywhere;
    }
    .date-text{
      font-family:'JetBrains Mono',monospace;
      font-size:.66rem;font-weight:700;letter-spacing:.7px;color:var(--muted2);
      margin-top:4px;
      overflow-wrap:anywhere;
    }
    .user-greet{
      display:inline-flex;
      align-items:center;
      gap:.45rem;
      background:linear-gradient(145deg,#F8FBFF,#EEF5FF);
      border:1px solid var(--border-mid);
      border-radius:999px;
      padding:.42rem .9rem;
      font-size:.78rem;
      font-weight:700;
      color:var(--text2);
      white-space:nowrap;
      box-shadow:var(--shadow-xs);
      text-decoration:none;
      transition:transform .2s ease, color .2s ease, background .2s ease, border-color .2s ease, box-shadow .2s ease;
      will-change:transform;
    }
    .user-greet-icon{
      width:18px;height:18px;display:inline-flex;align-items:center;justify-content:center;
      border-radius:50%;
      background:var(--blue-light);
      border:1px solid var(--blue-border);
      color:var(--blue);
      flex-shrink:0;
      transition:all .2s ease;
    }
    .user-greet-icon svg{
      width:11px;height:11px;stroke:currentColor;fill:none;stroke-width:2;
      stroke-linecap:round;stroke-linejoin:round;
    }
    .user-greet:hover{
      color:#fff;
      background:linear-gradient(135deg,var(--blue),var(--red));
      border-color:transparent;
      box-shadow:0 8px 18px rgba(29,78,216,.28);
      transform:translateY(-1px) scale(1.02);
      animation:greetFloat .85s ease-in-out;
    }
    .user-greet:focus-visible{
      outline:none;
      box-shadow:0 0 0 3px rgba(29,78,216,.22), 0 8px 18px rgba(29,78,216,.22);
    }
    .user-greet:active{transform:translateY(0) scale(.99);}
    .user-greet span{
      color:var(--amber-deep);
      font-weight:800;
    }
    .act-btn[disabled]{
      opacity:.6;
      cursor:not-allowed;
      box-shadow:none;
    }
    .user-greet:hover .user-greet-icon{
      background:rgba(255,255,255,.2);
      border-color:rgba(255,255,255,.45);
      color:#fff;
    }
    .user-greet:hover span{color:#FDE047;}
    @keyframes greetFloat{
      0%{transform:translateY(0) scale(1);}
      50%{transform:translateY(-2px) scale(1.03);}
      100%{transform:translateY(-1px) scale(1.02);}
    }
    /* Notifications */
    .notif-stack{
      position:fixed;top:14px;right:14px;z-index:300;
      display:flex;flex-direction:column;gap:.6rem;max-width:340px;width:calc(100% - 28px);
      pointer-events:none;
    }
    .notif-card{
      pointer-events:auto;
      background:#fff;
      border:1.5px solid #dbe7ff;
      border-left:6px solid #1D4ED8;
      border-radius:14px;
      padding:.85rem 1rem;
      box-shadow:0 16px 34px rgba(15,23,42,.16);
      display:grid;gap:.3rem;
      transition:transform .15s ease, opacity .2s ease;
    }
    .notif-card.alert{border-left-color:#dc2626;}
    .notif-card.warn{border-left-color:#f59e0b;}
    .notif-title{font-weight:840;color:#0f1d3a;}
    .notif-msg{color:#1f2937;line-height:1.5;font-size:.94rem;}
    .notif-meta{font-size:.78rem;color:#6b7280;}
    .filter-label-bar{
      font-family:'JetBrains Mono',monospace;font-size:.6rem;font-weight:700;
      letter-spacing:2px;text-transform:uppercase;color:var(--muted);
      display:flex;align-items:center;gap:10px;
      position:sticky;top:0;z-index:8;
      background:transparent;
      padding:.35rem 0;
      backdrop-filter:blur(4px);
    }
    .filter-label-bar::after{content:'';flex:1;height:1px;background:var(--border);}
    .ops-grid{
      display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.85rem;
    }
    .ops-card{
      position:relative;overflow:hidden;
      padding:1rem 1rem .95rem;border-radius:18px;
      border:1.5px solid var(--border);
      background:linear-gradient(180deg,rgba(255,255,255,.82),rgba(240,247,255,.9));
      box-shadow:var(--shadow-sm);
    }
    .ops-card::before{
      content:'';position:absolute;inset:0 auto 0 0;width:4px;
      border-radius:18px 0 0 18px;background:var(--border-mid);
    }
    .ops-card.urgent::before{background:var(--red);}
    .ops-card.mine::before{background:var(--blue);}
    .ops-card.verify::before{background:var(--amber-dark);}
    .ops-card.resolved::before{background:var(--green);}
    .ops-kicker{
      font-family:'JetBrains Mono',monospace;font-size:.58rem;font-weight:700;
      letter-spacing:1.6px;text-transform:uppercase;color:var(--muted2);margin-bottom:.45rem;
    }
    .ops-value{font-size:1.55rem;line-height:1;font-weight:900;letter-spacing:-1px;color:var(--text);}
    .ops-label{margin-top:.45rem;font-size:.8rem;font-weight:700;color:var(--text2);}
    .ops-meta{margin-top:.2rem;font-size:.72rem;color:var(--muted);line-height:1.45;}

    /* Ã¢â€â‚¬Ã¢â€â‚¬ REPORT CARDS Ã¢â€â‚¬Ã¢â€â‚¬ */
    .report-list{display:flex;flex-direction:column;gap:1rem;}

    .rcard {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.1rem 1.2rem 1.1rem 1.2rem;
      box-shadow: 0 4px 18px rgba(15,23,42,0.07);
      transition: box-shadow .16s, border-color .16s, transform .16s;
      position: relative;
      overflow: hidden;
    }
    .rcard:hover {
      box-shadow: 0 8px 28px rgba(15,23,42,0.13);
      border-color: var(--blue-border);
      transform: translateY(-2px);
    }
    .rcard::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0; width: 3px;
      border-radius: 12px 0 0 12px;
    }
    .rcard.sev-High::before   { background: var(--red); }
    .rcard.sev-Medium::before { background: var(--amber); }
    .rcard.sev-Low::before    { background: var(--green); }
    .rcard-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.7rem;
      margin-bottom: 0.7rem;
    }
    .rcard-left { flex: 1; min-width: 0; }
    .rcard-type {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 6px;
      flex-wrap: wrap;
    }
    .type-stack { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
    .pill-row { display: flex; gap: 5px; flex-wrap: wrap; }
    .type-icon {
      width: 28px; height: 28px; border-radius: 8px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      background: var(--surface2); border: 1px solid var(--border);
      box-shadow: 0 2px 6px rgba(15,23,42,0.06);
    }
    .type-icon svg { width: 15px; height: 15px; }
    .type-name { font-weight: 700; font-size: 0.98rem; color: var(--text); }
    .rcard-meta {
      display: flex;
      gap: 0.7rem;
      flex-wrap: wrap;
      font-family: 'JetBrains Mono', monospace;
      font-size: .7rem;
      color: var(--muted);
    }
    .rcard-meta span { display: flex; align-items: center; gap: 4px; }
    .rcard-meta svg { width: 12px; height: 12px; }
    .cred-pill{
      display:inline-flex;align-items:center;gap:3px;
      font-family:'JetBrains Mono',monospace;font-size:.58rem;font-weight:700;
      padding:2px 7px;border-radius:99px;text-transform:uppercase;
    }
    .cred-high  {color:var(--green);background:var(--green-light);border:1px solid var(--green-border);}
    .cred-medium{color:var(--amber-dark);background:var(--amber-light);border:1px solid var(--amber-border);}
    .cred-low   {color:var(--red);background:var(--red-light);border:1px solid var(--red-border);}
    .trust-pill{
      display:inline-flex;align-items:center;gap:3px;
      font-family:'JetBrains Mono',monospace;font-size:.58rem;font-weight:700;
      padding:2px 7px;border-radius:99px;text-transform:uppercase;
      border:1px solid transparent;
    }
    .trust-trustworthy{color:var(--green);background:var(--green-light);border-color:var(--green-border);}
    .trust-neutral{color:var(--blue);background:var(--blue-light);border-color:var(--blue-border);}
    .trust-verify{color:var(--amber-dark);background:var(--amber-light);border-color:var(--amber-border);}
    .trust-no{color:var(--red);background:var(--red-light);border-color:var(--red-border);}
    .prank-warning{
      flex-basis:100%;
      font-size:.72rem;
      color:var(--red);
      font-weight:700;
      margin-top:2px;
    }

    .rcard-meta{
      display:flex;gap:1rem;flex-wrap:wrap;
      font-family:'JetBrains Mono',monospace;font-size:.71rem;color:var(--muted);
    }
    .rcard-meta span{display:flex;align-items:center;gap:5px;}
    .rcard-meta svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .tag-list{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.45rem;}
    .tag-pill{
      display:inline-flex;align-items:center;gap:5px;
      padding:.38rem .7rem;border-radius:999px;
      border:1.2px solid var(--border-mid);
      background:rgba(226,232,255,.7);
      color:var(--blue);
      font-family:'JetBrains Mono',monospace;
      font-size:.68rem;font-weight:800;letter-spacing:.5px;text-transform:uppercase;
    }
    /* image modal */
    .img-modal{
      position:fixed;inset:0;z-index:400;
      display:flex;align-items:center;justify-content:center;
      background:rgba(15,23,42,.55);
      backdrop-filter:blur(6px);
      padding:1.2rem;
      opacity:0;pointer-events:none;
      transition:opacity .18s ease;
    }
    .img-modal.show{opacity:1;pointer-events:auto;}
    .img-modal-card{
      width:min(900px,96vw);
      background:#fff;
      border-radius:16px;
      box-shadow:0 24px 48px rgba(0,0,0,.24);
      overflow:hidden;
      display:grid;
      grid-template-columns:1.2fr 1fr;
      gap:0;
      position:relative;
    }
    @media(max-width:900px){.img-modal-card{grid-template-columns:1fr;}}
    .img-preview-wrap{
      background:#0b1224;
      display:flex;align-items:center;justify-content:center;
      min-height:340px;
      position:relative;
    }
    .img-preview-wrap img{max-width:100%;max-height:80vh;object-fit:contain;}
    .img-nav-btn{
      position:absolute;top:50%;transform:translateY(-50%);
      width:42px;height:42px;border-radius:50%;
      border:none;background:rgba(15,23,42,.65);color:#fff;
      cursor:pointer;font-weight:900;font-size:1.1rem;
      display:flex;align-items:center;justify-content:center;
    }
    .img-nav-btn.prev{left:12px;} .img-nav-btn.next{right:12px;}
    .img-nav-btn:disabled{opacity:.35;cursor:not-allowed;}
    .img-meta{
      padding:1.05rem 1.2rem;
      display:grid;gap:.65rem;align-content:start;
    }
    .img-meta h4{margin:0;font-size:1.05rem;font-weight:820;letter-spacing:-.2px;color:#0f172a;}
    .img-meta p{margin:0;color:#1f2937;font-size:.92rem;line-height:1.5;}
    .img-meta label{font-size:.78rem;font-weight:800;color:#475569;letter-spacing:.3px;text-transform:uppercase;}
    .img-meta textarea{
      width:100%;min-height:110px;border:1.5px solid #cbd5e1;border-radius:12px;
      padding:.75rem;font-family:'Outfit',sans-serif;font-size:.92rem;color:#0f172a;resize:vertical;
      background:#f8fafc;
    }
    .img-actions{display:flex;flex-wrap:wrap;gap:.55rem;}
    .img-btn{
      padding:.65rem .95rem;border-radius:12px;border:1.5px solid #cbd5e1;
      background:#fff;font-weight:800;font-size:.9rem;cursor:pointer;transition:.15s;
      display:inline-flex;align-items:center;gap:8px;color:#0f172a;
    }
  .img-btn:hover{transform:translateY(-1px);}
  .img-close{position:absolute;top:12px;right:12px;border:none;background:rgba(0,0,0,.55);color:#fff;border-radius:50%;width:34px;height:34px;cursor:pointer;font-weight:900;}

    /* mic permission modal */
    .perm-modal{
      position:fixed;inset:0;z-index:390;
      background:rgba(15,23,42,.45);
      backdrop-filter:blur(6px);
      display:flex;align-items:center;justify-content:center;
      opacity:0;pointer-events:none;transition:opacity .18s ease;
      padding:1rem;
    }
    .perm-modal.show{opacity:1;pointer-events:auto;}
    .perm-card{
      background:#fff;border-radius:16px;box-shadow:0 18px 42px rgba(0,0,0,.24);
      max-width:420px;width:95%;padding:1.35rem 1.45rem;display:grid;gap:.65rem;
    }
    .perm-card h3{margin:0;font-size:1.1rem;font-weight:840;color:#0f172a;}
    .perm-card p{margin:0;color:#1f2937;line-height:1.6;font-size:.95rem;}
    .perm-actions{display:flex;gap:.6rem;justify-content:flex-end;flex-wrap:wrap;}
    .perm-btn{
      padding:.55rem .95rem;border-radius:12px;border:1.5px solid #cbd5e1;
      background:#fff;font-weight:800;font-size:.9rem;cursor:pointer;transition:.15s;
    }
    .perm-btn.primary{background:linear-gradient(135deg,#2563EB,#1D4ED8);color:#fff;border-color:transparent;box-shadow:0 8px 18px rgba(37,99,235,.22);}
    .perm-btn:hover{transform:translateY(-1px);}

    .rcard-right{display:flex;align-items:center;gap:9px;flex-shrink:0;}
    .status-pill{
      padding:.35rem 1rem;border-radius:999px;
      font-family:'JetBrains Mono',monospace;font-size:.64rem;font-weight:800;
      letter-spacing:.6px;text-transform:uppercase;white-space:nowrap;
      box-shadow:var(--shadow-xs);
    }
    .sp-new        {background:var(--red-light);color:var(--red);border:1px solid var(--red-border);}
    .sp-verifying  {background:var(--amber-light);color:var(--amber-dark);border:1px solid var(--amber-border);}
    .sp-dispatched {background:var(--orange-light);color:var(--orange);border:1px solid var(--orange-border);}
    .sp-resolved   {background:var(--green-light);color:var(--green);border:1px solid var(--green-border);}
    .sp-false-report{background:#F5F0E8;color:var(--muted);border:1px solid var(--border-mid);}

    .photo-stack{display:flex;gap:6px;align-items:center;}
    .photo-thumb{width:48px;height:48px;border-radius:10px;object-fit:cover;border:1.5px solid var(--border);box-shadow:var(--shadow-sm);cursor:pointer;}
    .photo-more{padding:.4rem .6rem;border:1.5px dashed var(--border);border-radius:10px;font-weight:800;color:var(--muted2);background:#fff;}
    button.photo-more{cursor:pointer;font:inherit;}
    .photo-count{font-size:.78rem;font-weight:700;color:var(--muted2);}

    .rcard-loc{
      display:flex;gap:.9rem;flex-wrap:wrap;margin-bottom:.8rem;
      font-family:'Outfit',sans-serif;font-size:.9rem;color:var(--muted);
    }
    .rcard-loc span{display:flex;align-items:center;gap:4px;}
    .rcard-loc svg{width:11px;height:11px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .rcard-map{
      position:relative;
      margin-bottom:.9rem;
      border:1px solid var(--border);
      border-radius:12px;
      overflow:hidden;
      background:var(--surface2);
    }
    .rcard-map-head{
      display:flex;align-items:center;justify-content:flex-start;gap:.6rem;
      padding:.5rem .75rem .9rem;
      border-bottom:1px solid var(--border);
      font-family:'JetBrains Mono',monospace;
      font-size:.62rem;font-weight:700;color:var(--muted);
      letter-spacing:.6px;text-transform:uppercase;
      background:var(--surface);
    }
    .map-open{
      position:absolute;top:10px;right:10px;
      padding:.5rem .9rem;border-radius:10px;
      background:linear-gradient(135deg,#2563EB,#1D4ED8);
      color:#fff;border:none;font-family:'Outfit',sans-serif;font-weight:800;font-size:.8rem;
      cursor:pointer;box-shadow:0 6px 16px rgba(29,78,216,.18);
      transition:transform .12s,box-shadow .12s;
      text-decoration:none;
    }
    .map-open:hover{transform:translateY(-1px);box-shadow:0 10px 22px rgba(29,78,216,.22);}
    .rcard-map-canvas{
      width:100%;
      height:clamp(210px, 33vw, 320px);
      border:0;
      display:block;
      background:#F3F4F6;
    }

    .rcard-desc{
      font-size:.93rem;color:var(--text);line-height:1.6;
      background:var(--surface2);padding:.85rem 1rem;
      border-radius:var(--r-md);border:1px solid var(--border);
      margin-bottom:.95rem;
    }
    .ownership-bar{
      display:flex;align-items:center;justify-content:space-between;gap:.85rem;
      padding:.85rem 1rem;margin-bottom:1rem;border-radius:16px;
      border:1px solid var(--border);background:rgba(255,255,255,.85);
      }
    .ownership-main{display:flex;align-items:flex-start;gap:.65rem;min-width:0;}
    .ownership-icon{
      width:32px;height:32px;border-radius:10px;display:flex;align-items:center;justify-content:center;
      flex-shrink:0;border:1px solid transparent;background:var(--surface2);color:var(--text2);
    }
    .ownership-icon svg{
      width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:1.8;
      stroke-linecap:round;stroke-linejoin:round;
    }
    .ownership-copy{min-width:0;}
    .ownership-title{font-size:.8rem;font-weight:800;color:var(--text);line-height:1.2;}
    .ownership-sub{margin-top:2px;font-size:.71rem;line-height:1.45;color:var(--muted);}
    .ownership-tag{
      flex-shrink:0;align-self:center;padding:.26rem .62rem;border-radius:999px;
      font-family:'JetBrains Mono',monospace;font-size:.58rem;font-weight:700;letter-spacing:1px;
      text-transform:uppercase;border:1px solid var(--border);color:var(--muted);background:var(--surface);
    }
    .ownership-bar.mine{
      border-color:var(--blue-border);
      background:linear-gradient(135deg,rgba(219,234,254,.7),rgba(255,255,255,.85));
    }
    .ownership-bar.mine .ownership-icon{
      color:var(--blue);background:var(--blue-light);border-color:var(--blue-border);
    }
    .ownership-bar.mine .ownership-tag{
      color:var(--blue);background:var(--blue-light);border-color:var(--blue-border);
    }
    .ownership-bar.open{
      border-color:var(--amber-border);
      background:linear-gradient(135deg,rgba(254,252,232,.8),rgba(255,255,255,.85));
    }
    .ownership-bar.open .ownership-icon{
      color:var(--amber-deep);background:var(--amber-light);border-color:var(--amber-border);
    }
    .ownership-bar.open .ownership-tag{
      color:var(--amber-deep);background:var(--amber-light);border-color:var(--amber-border);
    }

    .rcard-actions{display:flex;gap:.55rem;flex-wrap:wrap;}
    .act-btn{
      display:inline-flex;align-items:center;gap:5px;
      padding:.5rem 1.05rem;border-radius:12px;
      border:1.5px solid var(--border-mid);background:var(--surface);
      color:var(--text2);font-family:'Outfit',sans-serif;font-weight:700;font-size:.8rem;
      cursor:pointer;transition:all .18s;
      }
    .act-btn svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    .act-btn:hover{border-color:var(--amber-border);color:var(--amber-dark);background:var(--amber-light);}
    .act-btn.primary{
      background:linear-gradient(135deg,var(--amber),var(--amber-dark));
      border-color:transparent;color:#fff;
    }
    .act-btn.primary:hover{box-shadow:0 4px 16px rgba(245,158,11,.34);transform:translateY(-1px);}
    .act-btn.success{background:var(--green);border-color:var(--green);color:#fff;}
    .act-btn.success:hover{box-shadow:0 4px 16px rgba(5,150,105,.28);transform:translateY(-1px);}
    .act-btn.danger-act{color:var(--red);border-color:var(--red-border);}
    .act-btn.danger-act:hover{background:var(--red-light);border-color:var(--red);}
    .act-btn.call-act{background:linear-gradient(135deg,var(--blue),var(--indigo));border-color:transparent;color:#fff;}
    .act-btn.call-act:hover{box-shadow:0 4px 16px rgba(29,78,216,.28);transform:translateY(-1px);}
    .act-btn.utility{background:rgba(255,255,255,.88);color:var(--muted);border-color:var(--border);}
    .act-btn.utility:hover{color:var(--text2);border-color:var(--border-mid);background:var(--surface2);}

    /* empty state */
    .empty{
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      padding:4.5rem 2rem;text-align:center;
      background:linear-gradient(180deg,#F3F8FF,#EAF2FF);
      border:1.5px solid var(--border);border-radius:var(--r-xl);
    }
    .empty-icon{
      width:58px;height:58px;border-radius:14px;
      background:var(--surface2);border:1.5px solid var(--border);
      display:flex;align-items:center;justify-content:center;margin-bottom:1.1rem;
    }
    .empty-icon svg{width:26px;height:26px;stroke:var(--muted2);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
    .empty h3{font-weight:700;font-size:.97rem;color:var(--text2);margin-bottom:.35rem;}
    .empty p{font-size:.82rem;color:var(--muted);line-height:1.6;max-width:280px;}

    /* flash on new report */
    @keyframes flashGreen{
      0%{border-color:var(--green);box-shadow:0 0 0 3px rgba(5,150,105,.22);}
      100%{border-color:var(--border);box-shadow:var(--shadow-sm);}
    }
    .card-flash{animation:flashGreen 1.6s ease;}

    /* toast */
    .toast{
      position:fixed;bottom:1.75rem;right:1.75rem;z-index:999;
      display:flex;align-items:flex-start;gap:10px;
      padding:.9rem 1.05rem;background:var(--surface);
      border:1px solid var(--border-mid);border-left:3px solid var(--green);
      border-radius:var(--r-md);box-shadow:var(--shadow-xl);max-width:300px;
      transform:translateX(calc(100% + 2rem));
      transition:transform .35s cubic-bezier(.34,1.56,.64,1);
    }
    .toast.show{transform:translateX(0);}
    .toast svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;margin-top:1px;}
    .toast strong{display:block;font-weight:700;font-size:.82rem;color:var(--text);margin-bottom:1px;}
    .toast span{font-size:.74rem;color:var(--text2);}

    /* edit modal */
    .edit-backdrop{
      position:fixed;inset:0;z-index:950;
      background:rgba(24,18,10,.34);
      backdrop-filter:blur(2px);
      display:none;align-items:center;justify-content:center;
      padding:1rem;
    }
    .edit-backdrop.show{display:flex;}
    .edit-modal{
      width:min(560px,100%);
      background:var(--surface);
      border:1.5px solid var(--border);
      border-radius:var(--r-lg);
      box-shadow:var(--shadow-xl);
      overflow:hidden;
    }
    .edit-head{
      display:flex;align-items:center;justify-content:space-between;gap:.75rem;
      padding:1rem 1.1rem;
      border-bottom:1px solid var(--border);
      background:var(--surface2);
    }
    .edit-title{font-size:.92rem;font-weight:800;color:var(--text);}
    .edit-close{
      border:1px solid var(--border-mid);background:var(--surface);color:var(--text2);
      border-radius:8px;padding:.3rem .55rem;cursor:pointer;font-weight:700;
    }
    .edit-close:hover{background:var(--amber-light);border-color:var(--amber-border);color:var(--amber-dark);}
    .edit-form{padding:1rem 1.1rem 1.1rem;display:grid;gap:.78rem;}
    .edit-field label{
      display:block;margin-bottom:.3rem;font-size:.72rem;font-weight:700;color:var(--text2);
      font-family:'JetBrains Mono',monospace;letter-spacing:.45px;text-transform:uppercase;
    }
    .edit-field input{
      width:100%;padding:.64rem .72rem;border-radius:10px;
      border:1.5px solid var(--border);background:var(--bg);color:var(--text);
      font-family:'Outfit',sans-serif;font-size:.88rem;
    }
    .edit-field input:focus{outline:none;border-color:var(--amber);box-shadow:0 0 0 3px rgba(245,158,11,.13);background:var(--surface);}
    .edit-actions{display:flex;justify-content:flex-end;gap:.55rem;padding:.2rem 1.1rem 1.1rem;}
    .edit-btn{
      border:1.5px solid var(--border-mid);background:var(--surface);color:var(--text2);
      border-radius:10px;padding:.5rem .9rem;cursor:pointer;font-weight:700;font-size:.8rem;
    }
    .edit-btn:hover{background:var(--amber-light);border-color:var(--amber-border);color:var(--amber-dark);}
    .edit-btn.save{background:linear-gradient(135deg,var(--amber),var(--amber-dark));border-color:transparent;color:#fff;}
    .edit-btn.save:hover{box-shadow:0 4px 14px rgba(245,158,11,.3);}

    /* dispatcher profile modal */
    .profile-backdrop{
      position:fixed;inset:0;z-index:960;
      background:rgba(15,23,42,.35);
      backdrop-filter:blur(3px);
      display:none;align-items:center;justify-content:center;
      padding:1rem;
    }
    .profile-backdrop.show{display:flex;animation:fadeIn .2s ease;}
    .profile-modal{
      width:min(620px,100%);
      background:linear-gradient(180deg,#F6FAFF,#FFFFFF);
      border:1.5px solid var(--border);
      border-radius:16px;
      box-shadow:var(--shadow-xl);
      overflow:hidden;
    }
    .profile-head{
      display:flex;align-items:center;justify-content:space-between;gap:.75rem;
      padding:1rem 1.1rem;
      border-bottom:1px solid var(--border);
      background:var(--surface2);
    }
    .profile-title{font-size:.98rem;font-weight:800;color:var(--text);}
    .profile-sub{font-size:.74rem;color:var(--muted);margin-top:2px;}
    .profile-close{
      border:1px solid var(--border-mid);background:var(--surface);color:var(--text2);
      border-radius:8px;padding:.32rem .58rem;cursor:pointer;font-weight:700;
    }
    .profile-close:hover{background:var(--amber-light);border-color:var(--amber-border);color:var(--amber-dark);}
    .profile-form{padding:1rem 1.1rem 1.1rem;display:grid;grid-template-columns:1fr 1fr;gap:.8rem;}
    .profile-field{display:flex;flex-direction:column;gap:.35rem;}
    .profile-field.full{grid-column:1 / -1;}
    .profile-field label{
      font-size:.7rem;font-weight:700;color:var(--text2);
      font-family:'JetBrains Mono',monospace;letter-spacing:.42px;text-transform:uppercase;
    }
    .profile-field input{
      width:100%;padding:.66rem .75rem;border-radius:10px;
      border:1.5px solid var(--border);background:var(--bg);color:var(--text);
      font-family:'Outfit',sans-serif;font-size:.86rem;
      transition:border-color .18s ease, box-shadow .18s ease;
    }
    .profile-field input:focus{
      outline:none;border-color:var(--blue);background:var(--surface);
      box-shadow:0 0 0 3px rgba(29,78,216,.12);
    }
    .profile-field input[disabled]{opacity:.75;cursor:not-allowed;}
    .profile-actions{
      grid-column:1 / -1;display:flex;justify-content:flex-end;gap:.55rem;margin-top:.15rem;
    }
    .profile-btn{
      border:1.5px solid var(--border-mid);background:var(--surface);color:var(--text2);
      border-radius:10px;padding:.5rem .9rem;cursor:pointer;font-weight:700;font-size:.8rem;
    }
    .profile-btn:hover{background:var(--amber-light);border-color:var(--amber-border);color:var(--amber-dark);}
    .profile-btn.save{background:linear-gradient(135deg,var(--blue),var(--red));border-color:transparent;color:#fff;}
    .profile-btn.save:hover{box-shadow:0 4px 14px rgba(29,78,216,.28);}

    /* dispatch team selection modal */
    .dispatch-backdrop{
      position:fixed;inset:0;z-index:970;
      background:rgba(15,23,42,.4);
      backdrop-filter:blur(4px);
      display:none;align-items:center;justify-content:center;
      padding:1rem;
    }
    .dispatch-backdrop.show{display:flex;animation:fadeIn .2s ease;}
    .dispatch-modal{
      width:min(480px,100%);
      background:linear-gradient(180deg,#FFFFFF,#F8FAFC);
      border:1.5px solid var(--border);
      border-radius:16px;
      box-shadow:var(--shadow-xl);
      overflow:hidden;
    }
    .dispatch-head{
      display:flex;flex-direction:column;gap:.5rem;
      padding:1.2rem 1.3rem;
      border-bottom:1.5px solid var(--border);
      background:linear-gradient(135deg,rgba(29,78,216,.03),rgba(220,38,38,.03));
    }
    .dispatch-title{font-size:.95rem;font-weight:800;color:var(--text);}
    .dispatch-subtitle{font-size:.78rem;color:var(--muted);line-height:1.4;}
    .dispatch-content{
      padding:1.3rem;
      display:flex;flex-direction:column;gap:.8rem;
    }
    .team-option{
      display:flex;align-items:center;gap:.8rem;
      padding:.85rem 1rem;
      border:1.5px solid var(--border);
      border-radius:12px;
      cursor:pointer;
      transition:all .2s ease;
      background:var(--surface);
    }
    .team-option:hover{
      border-color:var(--blue);
      background:var(--green-light);
      box-shadow:0 2px 8px rgba(29,78,216,.15);
    }
    .team-option input[type="radio"]{
      cursor:pointer;
      width:18px;height:18px;accent-color:var(--blue);
    }
    .team-option label{
      flex:1;cursor:pointer;display:flex;flex-direction:column;gap:.2rem;
      font-weight:600;color:var(--text);
      font-size:.88rem;
    }
    .team-option small{
      font-weight:500;color:var(--muted);font-size:.75rem;
    }
    .dispatch-actions{
      display:flex;justify-content:flex-end;gap:.6rem;
      padding:0 1.3rem 1.3rem;
      border-top:1px solid var(--border);
      background:var(--surface);
    }
    .dispatch-btn{
      border:1.5px solid var(--border-mid);
      background:var(--surface);
      color:var(--text2);
      border-radius:10px;
      padding:.5rem 1rem;
      cursor:pointer;
      font-weight:700;
      font-size:.8rem;
      transition:all .2s ease;
    }
    .dispatch-btn:hover{
      background:var(--amber-light);
      border-color:var(--amber-border);
      color:var(--amber-dark);
    }
    .dispatch-btn.confirm{
      background:linear-gradient(135deg,var(--blue),var(--green));
      border-color:transparent;
      color:#fff;
    }
    .dispatch-btn.confirm:hover{
      box-shadow:0 4px 14px rgba(29,78,216,.3);
    }
    .dispatch-btn.confirm:disabled{
      opacity:.6;
      cursor:not-allowed;
    }

    @media(max-width:1024px){
      .header{padding:0 .95rem;height:72px}
      .body{height:calc(100vh - 72px);}
      .sidebar{top:72px;height:calc(100vh - 72px);min-height:calc(100vh - 72px);}
      .main{height:calc(100vh - 72px);}
      .main-inner{padding:1rem 1rem 2rem}
      .sidebar{width:220px}
      .rcard{padding:1.1rem 1.05rem}
    }
    @media(max-width:768px){
      .ops-grid{grid-template-columns:repeat(2,minmax(0,1fr));}
      body{overflow:auto;height:auto;}
      .body{flex-direction:column;}
      .sidebar{width:100%;height:auto;min-height:0;position:relative;top:0;align-self:stretch;overflow:visible;}
      .sidebar-top,.sidebar-footer{padding:.9rem .85rem}
      .filter-list{flex-direction:row;flex-wrap:wrap;padding:.6rem;}
      .filter-item{flex:1;min-width:124px;padding:.65rem .72rem}
      .main{overflow:visible;}
      .main-inner{padding:.85rem .75rem 1.5rem}
      .main-header{padding:.85rem .9rem;align-items:stretch;}
      .main-title{font-size:1.3rem}
      .header-right{gap:.4rem;flex-wrap:wrap;justify-content:flex-end}
      .nav-btn{padding:.34rem .62rem;font-size:.72rem}
      .rcard-top{flex-direction:column;align-items:stretch}
      .rcard-right{justify-content:flex-start}
      .rcard-loc{gap:.55rem}
      .rcard-map-canvas{height:250px;}
      .main-head-copy,.main-head-tools{flex-basis:100%;max-width:none;}
      .main-head-tools{align-items:stretch;}
    }
    @media(max-width:520px){
      .ops-grid{grid-template-columns:1fr;}
      .ops-card{padding:.9rem;border-radius:16px;}
      .header{height:auto;padding:.62rem .65rem;align-items:flex-start;gap:.6rem;flex-direction:column}
      .header-right{width:100%}
      .brand-name{font-size:.9rem}
      .filter-item{min-width:46%}
      .fi-icon{width:30px;height:30px}
      .fi-label{font-size:.78rem}
      .rcard{padding:.92rem .82rem}
      .ownership-bar{flex-direction:column;align-items:stretch}
      .ownership-tag{align-self:flex-start}
      .main-header{padding:.9rem .8rem;border-radius:18px;}
      .main-title{font-size:1.15rem}
      .main-sub{font-size:.74rem;line-height:1.45;}
      .main-quick-filters{gap:.45rem;}
      .quick-filter-btn{flex:1 1 calc(50% - .25rem);justify-content:center;min-width:0;}
      .main-datetime{padding:.68rem .85rem;min-height:unset;gap:.7rem;white-space:normal;}
      .main-datetime svg{width:20px;height:20px;}
      .clock-text{font-size:1rem;letter-spacing:.7px;}
      .date-text{font-size:.62rem;letter-spacing:.5px;}
      .rcard-type{gap:6px}
      .type-name{font-size:.9rem}
      .rcard-meta{font-size:.66rem;gap:.58rem}
      .status-pill{font-size:.56rem}
      .edit-actions{flex-direction:column}
      .edit-btn{width:100%;text-align:center}
      .profile-form{grid-template-columns:1fr;}
      .profile-actions{flex-direction:column}
      .profile-btn{width:100%;text-align:center}
      .toast{left:.5rem;right:.5rem;max-width:none;width:auto}
      .sidebar-footer{gap:.45rem;padding:.85rem .8rem 1rem;}
      .rf-brand{align-items:center;gap:.5rem;}
      .rf-copy,.rf-text{min-width:0;}
      .rf-text{font-size:.66rem;line-height:1.45;overflow-wrap:anywhere;}
      .user-greet{
        width:100%;
        justify-content:center;
        padding:.5rem .9rem;
      }
      .user-greet-icon{width:20px;height:20px;}
      .filter-label-bar{top:-1px;}
      .rf-logo{width:48px;height:40px;}
      .rf-name{font-size:.76rem;}
    }

    /* modern polish */
    body::before{
      content:'';
      position:fixed; inset:0; pointer-events:none; z-index:0;
      background:
        linear-gradient(rgba(148,163,184,.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(148,163,184,.06) 1px, transparent 1px);
      background-size: 34px 34px;
      mask-image: radial-gradient(circle at center, rgba(0,0,0,.92), rgba(0,0,0,.28));
    }
    .header,.body{position:relative;z-index:1}
    .header{
      height:90px;
      background:rgba(236,245,255,.76);
      border-bottom:1px solid rgba(154,188,232,.6);
      box-shadow:0 18px 40px rgba(15,23,42,.08);
    }
    .brand-logo{filter:drop-shadow(0 10px 16px rgba(29,78,216,.08))}
    .header-weather,.online-pill,.nav-btn,.user-greet{
      box-shadow: var(--shadow-sm);
    }
    .sidebar{
      background:
        linear-gradient(180deg, rgba(220,235,255,.92), rgba(232,242,255,.86)),
        linear-gradient(180deg, rgba(250,204,21,.10), transparent 42%);
      border-right:1px solid rgba(154,188,232,.6);
      box-shadow: inset -1px 0 0 rgba(255,255,255,.55);
    }
    .sidebar-top{
      padding:1.35rem 1.15rem 1rem;
      background:linear-gradient(180deg, rgba(250,204,21,.20), rgba(255,255,255,0));
    }
    .filter-list{padding:.85rem}
    .filter-item{
      border-radius:16px;
      background:rgba(255,255,255,.68);
      box-shadow: 0 8px 18px rgba(15,23,42,.05);
      backdrop-filter: blur(10px);
    }
    .filter-item.active{
      background:linear-gradient(135deg, rgba(250,204,21,.34), rgba(255,255,255,.76));
      box-shadow:0 16px 30px rgba(15,23,42,.10);
    }
    .main-inner{
      padding:1.65rem 1.8rem 3rem;
      gap:1.35rem;
    }
    .main-header{
      padding:1.15rem 1.2rem;
      border-radius:22px;
      background:rgba(255,255,255,.58);
      box-shadow:0 16px 38px rgba(15,23,42,.08);
      backdrop-filter: blur(14px);
    }
    .main-title{font-size:1.7rem}
    .quick-filter-btn{
      border-radius:999px;
      padding:.5rem .92rem;
      box-shadow: var(--shadow-xs);
    }
    .rcard{
      border-radius:24px;
      padding:1.45rem 1.55rem;
      background:linear-gradient(180deg, rgba(255,255,255,.94), rgba(244,248,255,.92));
      box-shadow:0 16px 34px rgba(15,23,42,.08);
      backdrop-filter: blur(10px);
    }
    .rcard:hover{transform:translateY(-3px); box-shadow:0 22px 44px rgba(15,23,42,.12)}
    .type-icon,.photo-thumb,.rcard-map,.rcard-desc,.act-btn,.edit-modal,.profile-modal{
      box-shadow: var(--shadow-xs);
    }
    .rcard-desc{
      background:linear-gradient(180deg, rgba(239,246,255,.72), rgba(231,240,255,.8));
      border-radius:16px;
    }
    .act-btn{
      border-radius:12px;
      padding:.5rem .95rem;
    }
    .empty{
      border-radius:24px;
      background:linear-gradient(180deg, rgba(243,248,255,.92), rgba(234,242,255,.92));
      box-shadow:0 16px 30px rgba(15,23,42,.06);
    }
    @media(max-width:1024px){
      .main-inner{padding:1rem 1rem 2rem}
      .header{height:78px}
    }
  
    /* Web call mini panel */
    .webcall-panel{
      position:fixed;bottom:18px;right:20px;z-index:400;
      width:320px;max-width:90vw;
      background:rgba(255,255,255,.96);border:1.5px solid var(--border);border-radius:16px;
      box-shadow:0 18px 44px rgba(15,23,42,.18);
      padding:14px 16px;backdrop-filter:blur(10px) saturate(140%);
      display:flex;flex-direction:column;gap:10px;
    }
    .webcall-panel.hidden{display:none;}
    .webcall-top{display:flex;align-items:center;gap:10px;}
    .webcall-ico{
      width:36px;height:36px;border-radius:12px;
      display:flex;align-items:center;justify-content:center;
      background:linear-gradient(135deg,rgba(29,78,216,.12),rgba(29,78,216,.2));
      border:1px solid var(--blue-border);color:var(--blue);
    }
    .webcall-ico svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.8;}
    .webcall-meta{flex:1;min-width:0;}
    .webcall-title{font-weight:800;font-size:.92rem;color:var(--text);}
    .webcall-sub{font-size:.78rem;color:var(--muted);}
    .webcall-status{font-family:'JetBrains Mono',monospace;font-size:.74rem;color:var(--muted2);}
    .webcall-actions{display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;}
    .webcall-btn{padding:.45rem .9rem;border-radius:12px;border:1px solid var(--border-mid);font-weight:700;font-size:.82rem;cursor:pointer;}
    .webcall-btn.primary{background:linear-gradient(135deg,var(--blue),var(--indigo));color:#fff;border-color:transparent;}
    .webcall-btn.danger{background:var(--orange-light);color:var(--red);border-color:var(--orange-border);}
    .webcall-btn:disabled{opacity:.6;cursor:not-allowed;}
    @media(max-width:520px){.webcall-panel{left:10px;right:10px;width:auto;}}
</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <div class="brand" aria-label="Smart Verification System">
    <img class="brand-logo" src="/images/logo.png" alt="MDRRMO SVS Logo">
    <div class="brand-text">
      <div class="brand-name">SVS</div>
      <div class="brand-sub">Smart Verification System</div>
    </div>
  </div>
  <div class="header-right">
    <div class="header-weather" id="weatherText">
      <svg viewBox="0 0 24 24"><path d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z"/></svg>
      Loading weather...
    </div>
    <div class="online-pill"><div class="online-dot"></div>Live</div>
    <a class="nav-btn" href="/dispatcher/reset" target="_blank" rel="noopener">Reset Password</a>
    <form method="post" action="/dispatcher/logout" style="margin:0" id="dispatcherLogoutForm">
      <button class="nav-btn danger" type="submit">Logout</button>
    </form>
    <% if (currentUser && currentUser.role === 'admin') { %>
      <a class="nav-btn" href="/admin">Admin Panel</a>
    <% } %>
  </div>
</header>

<div class="body">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-top">
      <div class="sidebar-heading">Report Queue</div>
      <div class="sidebar-sub">Filter by status</div>
    </div>

    <div class="filter-list">

      <div class="filter-item fi-all active" onclick="setFilter('all',this)">
        <div class="fi-icon">
          <!-- Heroicon: queue-list -->
          <svg viewBox="0 0 24 24"><path d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
        </div>
        <span class="fi-label">All Reports</span>
        <span class="fi-count" id="cAll">0</span>
      </div>

      <div class="filter-item fi-new" onclick="setFilter('new',this)">
        <div class="fi-icon">
          <!-- Heroicon: exclamation-circle -->
          <svg viewBox="0 0 24 24"><path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
        </div>
        <span class="fi-label">New</span>
        <span class="fi-count" id="cNew">0</span>
      </div>

      <div class="filter-item fi-disp" onclick="setFilter('assigned',this)">
        <div class="fi-icon">
          <!-- Heroicon: rectangle stack -->
          <svg viewBox="0 0 24 24"><path d="M4.5 8.25h15m-15 4.5h15M5.25 6A1.5 1.5 0 0 1 6.75 4.5h10.5A1.5 1.5 0 0 1 18.75 6v12a1.5 1.5 0 0 1-1.5 1.5H6.75a1.5 1.5 0 0 1-1.5-1.5V6Z"/></svg>
        </div>
        <span class="fi-label">Assigned to me</span>
        <span class="fi-count" id="cAssigned">0</span>
      </div>

      <div class="filter-item fi-verify" onclick="setFilter('verifying',this)">
        <div class="fi-icon">
          <!-- Heroicon: phone -->
          <svg viewBox="0 0 24 24"><path d="M2.25 6.338c0 7.5 6.089 13.587 13.589 13.587l.682-.002a1.124 1.124 0 0 0 1.12-1.065l.254-3.223a1.125 1.125 0 0 0-.89-1.207l-2.98-.67a1.125 1.125 0 0 0-1.264.597l-.75 1.5a11.775 11.775 0 0 1-4.955-4.955l1.5-.75a1.125 1.125 0 0 0 .597-1.264l-.67-2.98a1.125 1.125 0 0 0-1.207-.89l-3.223.254a1.124 1.124 0 0 0-1.065 1.12L2.25 6.338Z"/></svg>
        </div>
        <span class="fi-label">Verifying</span>
        <span class="fi-count" id="cVerify">0</span>
      </div>

      <div class="filter-item fi-disp" onclick="setFilter('dispatched',this)">
        <div class="fi-icon">
          <!-- Heroicon: bolt -->
          <svg viewBox="0 0 24 24"><path d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>
        </div>
        <span class="fi-label">Dispatched</span>
        <span class="fi-count" id="cDisp">0</span>
      </div>

      <div class="filter-item fi-res" onclick="setFilter('resolved',this)">
        <div class="fi-icon">
          <!-- Heroicon: check-circle -->
          <svg viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        </div>
        <span class="fi-label">Resolved</span>
        <span class="fi-count" id="cRes">0</span>
      </div>

      <div class="filter-item fi-false" onclick="setFilter('false-report',this)">
        <div class="fi-icon">
          <!-- Heroicon: x-circle -->
          <svg viewBox="0 0 24 24"><path d="M9.75 9.75l4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        </div>
        <span class="fi-label">False Report</span>
        <span class="fi-count" id="cFalse">0</span>
      </div>

    </div>

    <div class="sidebar-footer">
      <div class="rf-brand">
        <img class="rf-logo" src="/images/logo.png" alt="MDRRMO SVS Logo">
        <div class="rf-copy">
          <div class="rf-name">Smart Verification System</div>
          <div class="rf-sub">Emergency Reporting</div>
        </div>
      </div>
      <p class="rf-text">Fast and reliable citizen incident reporting with real-time dispatcher visibility and location-aware alerts.</p>
    </div>
  </aside>

  <div id="notifStack" class="notif-stack" aria-live="polite" aria-atomic="true"></div>

  <!-- MAIN CONTENT -->
  <main class="main">
    <div class="main-inner">

      <div class="main-header">
        <div class="main-head-copy">
          <div class="main-title">Live Dispatch Console</div>
          <div class="main-sub">Real-time emergency report management</div>
          <div class="main-quick-filters">
            <button class="quick-filter-btn" type="button" onclick="setFilter('sos',this)">
              SOS
              <span class="quick-count" id="cSos">0</span>
            </button>
            <button class="quick-filter-btn" type="button" onclick="setFilter('report',this)">
              Report
              <span class="quick-count" id="cReport">0</span>
            </button>
          </div>
        </div>
        <div class="main-head-tools">
          <div class="search-bar" role="search">
            <svg viewBox="0 0 24 24"><path d="m15.75 15.75 3.5 3.5M4.5 11.25a6.75 6.75 0 1 0 13.5 0 6.75 6.75 0 0 0-13.5 0Z"/></svg>
            <input class="search-input" id="reportSearch" type="search" placeholder="Search ID, name, phone, barangay..." oninput="setSearch(this.value)">
            <button class="search-go" type="button" onclick="jumpToFirst()">Jump</button>
            <button class="search-clear" type="button" onclick="clearSearch()">Clear</button>
          </div>
          <div class="main-datetime" id="dateTimeText">
            <svg viewBox="0 0 24 24"><path d="M6.75 3v2.25m10.5-2.25v2.25M3.75 9.75h16.5M4.5 5.25h15A1.5 1.5 0 0 1 21 6.75v12A1.5 1.5 0 0 1 19.5 20.25h-15A1.5 1.5 0 0 1 3 18.75v-12A1.5 1.5 0 0 1 4.5 5.25Z"/></svg>
            Loading time...
          </div>
          <button type="button" class="user-greet" title="Open profile settings" onclick="openProfileModal()">
            <span class="user-greet-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0m-3.75 13.5a7.5 7.5 0 0 1 15 0"/></svg>
            </span>
            HI!!! <span id="profileGreetingName"><%= (currentUser && (currentUser.fullName || currentUser.username)) ? (currentUser.fullName || currentUser.username) : 'Dispatcher' %></span>
          </button>
        </div>
      </div>

      <div class="ops-grid" aria-label="Dispatch summary">
        <div class="ops-card urgent">
          <div class="ops-kicker">Incoming</div>
          <div class="ops-value" id="opsIncoming">0</div>
          <div class="ops-label">New / urgent queue</div>
          <div class="ops-meta">Fresh reports that may need immediate pickup.</div>
        </div>
        <div class="ops-card mine">
          <div class="ops-kicker">Assigned</div>
          <div class="ops-value" id="opsMine">0</div>
          <div class="ops-label">Owned by you</div>
          <div class="ops-meta">Reports you can verify, edit, dispatch, or resolve.</div>
        </div>
        <div class="ops-card verify">
          <div class="ops-kicker">Verification</div>
          <div class="ops-value" id="opsVerify">0</div>
          <div class="ops-label">In call-back stage</div>
          <div class="ops-meta">Reports currently under verification follow-up.</div>
        </div>
        <div class="ops-card resolved">
          <div class="ops-kicker">Closed</div>
          <div class="ops-value" id="opsResolved">0</div>
          <div class="ops-label">Resolved queue</div>
          <div class="ops-meta">Handled incidents already marked complete.</div>
        </div>
      </div>

      <div class="filter-label-bar" id="filterLabel">All Reports</div>

      <div class="report-list" id="reportList">
        <!-- rendered by JS -->
      </div>

    </div>
  </main>

</div>

<!-- TOAST -->

  <div class="toast" id="toast">
    <svg viewBox="0 0 24 24"><path d="M11.25 11.25l.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"/></svg>
    <div><strong id="toastTitle"></strong><span id="toastMsg"></span></div>
  </div>

  <div class="img-modal" id="imgModal">
    <div class="img-modal-card">
      <button class="img-close" type="button" onclick="closeImgModal()">×</button>
      <div class="img-preview-wrap">
        <img id="imgModalPreview" src="" alt="Evidence preview">
        <button class="img-nav-btn prev" type="button" id="imgPrevBtn" onclick="stepImg(-1)">‹</button>
        <button class="img-nav-btn next" type="button" id="imgNextBtn" onclick="stepImg(1)">›</button>
      </div>
      <div class="img-meta">
        <div>
          <label>Report</label>
          <h4 id="imgModalReport">Report</h4>
        </div>
        <div>
          <label>Reporter</label>
          <p id="imgModalName">-</p>
        </div>
        <div>
          <label>Notes (for your reference)</label>
          <textarea id="imgModalNotes" placeholder=" jot authenticity checks (e.g., timestamps, shadows, GPS match)"></textarea>
        </div>
        <div class="img-actions">
          <button class="img-btn" type="button" onclick="closeImgModal()">Close</button>
        </div>
      </div>
    </div>
  </div>

  <div class="perm-modal" id="permModal">
    <div class="perm-card">
      <h3>Allow microphone to start call</h3>
      <p>Tap “Allow mic” — your browser will show a permission prompt. We keep this panel open until you decide.</p>
      <div id="permStatus" style="color:#b91c1c;font-weight:700;font-size:.9rem;"></div>
      <div class="perm-actions">
        <button class="perm-btn" type="button" onclick="closePermModal()">Cancel</button>
        <button class="perm-btn primary" type="button" onclick="requestMicPermission()">Allow mic</button>
      </div>
