  async function claimReport(id, options = {}) {
    if (!id) return null;
    if (pendingClaims.has(id)) return null;
    const silent = !!options.silent;
    pendingClaims.add(id);
    render();
    try {
      const res = await fetch(`/api/report/${encodeURIComponent(id)}/claim`, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json().catch(() => ({}));
      if (res.status === 401) {
        handleUnauthorized(data);
        pendingClaims.delete(id);
        render();
        return null;
      }
      if (res.status === 409) {
        toast_('Already claimed', data.error || 'Another dispatcher claimed this first.', 'warn');
        pendingClaims.delete(id);
        render();
        syncReportsFromServer(true);
        return null;
      }
      if (!res.ok || !data.success) throw new Error(data.error || 'Could not claim report');
      const incoming = normalizeReport(data.report || {});
      upsertReport(incoming);
      if (!silent) {
        toast_('Report claimed', `${incoming.id || id} is now assigned to you.`);
      }
      // Clear pending and render immediately
      pendingClaims.delete(id);
      render();
      // Sync in background without blocking UI
      syncReportsFromServer(true);
      return incoming;
    } catch (e) {
      toast_('Error', e && e.message ? e.message : 'Could not claim report.', 'warn');
      pendingClaims.delete(id);
      render();
      return null;
    }
  }

  async function passReport(id, targetDispatcherId) {
    if (!id || !targetDispatcherId) {
      toast_('Error', 'Missing report or target dispatcher', 'warn');
      return false;
    }
    
    // Find the target dispatcher info for instant feedback
    const targetDisp = activeDispatchers.find(u => String(u.id || '').trim() === String(targetDispatcherId || '').trim());
    const targetName = String(targetDisp ? (targetDisp.fullName || targetDisp.username) : 'dispatcher').trim();
    
    // Update UI immediately for instant feedback
    const r = reports.find(x => x.id === id);
    if (!r) {
      toast_('Error', 'Report not found', 'warn');
      return false;
    }
    
    const originalAssignment = { assignedToId: r.assignedToId, assignedToName: r.assignedToName, passCount: r.passCount };
    
    // Optimistic update
    r.assignedToId = targetDispatcherId;
    r.assignedToName = targetName;
    r.passCount = (Number(r.passCount) || 0) + 1;
    lastReportsSig = reportsSignature(reports);
    render();
    toast_('Report passed', `${id} was passed to ${targetName}.`);
    
    // Make server call in background
    try {
      const res = await fetch(`/api/report/${encodeURIComponent(id)}/pass`, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetDispatcherId }),
      });
      
      if (res.status === 401) {
        const data = await res.json().catch(() => ({}));
        handleUnauthorized(data);
        // Revert on auth error
        r.assignedToId = originalAssignment.assignedToId;
        r.assignedToName = originalAssignment.assignedToName;
        r.passCount = originalAssignment.passCount;
        lastReportsSig = reportsSignature(reports);
        render();
        return false;
      }
      
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) {
        throw new Error(data.error || 'Could not pass report');
      }
      
      // Sync the full response from server for accuracy
      const incoming = normalizeReport(data.report || {});
      
      // After successful pass, explicitly remove the report if it's no longer visible to current user
      if (!canSeeReport(incoming)) {
        reports = reports.filter(x => x.id !== incoming.id);
      } else {
        const reportIndex = reports.findIndex(x => x.id === incoming.id);
        if (reportIndex >= 0) {
          reports[reportIndex] = incoming;
        }
      }
      lastReportsSig = reportsSignature(reports);
      render();
      return true;
    } catch (e) {
      // Revert on error
      r.assignedToId = originalAssignment.assignedToId;
      r.assignedToName = originalAssignment.assignedToName;
      r.passCount = originalAssignment.passCount;
      lastReportsSig = reportsSignature(reports);
      render();
      toast_('Error', e && e.message ? e.message : 'Could not pass report.', 'warn');
      return false;
    }
  }

  async function passReportPrompt(id) {
    const r = reports.find(x => x.id === id);
    if (r && isClosedStatus(r.status)) {
      toast_('Action unavailable', 'Closed reports cannot be passed.', 'warn');
      return;
    }
    const choices = (activeDispatchers || []).filter(u => !u.isSelf && String(u.id || '').trim());
    if (!choices.length) {
      toast_('No active dispatcher', 'No other active dispatcher is currently available.', 'warn');
      return;
    }
    if (typeof Swal === 'undefined') {
      toast_('Action unavailable', 'Passing reports requires dialog support. Refresh this page.', 'warn');
      return;
    }
    const inputOptions = {};
    choices.forEach(u => {
      const name = String(u.fullName || u.username || 'Dispatcher').trim();
      inputOptions[String(u.id)] = `${name} (${u.username || 'user'})`;
    });
    const result = await Swal.fire({
      title: 'Pass Report',
      text: `Select dispatcher for ${id}`,
      input: 'select',
      inputOptions,
      inputPlaceholder: 'Select dispatcher',
      showCancelButton: true,
      confirmButtonText: 'Pass',
      confirmButtonColor: '#1D4ED8',
      cancelButtonColor: '#6B7280',
      inputValidator: (value) => (!value ? 'Select a dispatcher.' : undefined),
    });
    if (!result.isConfirmed || !result.value) return;
    try {
      await passReport(id, result.value);
    } catch (e) {
      toast_('Error', e && e.message ? e.message : 'Could not pass report.', 'warn');
    }
  }

