  async function updStatus(id, status, responseTeamType = null) {
    if (!id) {
      toast_('Error', 'Missing report ID.', 'warn');
      return;
    }
    
    // For dispatch status, a response team type is mandatory
    if (status === 'dispatched' && !responseTeamType) {
      toast_('Error', 'Response team type is required for dispatch.', 'warn');
      return;
    }
    
    // Update UI immediately for instant feedback
    const r = reports.find(x=>x.id===id);
    const originalStatus = r ? r.status : null;
    if (r) { r.status=status; lastReportsSig = reportsSignature(reports); render(); }
    const msgs = {verifying:'Calling reporter to verify…',dispatched:`${responseTeamType || 'Response'} team dispatched!`,resolved:'Incident resolved.',['false-report']:'Flagged as false report.'};
    callStartedIds.delete(id);
    const msg = status === 'verifying' ? 'Verification stage started.' : (msgs[status] || '');
    toast_(id, msg);
    
    try {
      const body = {status};
      if (responseTeamType) {
        body.responseTeamType = responseTeamType;
      }
      const res = await fetch(`/api/report/${encodeURIComponent(id)}/status`, {
        method: 'PATCH',
        credentials: 'same-origin',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify(body)
      });
      const data = await res.json().catch(() => ({}));
      if (res.status === 401) {
        handleUnauthorized(data);
        return;
      }
      if (!res.ok) throw new Error(data.error || 'Could not update status');
    } catch(e) { 
      // Revert if error
      if (r && originalStatus) { r.status = originalStatus; render(); }
      toast_('Error', e && e.message ? e.message : 'Could not update status.','warn'); 
    }
  }

