        </button>` : ''}
        ${r.status==='dispatched' ? `<button class="act-btn success" onclick="updStatus('${rid}','resolved')">
          <svg viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          Resolved
        </button>` : ''}
        ${(canManageAssignedReport && r.status!=='resolved'&&r.status!=='false-report') ? `<button class="act-btn danger-act" onclick="confirmFalseReportById('${rid}')">
          <svg viewBox="0 0 24 24"><path d="M9.75 9.75l4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          False Report
        </button>` : ''}
        <button class="act-btn call-act" onclick="startWebCall('${rid}')">
          <svg viewBox="0 0 24 24"><path d="M2.25 6.338c0 7.5 6.089 13.587 13.589 13.587l.682-.002a1.124 1.124 0 0 0 1.12-1.065l.254-3.223a1.125 1.125 0 0 0-.89-1.207l-2.98-.67a1.125 1.125 0 0 0-1.264.597l-.75 1.5a11.775 11.775 0 0 1-4.955-4.955l1.5-.75a1.125 1.125 0 0 0 .597-1.264l-.67-2.98a1.125 1.125 0 0 0-1.207-.89l-3.223.254a1.124 1.124 0 0 0-1.065 1.12Z"/></svg>
          Web Call
        </button>
        ${(canManageAssignedReport && r.status==='new' && callStarted) ? '' : `<button class="act-btn call-act" onclick="callReporterById('${rid}')">
          <svg viewBox="0 0 24 24"><path d="M2.25 6.338c0 7.5 6.089 13.587 13.589 13.587l.682-.002a1.124 1.124 0 0 0 1.12-1.065l.254-3.223a1.125 1.125 0 0 0-.89-1.207l-2.98-.67a1.125 1.125 0 0 0-1.264.597l-.75 1.5a11.775 11.775 0 0 1-4.955-4.955l1.5-.75a1.125 1.125 0 0 0 .597-1.264l-.67-2.98a1.125 1.125 0 0 0-1.207-.89l-3.223.254a1.124 1.124 0 0 0-1.065 1.12L2.25 6.338Z"/></svg>
          Call ${esc(r.contact)}
        </button>`}
      </div>
    </div>`;
  }

  function isUnknownLocationText(v) {
    const s = String(v || '').trim().toLowerCase();
    if (!s) return true;
    return s.includes('unknown') || s.includes('gps only') || s.includes('location unavailable') || s === 'unavailable';
  }

  function getReadableLocation(r) {
    const parts = [];
    const street = String(r.street || '').trim();
    const landmark = String(r.landmark || '').trim();
    const barangay = String(r.barangay || '').trim();
    if (street && !isUnknownLocationText(street)) parts.push(street);
    if (landmark && !isUnknownLocationText(landmark) && !parseGps(landmark)) parts.push(landmark);
    if (barangay && !isUnknownLocationText(barangay)) parts.push(barangay);
    return parts.join(', ');
  }

  function displayReportRef(r) {
    if (r.reportId) return r.reportId;
    if (r.emergencyType === 'PANIC SOS') return 'SOS LEGACY';
    const raw = String(r._id || r.id || '').trim();
    return raw ? `LEGACY-${raw.slice(-6).toUpperCase()}` : 'N/A';
  }

  function parseGps(gps) {
    if (!gps || typeof gps !== 'string') return null;
    const m = gps.match(/^\s*(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)\s*$/);
    if (!m) return null;
    const lat = Number(m[1]);
    const lng = Number(m[2]);
    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return null;
    if (lat < -90 || lat > 90 || lng < -180 || lng > 180) return null;
    return { lat, lng };
  }

  function gpsMapHTML(r) {
    const p = parseGps(r.gps);
    if (!p) return '';
    const lat = p.lat.toFixed(6);
    const lng = p.lng.toFixed(6);
    const open = `https://www.google.com/maps?q=${lat},${lng}`;
    const embed = `https://maps.google.com/maps?q=${lat},${lng}&t=m&z=20&output=embed`;
    return `
      <div class="rcard-map">
        <div class="rcard-map-head">
          <span>GPS: ${lat}, ${lng}</span>
          <a class="map-open" href="${open}" target="_blank" rel="noopener noreferrer">Open map</a>
        </div>
        <iframe class="rcard-map-canvas" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="${embed}"></iframe>
      </div>
    `;
  }

  function gpsDisplayLabel(r) {
    const pretty = String(r.gpsResolvedText || '').trim();
    if (pretty) return pretty;
    const p = parseGps(r.gps);
    if (!p) return String(r.gps || '');
    if (r._gpsLookupPending) return 'Resolving location...';
    return 'Resolving location...';
  }

  async function resolveGpsTextForReport(r) {
    if (!r || r._gpsLookupDone || r._gpsLookupPending) return false;
    const p = parseGps(r.gps);
    if (!p) return false;
    r._gpsLookupPending = true;
    try {
      const res = await fetch(`/api/reverse-geocode?lat=${encodeURIComponent(p.lat)}&lng=${encodeURIComponent(p.lng)}`);
      if (!res.ok) throw new Error('reverse geocode failed');
      const data = await res.json();
      const parts = [data.barangay, data.landmark].filter(Boolean);
      if (parts.length) {
        r.gpsResolvedText = parts.join(', ');
      } else {
        r.gpsResolvedText = `Near ${p.lat.toFixed(5)}, ${p.lng.toFixed(5)}`;
      }
    } catch (_e) {
      r.gpsResolvedText = `Near ${p.lat.toFixed(5)}, ${p.lng.toFixed(5)}`;
    } finally {
      r._gpsLookupPending = false;
      r._gpsLookupDone = true;
    }
    return true;
  }

  async function resolveGpsTexts(reportsToResolve) {
    const jobs = reportsToResolve.map(resolveGpsTextForReport);
    const results = await Promise.all(jobs);
    return results.some(Boolean);
  }

  function normalizeReport(r) {
    if (!r || typeof r !== 'object') return r;
    const status = String(r.status || 'new');
    const primaryPhoto = String(r.photo || '').trim();
    const photos = Array.isArray(r.photos)
      ? r.photos.map(x => String(x || '').trim()).filter(Boolean)
      : [];
    const photoCount = Math.max(Number.parseInt(r.photoCount, 10) || 0, photos.length + (primaryPhoto ? 1 : 0));
    return {
      ...r,
      id: r.id || r.reportId || r._id || '',
      status,
      photo: primaryPhoto,
      photos,
      photoCount,
      assignedToId: String(r.assignedToId || '').trim(),
      assignedToName: String(r.assignedToName || '').trim(),
      assignedAt: r.assignedAt || null,
      gpsResolvedText: r.gpsResolvedText || '',
      _gpsLookupPending: false,
      _gpsLookupDone: false
    };
  }

  function reportsSignature(arr) {
    return (arr || [])
      .map(r => `${r.id || r.reportId || ''}|${r.status || ''}|${r.assignedToId || ''}|${r.timestamp || ''}`)
      .join('||');
  }

  function dedupeReports(arr = []) {
    const seen = new Set();
    const clean = [];
    for (const r of arr) {
      const id = normalizeId(r.id || r.reportId || r._id || '');
      if (!id) continue;
      if (seen.has(id)) continue;
      seen.add(id);
      clean.push(r);
    }
    return clean;
  }

  function upsertReport(incoming, options = {}) {
    if (!incoming) return;
    const id = normalizeId(incoming.id || incoming.reportId || incoming._id || '');
    if (!id) return;
    const idx = reports.findIndex(x => normalizeId(x.id || x.reportId || x._id || '') === id);
    if (idx >= 0) reports[idx] = incoming;
    else {
      if (options.append) reports.push(incoming);
      else reports.unshift(incoming);
    }
    reports = dedupeReports(reports);
    lastReportsSig = reportsSignature(reports);
  }

  /* Notifications */
  const hotspotAlerts = new Map(); // barangay -> timestamp ms
  function addNotification(title, msg, type='info') {
    const stack = document.getElementById('notifStack');
    if (!stack) return;
    const card = document.createElement('div');
    card.className = `notif-card ${type === 'alert' ? 'alert' : (type === 'warn' ? 'warn' : '')}`;
    card.innerHTML = `<div class="notif-title">${esc(title)}</div><div class="notif-msg">${esc(msg)}</div><div class="notif-meta">${new Date().toLocaleTimeString()}</div>`;
    stack.prepend(card);
    setTimeout(()=>{
      card.style.opacity='0'; card.style.transform='translateY(-4px)';
      setTimeout(()=>card.remove(),320);
    }, 5200);
    // limit stack size
    while(stack.children.length>4){stack.lastChild.remove();}
  }

  function checkHotspot(report) {
    const area = String(report.barangay || '').trim();
    const ts = Number(new Date(report.timestamp || Date.now()));
    if (!area || !Number.isFinite(ts)) return;
    const windowMs = 15*60*1000;
    const cutoff = Date.now() - windowMs;
    const recent = reports.filter(r => String(r.barangay || '').trim() === area && Number(new Date(r.timestamp || 0)) >= cutoff);
    if (recent.length >= 3) {
      const last = hotspotAlerts.get(area) || 0;
      if (Date.now() - last > windowMs/2) {
        hotspotAlerts.set(area, Date.now());
        addNotification('Cluster detected', `${area}: ${recent.length} reports in the last 15 minutes. Coordinate response.`, 'warn');
      }
    }
  }

  let lastReportsSig = reportsSignature(reports);
  const mediaLoads = new Map();

  async function loadReportMedia(reportId) {
    const id = normalizeId(reportId);
    if (!id) return [];
    const existing = reports.find(x => normalizeId(x.id || x.reportId || x._id || '') === id);
    const cached = existing && Array.isArray(existing.photos) && existing.photos.length
      ? existing.photos.filter(Boolean)
      : [];
    if (cached.length) return cached;
    if (mediaLoads.has(id)) return mediaLoads.get(id);
    const job = (async () => {
      const res = await fetch(`/api/report/${encodeURIComponent(id)}/media?_=${Date.now()}`, { cache: 'no-store' });
      const data = await res.json().catch(() => ({}));
      if (res.status === 401) {
        handleUnauthorized(data);
        return [];
      }
      if (!res.ok) throw new Error(data.error || 'Could not load report photos.');
      const photos = Array.isArray(data.photos) ? data.photos.map(x => String(x || '').trim()).filter(Boolean) : [];
      const idx = reports.findIndex(x => normalizeId(x.id || x.reportId || x._id || '') === id);
      if (idx >= 0) {
        reports[idx].photos = photos;
        reports[idx].photo = photos[0] || '';
        reports[idx].photoCount = Math.max(Number(data.photoCount || 0), photos.length);
        render();
      }
      return photos;
    })().finally(() => mediaLoads.delete(id));
    mediaLoads.set(id, job);
    return job;
  }

  async function syncReportsFromServer(forceRender = false) {
    if (webCallReportId || (permModal && permModal.classList.contains('show'))) return; // pause while in call or permission dialog
    try {
      const res = await fetch(`/api/reports?_=${Date.now()}`, { cache: 'no-store' });
      if (res.status === 401) {
        const data = await res.json().catch(() => ({}));
        handleUnauthorized(data);
        return;
      }
      if (!res.ok) return;
      const data = await res.json();
      let fresh = dedupeReports((Array.isArray(data) ? data : []).map(normalizeReport));
      // Extra safety: filter out any reports that shouldn't be visible to current user
      fresh = fresh.filter(r => canSeeReport(r));
      const sig = reportsSignature(fresh);
      if (!forceRender && sig === lastReportsSig) return;
      reports = fresh;
      lastReportsSig = sig;
      render();
    } catch (_e) {}
  }

  function render() {
    for (const id of Array.from(callStartedIds)) {
      const r = reports.find(x => x.id === id);
      const stillMine = r && String(r.assignedToId || '').trim() === currentUserId;
      if (!r || String(r.status || '') !== 'new' || !stillMine) callStartedIds.delete(id);
    }
    counts();
    const list = document.getElementById('reportList');
    const existingMaps = new Map();
    list.querySelectorAll('.rcard-map').forEach(mapNode => {
      const card = mapNode.closest('.rcard');
      if (!card || !card.id) return;
      existingMaps.set(card.id, mapNode);
    });

    const visibleReports = reports.filter(canSeeReport);
    const baseFiltered = curFilter === 'all'
      ? visibleReports.filter(r => !isClosedStatus(r.status) && (!String(r.assignedToId||'').trim() || String(r.assignedToId||'').trim() === currentUserId))
      : curFilter === 'sos'
        ? visibleReports.filter(r => isSosReport(r) && !isClosedStatus(r.status) && (!String(r.assignedToId||'').trim() || String(r.assignedToId||'').trim() === currentUserId))
        : curFilter === 'report'
          ? visibleReports.filter(r => isRegularReport(r) && !isClosedStatus(r.status) && (!String(r.assignedToId||'').trim() || String(r.assignedToId||'').trim() === currentUserId))
          : curFilter === 'new'
            ? visibleReports.filter(r=>r.status==='new' && !String(r.assignedToId||'').trim())
            : curFilter === 'assigned'
              ? visibleReports.filter(r=>String(r.assignedToId||'').trim() === currentUserId && !isClosedStatus(r.status))
              : visibleReports.filter(r=>r.status===curFilter);
    const searchTerm = curSearch.trim().toLowerCase();
    const filtered = searchTerm
      ? baseFiltered.filter(r => matchesSearch(r, searchTerm))
      : baseFiltered;
    if (!filtered.length) {
      list.innerHTML = `<div class="empty">
        <div class="empty-icon"><svg viewBox="0 0 24 24"><path d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776"/></svg></div>
        <h3>${searchTerm ? 'No reports match your search' : 'No reports here'}</h3>
        <p>${searchTerm ? 'Try another keyword or clear the search filter.' : 'Citizen reports appear instantly when submitted.'}</p>
      </div>`;
      return;
    }
    list.innerHTML = filtered.map(r => cardHTML(r, searchTerm && matchesSearch(r, searchTerm))).join('');

    // Reuse already-loaded map nodes so map iframes do not reload on data refresh.
    existingMaps.forEach((oldMapNode, cardId) => {
      const card = document.getElementById(cardId);
      if (!card) return;
      const freshMapNode = card.querySelector('.rcard-map');
      if (!freshMapNode) return;
      freshMapNode.replaceWith(oldMapNode);
    });

    if (pendingScrollToFirst && filtered.length) {
      const firstId = normalizeId(filtered[0].id || filtered[0].reportId || filtered[0]._id || '');
      if (firstId) {
        const target = document.getElementById(`card-${firstId}`);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    pendingScrollToFirst = false;

    resolveGpsTexts(filtered).then(changed => { if (changed) render(); });
  }

  async function reverseGeocodeForDashboard(lat, lng) {
    const key = `${lat.toFixed(5)},${lng.toFixed(5)}`;
    if (geoCache.has(key)) return geoCache.get(key);
    if (geoInFlight.has(key)) return null;
    geoInFlight.add(key);
    try {
      const res = await fetch(`/api/reverse-geocode?lat=${encodeURIComponent(lat)}&lng=${encodeURIComponent(lng)}`);
      if (!res.ok) return null;
      const data = await res.json().catch(() => ({}));
      const out = {
        barangay: String((data && data.barangay) || '').trim(),
        landmark: String((data && data.landmark) || '').trim(),
        street: String((data && data.street) || '').trim(),
      };
      geoCache.set(key, out);
      return out;
    } catch (_e) {
      return null;
    } finally {
      geoInFlight.delete(key);
    }
  }

  async function hydrateLegacyPanicLocations() {
    const candidates = reports.filter(r =>
      r && r.emergencyType === 'PANIC SOS' && parseGps(r.gps) && !getReadableLocation(r)
    );
    if (!candidates.length) return;

    let changed = false;
    for (const r of candidates) {
      const p = parseGps(r.gps);
      if (!p) continue;
      const g = await reverseGeocodeForDashboard(p.lat, p.lng);
      if (!g) continue;
      if (!r.barangay && g.barangay) { r.barangay = g.barangay; changed = true; }
      if ((!r.landmark || parseGps(r.landmark) || isUnknownLocationText(r.landmark)) && g.landmark) { r.landmark = g.landmark; changed = true; }
      if (!r.street && g.street) { r.street = g.street; changed = true; }
    }
    if (changed) render();
  }

