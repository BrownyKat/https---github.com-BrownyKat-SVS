          ${isClaiming ? 'Claiming...' : 'Claim'}
        </button>` : ''}
        ${isMine && !isClosed && r.status!=='verifying' && r.status!=='dispatched' && r.status!=='resolved' && r.status!=='false-report' ? `<button class="act-btn" onclick="passReportPrompt('${rid}')">
          <svg viewBox="0 0 24 24"><path d="M7.5 8.25h9m-9 3h6m-6 3h3M3 5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25v13.5A2.25 2.25 0 0 1 18.75 21H5.25A2.25 2.25 0 0 1 3 18.75V5.25Z"/></svg>
