<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dispatcher Login - SVS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --blue:#1d4ed8; --blue-light:#dbeafe; --blue-border:#93c5fd;
      --amber:#facc15; --red:#dc2626; --surface:#ffffff; --border:#bfd6f5;
      --text:#0f172a; --muted:#334155;
    }
    *{box-sizing:border-box}
    body{
      margin:0;font-family:'Outfit',sans-serif;color:var(--text);display:flex;min-height:100vh;align-items:center;justify-content:center;
      padding:18px;
      background:
        radial-gradient(560px 320px at 100% 0,rgba(29,78,216,.24),transparent 64%),
        radial-gradient(420px 240px at 8% 100%,rgba(250,204,21,.26),transparent 66%),
        linear-gradient(180deg,#f5f9ff 0%,#e8f1ff 100%);
      overflow:hidden;position:relative;
    }
    body::before,body::after{content:'';position:fixed;border-radius:50%;pointer-events:none}
    body::before{width:280px;height:280px;left:-90px;top:-70px;background:rgba(250,204,21,.14);filter:blur(6px)}
    body::after{width:360px;height:360px;right:-120px;bottom:-110px;background:rgba(29,78,216,.10);filter:blur(8px)}
    .card{
      width:min(460px,94vw);background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(244,248,255,.94));
      border:1px solid var(--border);border-radius:24px;padding:28px;box-shadow:0 24px 58px rgba(15,23,42,.14);animation:fadeUp .4s ease both;
      position:relative;overflow:hidden;backdrop-filter:blur(12px)
    }
    .card::before{
      content:'';position:absolute;inset:0 0 auto 0;height:5px;background:linear-gradient(90deg,var(--blue),var(--amber),var(--red));
    }
    .logo-wrap{text-align:center;margin-bottom:14px}
    .logo{width:180px;max-width:58vw;height:auto;object-fit:contain;display:inline-block;filter:drop-shadow(0 10px 18px rgba(29,78,216,.08))}
    h1{margin:0 0 10px;font-size:28px;letter-spacing:-.8px}
    p{margin:0 0 20px;color:#1e3a8a;font-size:14px;line-height:1.7}
    label{
      display:block;font-size:11px;font-weight:800;margin:12px 0 7px;text-transform:uppercase;color:#1e3a8a;letter-spacing:1px;
      font-family:'JetBrains Mono',monospace
    }
    input{
      width:100%;padding:13px 14px;border:1px solid var(--blue-border);border-radius:14px;font-size:14px;box-sizing:border-box;background:#fff;
      font-family:'Outfit',sans-serif;transition:border-color .18s ease,box-shadow .18s ease,transform .18s ease
    }
    input:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 4px rgba(29,78,216,.12);transform:translateY(-1px)}
    .btn{
      margin-top:18px;width:100%;padding:13px 14px;border:0;border-radius:14px;background:linear-gradient(135deg,var(--blue),#2563eb);
      color:#fff;font-weight:800;cursor:pointer;font-family:'Outfit',sans-serif;box-shadow:0 14px 30px rgba(29,78,216,.24);
      transition:transform .2s ease,box-shadow .2s ease
    }
    .btn:hover{transform:translateY(-2px);box-shadow:0 18px 34px rgba(29,78,216,.28)}
    .err{background:#fef2f2;border:1px solid #fca5a5;color:#b91c1c;padding:11px 12px;border-radius:12px;margin-bottom:12px;font-size:13px;font-weight:600}
    .hint{margin-top:12px;font-size:12px;color:var(--muted)}
    @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    @media(max-width:460px){.card{padding:20px;border-radius:18px}h1{font-size:24px}}
  </style>
</head>
<body>
  <form class="card" method="post" action="/dispatcher/login" id="dispatcherLoginForm">
    <div class="logo-wrap"><img class="logo" src="/images/logo.png" alt="MDRRMO SVS Logo"></div>
    <h1>Dispatcher Login</h1>
    <p>Sign in to access the dispatcher operations console.</p>
    <% if (error) { %><div class="err"><%= error %></div><% } %>
    <label for="username">Username</label>
    <input id="username" name="username" required autocomplete="username">
    <label for="password">Password</label>
    <input id="password" name="password" type="password" required autocomplete="current-password">
    <button class="btn" type="submit">Login</button>
  </form>
  <script>
    try {
      const q = new URLSearchParams(window.location.search);
      if (q.get('force') === '1') {
        sessionStorage.removeItem('svs_dispatcher_window_ok');
      }
      const f = document.getElementById('dispatcherLoginForm');
      if (f) {
        f.addEventListener('submit', function () {
          sessionStorage.setItem('svs_dispatcher_window_ok', String(Date.now()));
          sessionStorage.removeItem('svs_admin_window_ok');
        });
      }
    } catch (_e) {}
  </script>
</body>
</html>

