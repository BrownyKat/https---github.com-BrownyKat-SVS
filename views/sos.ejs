<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SVS - SOS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[linear-gradient(180deg,#f2f6ff_0%,#fff7ef_72%,#ffffff_100%)] text-slate-900 antialiased [font-family:'Outfit',sans-serif] leading-[1.65]">
  <%- include('partials/navbar', { active: 'sos', timeId: 'sosTime' }) %>

  <main class="mx-auto my-12 max-w-[1100px] px-5">
    <section class="rounded-[28px] border border-red-200/70 bg-[linear-gradient(180deg,#ecf2ff_0%,#fff7e8_52%,#ffeef1_100%)] px-6 py-10 text-center shadow-[0_18px_38px_rgba(0,0,0,0.12)] sm:px-8 sm:py-14" style="margin-bottom:2.2rem;">
      <div class="mb-5 font-mono text-[1.05rem] font-extrabold uppercase tracking-[0.22em] text-red-700 sm:text-[1.1rem]">
        Urgent Emergency
      </div>

  <main class="wrap">
    <section class="panic-strip">
      <div class="panic-eyebrow">Urgent Emergency</div>
      <button class="panic-btn" type="button" onclick="triggerPanic()">
        <svg viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
        <div class="panic-btn-label">PANIC SOS</div>
      </button>

      <div class="mx-auto mb-5 max-w-[520px] rounded-[18px] border border-blue-200 bg-white px-5 py-5 shadow-[0_14px_30px_rgba(15,23,42,0.14)]">
        <h3 class="mb-2 text-[1.08rem] font-extrabold text-slate-950">One tap sends instant SOS.</h3>
        <p class="text-base leading-[1.65] text-slate-800">
          Your exact location will be sent to dispatchers immediately. If GPS is weak, proceed to the full report form.
        </p>
      </div>

      <div class="mt-4 flex flex-wrap items-center justify-center gap-3 rounded-[14px] border border-slate-300 bg-slate-50 px-4 py-3 font-mono font-extrabold text-slate-900">
        <span>Sending as:</span>
        <input id="sosNumber" type="tel" inputmode="tel" placeholder="+63 9XX XXX XXXX">
        <button id="sosBtn" type="button" onclick="handleSosClick()">Save</button>
        <span id="sosSaved" style="color:#2563eb;"></span>
      </div>
    </section>

    <div class="mt-8 grid gap-5 [grid-template-columns:repeat(auto-fit,minmax(260px,1fr))]">
      <div class="rounded-[18px] border border-blue-200 bg-[linear-gradient(180deg,#e9f2ff,#fdf7ef)] px-5 py-5 shadow-[0_12px_28px_rgba(15,23,42,0.12)]">
        <h3 class="mb-2 text-[1.05rem] font-extrabold text-red-500">1. Tap Panic</h3>
        <p class="text-[0.98rem] leading-[1.6] text-slate-800">
          Sends your saved emergency contact plus your latest GPS fix.
        </p>
      </div>

      <div class="rounded-[18px] border border-blue-200 bg-[linear-gradient(180deg,#e9f2ff,#fdf7ef)] px-5 py-5 shadow-[0_12px_28px_rgba(15,23,42,0.12)]">
        <h3 class="mb-2 text-[1.05rem] font-extrabold text-red-500">2. Stay on the line</h3>
        <p class="text-[0.98rem] leading-[1.6] text-slate-800">
          Dispatch will call back if GPS is weak. Keep your phone nearby.
        </p>
      </div>

      <div class="rounded-[18px] border border-blue-200 bg-[linear-gradient(180deg,#e9f2ff,#fdf7ef)] px-5 py-5 shadow-[0_12px_28px_rgba(15,23,42,0.12)]">
        <h3 class="mb-2 text-[1.05rem] font-extrabold text-red-500">3. If offline</h3>
        <p class="text-[0.98rem] leading-[1.6] text-slate-800">
          Reports are queued and auto-retried when signal returns.
        </p>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    function updateTime(elId){
      const el=document.getElementById(elId); if(!el) return;
      const clock=el.querySelector('.clock-text'); const date=el.querySelector('.date-text');
      const now=new Date(); const pad=n=>String(n).padStart(2,'0'); const h24=now.getHours(); const h=h24%12||12; const ampm=h24>=12?'PM':'AM';
      clock.textContent=`${pad(h)}:${pad(now.getMinutes())}:${pad(now.getSeconds())} ${ampm}`;
      const days=['SUN','MON','TUE','WED','THU','FRI','SAT'];
      date.textContent=`${days[now.getDay()]} ${pad(now.getMonth()+1)}/${pad(now.getDate())}/${now.getFullYear()}`;
    }
    updateTime('sosTime'); setInterval(()=>updateTime('sosTime'),1000);

    async function triggerPanic() {
      const contact = localStorage.getItem('mdrrmo_panic');
      if (!contact) {
        alert('Please save an emergency contact number first.');
        document.getElementById('sosNumber').focus();
        return;
      }

      const panicBtn = document.querySelector('.panic-btn');
      const btnLabel = panicBtn.querySelector('.panic-btn-label');
      const originalLabel = btnLabel.textContent;

      panicBtn.disabled = true;
      btnLabel.textContent = 'SENDING...';
      panicBtn.style.animation = 'none'; // Pause pulse
      panicBtn.style.cursor = 'wait';

      let gps = 'unavailable';
      try {
        const position = await new Promise((resolve, reject) => {
          navigator.geolocation.getCurrentPosition(resolve, reject, {
            enableHighAccuracy: true,
            timeout: 10000,
            maximumAge: 0
          });
        });
        gps = `${position.coords.latitude}, ${position.coords.longitude}`;
      } catch (err) {
        console.warn('Could not get GPS location:', err.message);
      }

      try {
        const response = await fetch('/api/panic', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ contact, gps }),
        });
        const result = await response.json();
        if (!response.ok) throw new Error(result.error || 'Failed to send SOS.');
        alert(`SOS sent successfully! Report ID: ${result.id}. Dispatchers will contact you shortly.`);
      } catch (err) {
        alert(`Error: Could not send SOS. Please try again or use the full report form.\nDetails: ${err.message}`);
      } finally {
        panicBtn.disabled = false;
        btnLabel.textContent = originalLabel;
        panicBtn.style.animation = '';
        panicBtn.style.cursor = 'pointer';
      }
    }

    function normalizePh(phone){
      if(!phone) return '';
      let p = phone.replace(/[^0-9+]/g,'');
      if(p.startsWith('0')) p = '+63' + p.slice(1);
      if(p.startsWith('63')) p = '+' + p;
      if(!p.startsWith('+63')) return '';
      return p;
    }
    function handleSosClick(){
      const input=document.getElementById('sosNumber');
      const btn=document.getElementById('sosBtn');
      const saved=document.getElementById('sosSaved');
      if(input.disabled){
        input.disabled=false;
        input.focus();
        btn.textContent='Save';
        saved.textContent='';
        return;
      }
      const norm=normalizePh(input.value);
      if(!norm || norm.length < 13){
        saved.textContent='Invalid PH mobile';
        saved.style.color='#b91c1c';
        return;
      }
      try{ localStorage.setItem('mdrrmo_panic', norm); }catch(_e){}
      saved.textContent='Saved';
      saved.style.color='#2563eb';
      input.value=norm;
      input.disabled=true;
      btn.textContent='Edit';
    }
    (function initSaved(){
      try{
        const n=localStorage.getItem('mdrrmo_panic')||'';
        if(n){
          const input=document.getElementById('sosNumber');
          input.value=n;
          input.disabled=true;
          document.getElementById('sosBtn').textContent='Edit';
        }
      }catch(_e){}
    })();
  </script>
</body>
</html>
