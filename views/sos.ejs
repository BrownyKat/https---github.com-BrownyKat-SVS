<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SVS — SOS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root{--blue:#1D4ED8;--red:#DC2626;--bg:#e9f0ff;--bg-2:#fff7ef;--border:#c8d7f3;--muted:#475569;--muted2:#64748B;--amber:#FACC15;--text:#0F172A;}
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Outfit',sans-serif;background:linear-gradient(180deg,#f2f6ff 0%,#fff7ef 72%,#ffffff 100%);color:#0F172A;-webkit-font-smoothing:antialiased;line-height:1.65;}
    a{color:var(--blue);text-decoration:none;}
    a:visited{color:var(--blue);}
    a:hover{color:#0f3fb5;}
    header{position:sticky;top:0;z-index:10;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:1rem;padding:1rem 1.5rem;background:rgba(243,247,255,.9);backdrop-filter:blur(18px);border-bottom:1px solid rgba(191,214,245,.9);box-shadow:0 6px 18px rgba(0,0,0,.08);color:var(--text);}
    .brand{display:flex;align-items:center;gap:.6rem;color:var(--text);text-decoration:none;}
    .brand img{width:72px;height:60px;object-fit:contain;}
    .brand-text{line-height:1;}
    .brand-name{font-weight:900;font-size:1.25rem;letter-spacing:-.2px;color:var(--text);}
    .brand-sub{font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:1px;color:#475569;}
    .header-right{display:grid;grid-template-columns:1fr auto;align-items:center;gap:.7rem;width:100%;justify-items:center;}
    .nav-links{display:flex;align-items:center;gap:.65rem;flex-wrap:wrap;justify-content:center;}
        .nav-btn{display:inline-flex;align-items:center;gap:8px;padding:.5rem 1.1rem;border:1.6px solid rgba(151,189,233,.9);border-radius:15px;background:linear-gradient(180deg,#fff,#f3f7ff);color:var(--text);font-weight:820;font-size:.9rem;transition:.16s;box-shadow:0 9px 18px rgba(15,23,42,.08);}
        .nav-btn:hover{border-color:var(--blue);color:var(--blue);box-shadow:0 12px 24px rgba(29,78,216,.15);}
        .nav-btn.active{border-color:var(--blue);background:linear-gradient(180deg,#f0f5ff,#dfe9ff);color:var(--blue);box-shadow:0 12px 26px rgba(29,78,216,.22);}
        .main-datetime{display:flex;align-items:center;gap:12px;min-height:56px;padding:.65rem 1rem;background:linear-gradient(180deg,#ffffff,#eef3ff) padding-box,linear-gradient(135deg,rgba(239,68,68,.9),rgba(59,130,246,.9)) border-box;border:1.6px solid transparent;border-radius:18px;color:#0F172A;white-space:nowrap;box-shadow:0 14px 26px rgba(0,0,0,.08), inset 0 1px 0 rgba(255,255,255,.65);backdrop-filter:blur(10px);}
        .main-datetime svg{width:22px;height:18px;stroke:var(--blue);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
    .time-block{display:flex;flex-direction:column;line-height:1.05;min-width:0;}
        .clock-text{font-family:'Orbitron','JetBrains Mono',monospace;font-size:1.08rem;font-weight:900;letter-spacing:1.1px;color:#0b1a3a;}
        .date-text{font-family:'JetBrains Mono',monospace;font-size:.7rem;font-weight:800;letter-spacing:.8px;color:#4b5563;margin-top:3px;}
    .wrap{max-width:1100px;margin:2.25rem auto;padding:0 1.25rem;}
    .panic-strip{background:linear-gradient(180deg,#ecf2ff 0%,#fff7e8 52%,#ffeef1 100%);border:1.6px solid rgba(220,38,38,.14);border-radius:28px;box-shadow:0 18px 38px rgba(0,0,0,.12);padding:2.2rem 1.6rem 2.7rem;text-align:center;}
    .panic-eyebrow{font-family:'JetBrains Mono',monospace;font-size:1.1rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#b91c1c;margin-bottom:1.2rem;}
    .panic-btn{width:220px;height:220px;border-radius:50%;background:linear-gradient(145deg,#ef4444,#dc2626,#b91c1c);border:none;cursor:pointer;margin:0 auto 1.4rem;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;box-shadow:0 0 0 14px rgba(220,38,38,.08),0 12px 40px rgba(220,38,38,.35);transition:.15s;animation:panicPulse 3s ease-in-out infinite;}
    @keyframes panicPulse{0%,100%{box-shadow:0 0 0 14px rgba(220,38,38,.08),0 12px 40px rgba(220,38,38,.35);}50%{box-shadow:0 0 0 20px rgba(220,38,38,.12),0 16px 52px rgba(220,38,38,.45);}}
    .panic-btn:hover{transform:translateY(-2px);animation:none;}
    .panic-btn svg{width:48px;height:48px;stroke:#fff;fill:none;stroke-width:1.6;}
    .panic-btn-label{font-weight:900;font-size:.95rem;letter-spacing:4px;text-transform:uppercase;color:#fff;}
    .panic-card{max-width:520px;margin:0 auto 1.2rem;background:#fff;border:1.6px solid #c9d9f7;border-radius:18px;box-shadow:0 14px 30px rgba(15,23,42,.14);padding:1.25rem;}
    .panic-card h3{font-size:1.08rem;margin-bottom:.4rem;color:#0c1a36;}
    .panic-card p{color:#1e293b;line-height:1.65;font-size:1rem;}
    .action-row{display:none;}
    .number-pill{display:flex;align-items:center;gap:.65rem;border:1.5px solid #d4dded;background:#f8fbff;padding:.55rem 1rem;border-radius:14px;font-family:'JetBrains Mono',monospace;font-weight:800;color:#0f172a;justify-content:center;margin-top:1rem;flex-wrap:wrap;}
    .number-pill input{border:1px solid #c9d6ee;border-radius:10px;padding:.45rem .6rem;font-family:'Outfit',sans-serif;font-weight:700;font-size:.95rem;min-width:180px;}
    .number-pill button{border:1px solid #2563eb;background:#2563eb;color:#fff;border-radius:10px;padding:.45rem .8rem;font-weight:800;cursor:pointer;}
    .list{margin-top:1.6rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;}
    .card{background:linear-gradient(180deg,#e9f2ff,#fdf7ef);border:1.4px solid #cbdcfb;border-radius:18px;padding:1.2rem 1.25rem;box-shadow:0 12px 28px rgba(15,23,42,.12);}
    .card h3{font-size:1.05rem;margin-bottom:.45rem;color:#ff2020;}
    .card p{color:#1e293b;line-height:1.6;font-size:.98rem;}
    .hotline{display:flex;align-items:center;gap:.65rem;margin-top:1rem;font-family:'JetBrains Mono',monospace;font-weight:800;color:#ffd4c6;}
    .site-footer{
      margin-top:3rem;
      background:linear-gradient(180deg,rgba(233,240,255,.9),rgba(255,247,239,.95));
      border-top:1px solid var(--border);
      padding:2rem 1.5rem 2.5rem;
      color:var(--text);
      box-shadow:0 -6px 18px rgba(15,23,42,.04);
    }
    .footer-grid{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:flex-start;}
    .footer-brand{display:flex;align-items:center;gap:1rem;}
    .footer-brand img{width:64px;height:64px;object-fit:contain;}
    .footer-brand h4{margin:0;font-size:1.2rem;font-weight:900;letter-spacing:-.2px;}
    .footer-tag{font-family:'JetBrains Mono',monospace;font-size:.75rem;font-weight:700;color:#1D4ED8;letter-spacing:1.4px;text-transform:uppercase;}
    .footer-copy{margin-top:.6rem;color:#1f2937;font-size:1rem;line-height:1.6;}
    .footer-contact h5{letter-spacing:1px;font-size:.75rem;font-weight:800;color:#1D4ED8;margin:0 0 .5rem;}
    .footer-contact p{margin:.15rem 0;color:#0f172a;font-weight:700;}
    .footer-line{height:1px;background:linear-gradient(90deg,rgba(59,130,246,.3),transparent);margin:1.2rem 0;}
    .footer-meta{display:flex;justify-content:space-between;gap:1rem;color:#475569;font-size:.9rem;}
    @media(max-width:820px){.panic-btn{width:200px;height:200px;} .footer-grid{grid-template-columns:1fr;} .footer-meta{flex-direction:column;align-items:flex-start;}}
    @media(max-width:820px){.panic-btn{width:200px;height:200px;}}
  </style>
</head>
<body>
  <header>
    <a class="brand" href="/about">
      <img src="/images/logo.png" alt="SVS logo">
      <div class="brand-text">
      <div class="brand-name">SVS</div>
      <div class="brand-sub">Smart Verification System</div>
    </div>
  </a>
  <div class="header-right" style="display:grid;grid-template-columns:1fr auto;align-items:center;gap:.7rem;width:100%;">
      <div class="nav-links">
        <a class="nav-btn active" href="/sos">SOS</a>
        <a class="nav-btn" href="/report">Report</a>
        <a class="nav-btn" href="/about">About Us</a>
        <a class="nav-btn" href="/faq">FAQ</a>
      </div>
      <div class="main-datetime" id="sosTime">
        <svg viewBox="0 0 24 24"><path d="M6.75 3v2.25m10.5-2.25v2.25M3.75 9.75h16.5M4.5 5.25h15A1.5 1.5 0 0 1 21 6.75v12A1.5 1.5 0 0 1 19.5 20.25h-15A1.5 1.5 0 0 1 3 18.75v-12A1.5 1.5 0 0 1 4.5 5.25Z"/></svg>
        <div class="time-block"><span class="clock-text">--:--:--</span><span class="date-text">Loading...</span></div>
      </div>
    </div>
  </header>

  <main class="wrap">
    <section class="panic-strip">
      <div class="panic-eyebrow">Urgent Emergency</div>
      <button class="panic-btn" type="button" onclick="window.location.href='/report#report-form'">
        <svg viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
        <div class="panic-btn-label">PANIC SOS</div>
      </button>
      <div class="panic-card">
        <h3>One tap sends instant SOS.</h3>
        <p>Your exact location will be sent to dispatchers immediately. If GPS is weak, proceed to the full report form.</p>
      </div>
      <div class="number-pill">
        <span>Sending as:</span>
        <input id="sosNumber" type="tel" inputmode="tel" placeholder="+63 9XX XXX XXXX">
        <button type="button" onclick="saveSosNumber()">Save</button>
        <span id="sosSaved" style="color:#2563eb;"></span>
      </div>
    </section>

    <div class="list">
      <div class="card">
        <h3>1. Tap Panic</h3>
        <p>Sends your saved emergency contact plus your latest GPS fix.</p>
      </div>
      <div class="card">
        <h3>2. Stay on the line</h3>
        <p>Dispatch will call back if GPS is weak. Keep your phone nearby.</p>
      </div>
      <div class="card">
        <h3>3. If offline</h3>
        <p>Reports are queued and auto-retried when signal returns.</p>
      </div>
    </div>
  </main>
  <footer class="site-footer">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <img src="/images/logo.png" alt="SVS badge">
          <div>
            <div class="footer-tag">Emergency Reporting</div>
            <h4>Smart Verification System</h4>
          </div>
        </div>
        <div class="footer-copy">Fast and reliable citizen incident reporting with real-time dispatcher visibility and location-aware alerts.</div>
      </div>
      <div class="footer-contact">
        <h5>Contact Us</h5>
        <p>Hotline: 911</p>
        <p>Office: +63 917 000 0000</p>
        <p>Email: support@svs.local</p>
      </div>
    </div>
    <div class="footer-line"></div>
    <div class="footer-meta">
      <span>© 2026 SVS. All rights reserved.</span>
      <span>Built for easy and fast emergency reporting.</span>
    </div>
  </footer>

  <script>
    function updateTime(elId){
      const el=document.getElementById(elId); if(!el) return;
      const clock=el.querySelector('.clock-text'); const date=el.querySelector('.date-text');
      const now=new Date(); const pad=n=>String(n).padStart(2,'0'); const h24=now.getHours(); const h=h24%12||12; const ampm=h24>=12?'PM':'AM';
      clock.textContent=`${pad(h)}:${pad(now.getMinutes())}:${pad(now.getSeconds())} ${ampm}`;
      const days=['SUN','MON','TUE','WED','THU','FRI','SAT'];
      date.textContent=`${days[now.getDay()]} ${pad(now.getMonth()+1)}/${pad(now.getDate())}/${now.getFullYear()}`;
    }
    updateTime('sosTime'); setInterval(()=>updateTime('sosTime'),1000);

    function normalizePh(phone){
      if(!phone) return '';
      let p = phone.replace(/[^0-9+]/g,'');
      if(p.startsWith('0')) p = '+63' + p.slice(1);
      if(p.startsWith('63')) p = '+' + p;
      if(!p.startsWith('+63')) return '';
      return p;
    }
    function saveSosNumber(){
      const input=document.getElementById('sosNumber');
      const saved=document.getElementById('sosSaved');
      const norm=normalizePh(input.value);
      if(!norm || norm.length < 13){
        saved.textContent='Invalid PH mobile';
        saved.style.color='#b91c1c';
        return;
      }
      try{ localStorage.setItem('mdrrmo_panic', norm); }catch(_e){}
      saved.textContent=norm;
      saved.style.color='#2563eb';
      input.value=norm;
    }
    (function initSaved(){
      try{
        const n=localStorage.getItem('mdrrmo_panic')||'';
        if(n){
          document.getElementById('sosNumber').value=n;
          document.getElementById('sosSaved').textContent=n;
          document.getElementById('sosSaved').style.color='#2563eb';
        }
      }catch(_e){}
    })();
  </script>
</body>
</html>
