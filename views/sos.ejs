<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/favicon') %>
  <title>SVS - SOS</title>
  <%- include('partials/typography') %>
  <script src="https://cdn.tailwindcss.com"></script>
  <%- include('partials/public-motion-head') %>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(37,99,235,0.12),_transparent_34%),radial-gradient(circle_at_bottom_right,_rgba(239,68,68,0.14),_transparent_32%),linear-gradient(180deg,#f3f7ff_0%,#fff8ef_78%,#ffffff_100%)] text-slate-900 antialiased">
  <%- include('partials/navbar', { active: 'sos', timeId: 'sosTime' }) %>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <section class="mx-auto max-w-5xl">
      <div data-animate="zoom-in" class="overflow-hidden rounded-[2rem] border border-red-200/70 bg-[linear-gradient(145deg,#fff8f4_0%,#eef4ff_52%,#ffffff_100%)] shadow-[0_28px_70px_rgba(15,23,42,0.12)]">
        <div class="border-b border-white/70 bg-[radial-gradient(circle_at_top,_rgba(239,68,68,0.18),_transparent_42%),linear-gradient(180deg,rgba(255,255,255,0.92),rgba(255,255,255,0.72))] px-6 py-7 sm:px-8">
          <div class="inline-flex items-center gap-2 rounded-full border border-red-200 bg-white/85 px-3 py-1 font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-red-600">
            Emergency SOS
          </div>
          <div class="mt-5 grid gap-6 lg:grid-cols-[minmax(0,1fr)_220px] lg:items-center">
            <div data-animate="fade-right" style="--animate-order:0">
              <h1 class="max-w-xl text-3xl font-black leading-[1.05] tracking-tight text-slate-950 sm:text-[3.2rem]">
                Send a location-first emergency alert in one tap.
              </h1>
              <p class="mt-4 max-w-2xl text-base leading-8 text-slate-700 sm:text-lg">
                Use SOS when you need dispatch to react immediately. SVS grabs your latest GPS position, sends your saved number, and alerts responders with the fastest available location data.
              </p>
              <div class="mt-5 flex flex-wrap gap-2">
                <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">GPS-first alert</span>
                <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">Fast dispatcher callback</span>
                <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">Works with saved PH number</span>
              </div>
            </div>

            <div data-animate="fade-left" data-float style="--animate-order:1" class="mx-auto w-full max-w-[220px] rounded-[1.75rem] border border-white/80 bg-white/75 p-4 text-center shadow-[0_18px_38px_rgba(15,23,42,0.12)] backdrop-blur">
              <div class="text-sm font-black uppercase tracking-[0.22em] text-red-600">Live Status</div>
              <div id="panicStatusCard" class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-5 text-sm font-bold leading-6 text-slate-600">
                Ready to send.
              </div>
            </div>
          </div>
        </div>

        <div class="px-6 py-8 sm:px-8">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,1.08fr)_minmax(280px,320px)] lg:items-start">
            <div data-animate="fade-right" style="--animate-order:2" class="rounded-[1.8rem] border border-red-200/80 bg-[linear-gradient(180deg,#fff4f4_0%,#fffaf7_100%)] px-5 py-6 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.7),0_18px_42px_rgba(220,38,38,0.12)] sm:px-7">
              <button
                data-glow
                class="mx-auto flex h-[210px] w-[210px] items-center justify-center rounded-full border-0 bg-[linear-gradient(145deg,#ef4444,#dc2626,#b91c1c)] text-white shadow-[0_0_0_14px_rgba(220,38,38,0.08),0_18px_48px_rgba(220,38,38,0.34)] transition duration-150 hover:-translate-y-0.5 hover:shadow-[0_0_0_18px_rgba(220,38,38,0.11),0_22px_58px_rgba(220,38,38,0.42)] focus:outline-none focus:ring-4 focus:ring-red-200 disabled:cursor-not-allowed disabled:opacity-80 max-[520px]:h-[180px] max-[520px]:w-[180px]"
                type="button"
                onclick="triggerPanic()"
                id="panicBtn"
              >
                <span class="flex flex-col items-center gap-3">
                  <svg class="h-12 w-12 stroke-current" viewBox="0 0 24 24" fill="none" stroke-width="1.6">
                    <path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                  </svg>
                  <span class="panic-btn-label text-base font-black uppercase tracking-[0.3em]">PANIC SOS</span>
                </span>
              </button>

              <div class="mx-auto mt-6 max-w-xl rounded-[1.4rem] border border-blue-200/90 bg-white px-5 py-5 text-left shadow-[0_16px_34px_rgba(15,23,42,0.1)]">
                <h2 class="text-lg font-black text-slate-950">What happens after you tap</h2>
                <p class="mt-2 text-sm leading-7 text-slate-700 sm:text-base">
                  SVS attempts a live GPS fix first, then sends your emergency number and latest location data to dispatch. If GPS is weak, responders can still call the number you saved below.
                </p>
                <div id="panicStatus" data-shimmer class="mt-4 rounded-2xl border border-blue-100 bg-blue-50/80 px-4 py-3 text-sm font-extrabold text-blue-700" aria-live="polite">
                  Waiting for action.
                </div>
              </div>
            </div>

            <aside class="space-y-4">
              <div data-animate="fade-left" style="--animate-order:3" class="rounded-[1.6rem] border border-slate-200 bg-white/85 p-5 shadow-[0_16px_34px_rgba(15,23,42,0.1)]">
                <h3 class="text-lg font-black text-slate-950">Save your callback number</h3>
                <p class="mt-2 text-sm leading-7 text-slate-600">
                  Use a working Philippine mobile number so dispatch can reach you immediately if your signal drops or the GPS fix needs confirmation.
                </p>
                <div id="sosCallbackCard" class="mt-4 rounded-[1.4rem] border border-blue-200 bg-[linear-gradient(180deg,#eff6ff_0%,#ffffff_100%)] px-4 py-4 shadow-[0_12px_24px_rgba(37,99,235,0.08)]">
                  <div class="text-xs font-black uppercase tracking-[0.2em] text-blue-700">Saved callback number</div>
                  <div id="sosCallbackValue" class="mt-2 text-xl font-black tracking-tight text-slate-950">Not saved yet</div>
                  <p id="sosCallbackHint" class="mt-2 text-sm leading-7 text-slate-600">Add one active number below so dispatch can call you back fast.</p>
                </div>
                <div class="mt-4 flex flex-col gap-3">
                  <label class="text-xs font-black uppercase tracking-[0.22em] text-slate-500" for="sosNumber">Emergency contact</label>
                  <input
                    class="w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-base font-bold text-slate-900 outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-100"
                    id="sosNumber"
                    type="tel"
                    inputmode="tel"
                    pattern="[0-9+ ]{10,16}"
                    maxlength="16"
                    placeholder="+63 9XX XXX XXXX"
                  >
                  <div class="flex flex-wrap items-center gap-3">
                    <button
                      class="rounded-2xl border border-blue-600 bg-blue-600 px-5 py-3 text-sm font-black uppercase tracking-[0.18em] text-white transition hover:bg-blue-700"
                      type="button"
                      onclick="saveSosNumber()"
                    >
                      Save Number
                    </button>
                    <span id="sosSaved" class="text-sm font-bold text-blue-700"></span>
                  </div>
                  <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm leading-7 text-slate-700">
                    Keep location services on for the fastest pin. For ongoing life-threatening danger, call <span class="font-black text-slate-950">911</span> too when possible.
                  </div>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/public-motion-script') %>

  <script>
    function updateTime(elId){
      const el=document.getElementById(elId); if(!el) return;
      const clock=el.querySelector('.clock-text'); const date=el.querySelector('.date-text');
      const now=new Date(); const pad=n=>String(n).padStart(2,'0'); const h24=now.getHours(); const h=h24%12||12; const ampm=h24>=12?'PM':'AM';
      clock.textContent=`${pad(h)}:${pad(now.getMinutes())}:${pad(now.getSeconds())} ${ampm}`;
      const days=['SUN','MON','TUE','WED','THU','FRI','SAT'];
      date.textContent=`${days[now.getDay()]} ${pad(now.getMonth()+1)}/${pad(now.getDate())}/${now.getFullYear()}`;
    }
    updateTime('sosTime'); setInterval(()=>updateTime('sosTime'),1000);

    function toIntlPhone(v) {
      const digits = String(v || '').replace(/\D/g, '');
      if (/^09\d{9}$/.test(digits)) return `+63${digits.slice(1)}`;
      if (/^63\d{10}$/.test(digits)) return `+${digits}`;
      if (/^9\d{9}$/.test(digits)) return `+63${digits}`;
      return null;
    }

    function formatPhoneForDisplay(v) {
      const intl = toIntlPhone(v);
      if (!intl) {
        const digits = String(v || '').replace(/\D/g, '');
        let partial = digits;
        if (partial.startsWith('0')) partial = partial.slice(1);
        else if (partial.startsWith('63')) partial = partial.slice(2);
        partial = partial.replace(/\D/g, '').slice(0, 10);
        if (!partial) return '';
        if (partial.length <= 3) return `+63 ${partial}`;
        if (partial.length <= 6) return `+63 ${partial.slice(0, 3)} ${partial.slice(3)}`;
        return `+63 ${partial.slice(0, 3)} ${partial.slice(3, 6)} ${partial.slice(6)}`;
      }
      const local = intl.slice(3);
      return `+63 ${local.slice(0, 3)} ${local.slice(3, 6)} ${local.slice(6, 10)}`;
    }

    function normalizePh(phone){
      return toIntlPhone(phone) || '';
    }

    function saveSosNumber(){
      const input=document.getElementById('sosNumber');
      const saved=document.getElementById('sosSaved');
      const norm=normalizePh(input.value);
      if(!norm){
        saved.textContent='Invalid PH mobile (+63 9XXXXXXXXX)';
        saved.style.color='#b91c1c';
        refreshSavedNumberUi('');
        return;
      }
      try{ localStorage.setItem('mdrrmo_panic', norm); }catch(_e){}
      const pretty=formatPhoneForDisplay(norm);
      saved.textContent=pretty;
      saved.style.color='#2563eb';
      input.value=pretty;
      refreshSavedNumberUi(norm);
    }

    function refreshSavedNumberUi(value){
      const card=document.getElementById('sosCallbackCard');
      const valueEl=document.getElementById('sosCallbackValue');
      const hintEl=document.getElementById('sosCallbackHint');
      if(!card || !valueEl || !hintEl) return;
      const pretty=formatPhoneForDisplay(value);
      if(pretty){
        valueEl.textContent=pretty;
        hintEl.textContent='This is the number dispatch will use first if they need to verify your SOS.';
        card.classList.add('border-emerald-200','bg-[linear-gradient(180deg,#ecfdf3_0%,#ffffff_100%)]');
        card.classList.remove('border-blue-200','bg-[linear-gradient(180deg,#eff6ff_0%,#ffffff_100%)]');
      }else{
        valueEl.textContent='Not saved yet';
        hintEl.textContent='Add one active number below so dispatch can call you back fast.';
        card.classList.add('border-blue-200','bg-[linear-gradient(180deg,#eff6ff_0%,#ffffff_100%)]');
        card.classList.remove('border-emerald-200','bg-[linear-gradient(180deg,#ecfdf3_0%,#ffffff_100%)]');
      }
    }

    (function attachSanitizer(){
      const input=document.getElementById('sosNumber');
      if(!input) return;
      const handle=()=>{
        const formatted=formatPhoneForDisplay(input.value);
        if(formatted!==input.value) input.value=formatted;
      };
      input.addEventListener('input', handle);
      input.addEventListener('blur', handle);
      input.addEventListener('paste', evt=>{
        evt.preventDefault();
        const pasted=(evt.clipboardData||window.clipboardData).getData('text');
        input.value=formatPhoneForDisplay(pasted);
      });
    })();

    (function initSaved(){
      try{
        const stored=localStorage.getItem('mdrrmo_panic')||'';
        const norm=normalizePh(stored);
        if(norm){
          const pretty=formatPhoneForDisplay(norm);
          document.getElementById('sosNumber').value=pretty;
          document.getElementById('sosSaved').textContent=pretty;
          document.getElementById('sosSaved').style.color='#2563eb';
          refreshSavedNumberUi(norm);
        }
      }catch(_e){}
    })();

    refreshSavedNumberUi('');

    function setPanicStatus(msg, color='#2563eb'){
      const line=document.getElementById('panicStatus');
      const card=document.getElementById('panicStatusCard');
      if(line){
        line.textContent=msg;
        line.style.color=color;
      }
      if(card){
        card.textContent=msg;
        card.style.color=color;
      }
    }

    function getSavedNumber(){
      try{return localStorage.getItem('mdrrmo_panic')||'';}catch(_e){return '';}
    }

    function setPanicBtnState(state='idle'){
      const btn=document.getElementById('panicBtn');
      if(!btn) return;
      const label=btn.querySelector('.panic-btn-label');
      if(state==='sending'){
        btn.disabled=true;
        label.textContent='SENDING...';
      }else if(state==='sent'){
        btn.disabled=true;
        label.textContent='SENT!';
        setTimeout(()=>{ btn.disabled=false; label.textContent='PANIC SOS'; }, 1600);
      }else{
        btn.disabled=false;
        label.textContent='PANIC SOS';
      }
    }

    function detectGps(){
      return new Promise(resolve=>{
        if(!navigator.geolocation) return resolve({ gps:'', note:'GPS not available on this device' });
        navigator.geolocation.getCurrentPosition(
          pos => resolve({
            gps: `${pos.coords.latitude.toFixed(5)}, ${pos.coords.longitude.toFixed(5)}`,
            note: `Detected location +/-${Math.round(pos.coords.accuracy||0)}m`
          }),
          () => resolve({ gps:'', note:'Could not detect GPS - will send without location' }),
          { enableHighAccuracy:true, timeout:12000, maximumAge:0 }
        );
      });
    }

    async function triggerPanic(){
      const input=document.getElementById('sosNumber');
      const norm=normalizePh(input.value || getSavedNumber());
      if(!norm){
        setPanicStatus('Enter a valid PH mobile first (+63 9XXXXXXXXX).', '#b91c1c');
        return;
      }
      try{ localStorage.setItem('mdrrmo_panic', norm); }catch(_e){}
      input.value = formatPhoneForDisplay(norm);
      refreshSavedNumberUi(norm);
      setPanicBtnState('sending');
      setPanicStatus('Detecting location...');
      const gpsResult = await detectGps();
      if(gpsResult.note) setPanicStatus(gpsResult.note);
      try{
        const resp = await fetch('/api/panic', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ contact: norm, gps: gpsResult.gps })
        });
        const data = await resp.json().catch(()=>({}));
        if(!resp.ok){
          throw new Error(data.error || 'Could not send SOS');
        }
        try{ localStorage.setItem('svs_last_report_id', data.id || ''); }catch(_e){}
        setPanicStatus(`SOS sent ${data.id ? '('+data.id+') ' : ''}- dispatchers alerted.`, '#15803d');
        setPanicBtnState('sent');
      }catch(err){
        setPanicStatus(err && err.message ? err.message : 'Could not send SOS', '#b91c1c');
        setPanicBtnState('idle');
      }
    }
  </script>
</body>
</html>
