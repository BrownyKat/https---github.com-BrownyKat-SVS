        },
        {
          keywords: ['severity', 'low', 'medium', 'high', 'what severity'],
          answer: 'Severity helps dispatch understand urgency: Low is stable, Medium is urgent with possible escalation, and High is immediate danger to life or a rapidly worsening hazard.'
        },
        {
          keywords: ['detect gps', 'map', 'pin', 'location detect', 'find location'],
          answer: 'The report page uses a GPS-first flow. After detection, users should check whether the map pin matches the actual scene and manually correct barangay, landmark, or street details if needed.'
        },
        {
          keywords: ['emergency type', 'what type', 'fire', 'medical', 'accident', 'violence', 'incident type'],
          answer: 'Select the emergency type that best matches the situation (e.g., Fire, Medical Emergency, Traffic Accident, Violence, Natural Disaster). Dispatch prioritizes and routes your report accordingly.'
        },
        {
          keywords: ['location wrong', 'incorrect location', 'fix location', 'change location', 'adjust map'],
          answer: 'If the GPS pin is wrong, you can drag the map to the correct location or manually enter the barangay, street name, and landmark details. Accuracy helps dispatch respond faster.'
        },
        {
          keywords: ['barangay', 'street', 'landmark', 'address', 'location detail'],
          answer: 'Provide the barangay name, street or road name, and any nearby landmark (store, sign, school, etc.). These details help dispatch navigate to the exact scene if GPS is weak.'
        },
        {
          keywords: ['without gps', 'no gps', 'gps unavailable', 'offline location'],
          answer: 'Yes. You can still submit a report without GPS by providing barangay, street, and landmark details. GPS helps, but manual location details are still valid and useful for dispatch.'
        },
        {
          keywords: ['confirm phone', 'phone wrong', 'incorrect number', 'change phone'],
          answer: 'If you enter the wrong callback number, you can edit it on the Report form before submission. After submission, you cannot change it, so double-check before sending.'
        }
      ],
      track: [
        {
          keywords: ['report id', 'find my id', 'where is my id', 'last id', 'how to find id'],
          answer: 'Track needs a report ID like `RPT-0001` or `SOS-0001`. The page can also offer the last submitted ID stored on the device when one is available.'
        },
        {
          keywords: ['status meaning', 'status', 'dispatcher', 'handoff', 'timeline', 'what does status mean'],
          answer: 'Track shows the current status, the assigned dispatcher, transfer count, handoff timing, and a timeline so users can follow the latest dispatcher workflow state.'
        },
        {
          keywords: ['can i edit', 'change report', 'update report', 'modify'],
          answer: 'Tracking is read-only. It lets users review progress without changing the submitted report.'
        },
        {
          keywords: ['no update', 'status not changing', 'old status', 'refreshing'],
          answer: 'The Track page refreshes automatically to show the latest status. If it seems old, check your internet connection or try refreshing the page manually.'
        },
        {
          keywords: ['how long', 'when will they arrive', 'response time', 'eta'],
          answer: 'Response time varies by incident type, location, and available units. SVS helps get clearer information to dispatchers, but always call 911 if you need an immediate response for life-threatening situations.'
        },
        {
          keywords: ['no contact', 'not called', 'dispatcher didnt call', 'no call back'],
          answer: 'If dispatch has not called back after submission, check that your phone number is correct and your phone is working. You can also call your local hotline to provide your report ID and check progress directly.'
        }
      ],
      about: [
        {
          keywords: ['what is svs', 'about', 'purpose', 'why', 'svs help'],
          answer: 'SVS is designed to help citizens send clearer emergency reports and help responders receive better location-aware information faster, especially during stressful situations.'
        },
        {
          keywords: ['hotline', 'contact', 'numbers', 'phone', 'call'],
          answer: 'The About page includes hotline cards for local and national emergency services. Call 911 or the local hotline appropriate for your emergency type.'
        },
        {
          keywords: ['mdrrmo', 'bfp', 'pnp', 'ambulance', 'fire', 'police'],
          answer: 'The About page lists verified hotline numbers for MDRRMO (disaster management), BFP (fire), PNP (police), and emergency ambulance services. Use the relevant number based on your emergency type.'
        },
        {
          keywords: ['disaster', 'hazard', 'flood', 'earthquake', 'fire', 'landslide', 'typhoon', 'preparedness'],
          answer: 'The About page includes disaster safety guides that explain different hazards and what to do before, during, and after each type of event.'
        },
        {
          keywords: ['evacuation', 'go bag', 'emergency kit', 'what to bring', 'supplies'],
          answer: 'The About page includes disaster preparedness guides. A practical go bag should include water, non-perishable food, a flashlight, batteries, first aid kit, medicines, clothes, and important documents in a waterproof pouch.'
        },
        {
          keywords: ['safety', 'survival', 'emergency prep', 'prepare', 'ready'],
          answer: 'The About page has quick disaster readiness tips and local hotlines. Before an emergency strikes, review hazard guides and keep important numbers saved.'
        }
      ],
      faq: [
        {
          keywords: ['how do i report an emergency', 'report an emergency', 'report incident', 'submit report'],
          answer: 'To report an emergency, go to the Report page and provide the incident details, location, and a working contact number. That helps SVS collect clearer reports and reduce prank submissions.'
        },
        {
          keywords: ['why do i need to verify my phone number', 'why verify phone number', 'why verify my number', 'phone verification'],
          answer: 'A verified or working contact number helps the system reduce fake reports and gives dispatch a way to call back if they need to confirm urgent information or clarify the situation.'
        },
        {
          keywords: ['what happens after i submit a report', 'after i submit a report', 'what happens after submission', 'next step after report'],
          answer: 'Once a report is submitted, it is sent into the dispatcher workflow and can be followed through the Track page using the report ID shown after submission.'
        },
        {
          keywords: ['without gps', 'no gps', 'gps unavailable', 'submit without location'],
          answer: 'Yes. Users can still submit a report without GPS by providing barangay, street, and landmark details. GPS helps, but manual location details are still valid and useful.'
        },
        {
          keywords: ['feedback', 'suggestion', 'improve', 'form', 'feature request'],
          answer: 'The FAQ page includes a feedback form for short, specific product suggestions or pain points so the team can improve unclear parts of the experience.'
        },
        {
          keywords: ['prank', 'fake', 'low quality', 'false alarm'],
          answer: 'SVS reduces low-quality reports by encouraging structured fields, contact validation, location capture, optional photos, and dispatcher review.'
        },
        {
          keywords: ['nearest evacuation center', 'evacuation center', 'go bag', 'hotlines for mapandan', 'disaster', 'safety'],
          answer: 'For evacuation guidance, hotlines, and disaster preparedness, the About page is the best current reference in this app. It includes local hotline cards and disaster-readiness information users can review quickly.',
          links: [
            { href: '/about', label: 'Open About page' }
          ]
        },
        {
          keywords: ['when should i use sos', 'sos vs report', 'difference', 'which one'],
          answer: 'Use SOS for immediate dangers when you need the fastest alert possible. Use Report when it is safer to take time and provide detailed incident information. When uncertain, SOS is always appropriate for genuine emergencies.'
        },
        {
          keywords: ['what about privacy', 'data', 'security', 'who sees my info'],
          answer: 'SVS collects your location and phone number only to get help to you faster. Only authorized dispatch staff see this information to respond appropriately to your emergency.'
        },
        {
          keywords: ['contact number wrong', 'wrong phone', 'incorrect callback number'],
          answer: 'If you realize your phone number is wrong, you can edit it on the SOS or Report form before submission. After submission, contact your local hotline with your report ID to update your information.'
        }
      ]
    };

    function normalize(text) {
      return String(text || '')
        .toLowerCase()
        .replace(/[^a-z0-9+ ]+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function tokenize(text) {
      return normalize(text)
        .split(' ')
        .map(part => part.trim())
        .filter(part => part && part.length > 1);
    }

    function matchesAnyKeyword(message, keywords) {
      const normalized = normalize(message);
      return keywords.some(keyword => normalized.includes(normalize(keyword)));
    }

    function findSocialReply(message) {
      if (matchesAnyKeyword(message, ['thank you', 'thanks', 'ty', 'salamat', 'appreciate it'])) {
        return {
          answer: 'You are very welcome. I am glad I could help, and you can always come back whenever you need guidance.'
        };
      }

      if (matchesAnyKeyword(message, ['bye', 'goodbye', 'see you', 'talk later', 'farewell'])) {
        return {
          answer: 'Take care. You can always come back here anytime you need help or have more questions.'
        };
      }

      if (matchesAnyKeyword(message, ['hello', 'hi', 'hey', 'good morning', 'good afternoon', 'good evening'])) {
        return {
          answer: `Hello. I am here to help with ${pageLabel}, and you can ask me anytime if you need a quick guide.`
        };
      }

      return null;
    }

    function addMessage(role, text, links = []) {
      const item = document.createElement('div');
      item.className = `svs-chatbot__message svs-chatbot__message--${role}`;
      item.textContent = text;

      if (Array.isArray(links) && links.length) {
        const linkWrap = document.createElement('div');
        linkWrap.className = 'svs-chatbot__message-links';
        links.forEach(link => {
          const a = document.createElement('a');
          a.href = link.href;
          a.textContent = link.label;
          linkWrap.appendChild(a);
        });
        item.appendChild(linkWrap);
      }

      messages.appendChild(item);
      messages.scrollTop = messages.scrollHeight;
    }

    function scoreEntry(message, entry) {
      const normalized = normalize(message);
      const messageTokens = tokenize(message);
      return (entry.keywords || []).reduce((score, keyword) => {
        const normalizedKeyword = normalize(keyword);
        if (!normalizedKeyword) return score;

        if (normalized.includes(normalizedKeyword)) {
          return score + Math.max(3, normalizedKeyword.split(' ').length * 2);
        }

        const keywordTokens = tokenize(keyword);
        if (!keywordTokens.length) return score;

        const matchedTokens = keywordTokens.filter(token =>
          messageTokens.some(messageToken =>
            messageToken === token ||
            messageToken.includes(token) ||
            token.includes(messageToken)
          )
        );

        if (!matchedTokens.length) return score;
        return score + matchedTokens.length;
      }, 0);
    }

    function findAnswer(message) {
      const socialReply = findSocialReply(message);
      if (socialReply) return socialReply;

      const entries = [...sharedEntries, ...((pageEntries[context] || []))];
      let best = null;
      let bestScore = 0;

      entries.forEach(entry => {
        const score = scoreEntry(message, entry);
        if (score > bestScore) {
          bestScore = score;
          best = entry;
        }
      });

      if (best && bestScore >= 2) return best;

      return {
        answer: `I am not fully sure I understood that one yet. Try asking in a shorter way about ${pageLabel}, or ask about GPS, report IDs, callback numbers, severity, hotlines, evacuation guidance, weather alerts, or whether SOS or Report is the better option. If still unsure, please call a local hotline (or 911 for imminent danger) using numbers listed on About.`,
        links: [
          { href: '/faq', label: 'View FAQ' },
          { href: '/about', label: 'About SVS' }
        ]
      };
    }

    function ask(question) {
      const trimmed = String(question || '').trim();
      if (!trimmed) return;
      addMessage('user', trimmed);
      const match = findAnswer(trimmed);
      window.setTimeout(() => addMessage('bot', match.answer, match.links || []), 140);
    }

    function setOpen(nextOpen) {
      root.classList.toggle('is-open', nextOpen);
      launcher.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
      if (nextOpen) {
        input.focus();
      } else {
        launcher.focus();
      }
    }

    prompts.forEach(prompt => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'svs-chatbot__prompt';
      btn.textContent = prompt;
      btn.addEventListener('click', () => ask(prompt));
      promptsWrap.appendChild(btn);
    });

    addMessage('bot', `I’m the SVS help assistant for ${pageLabel}. Ask me what this page does, what details are needed, or where to go next.`);

    launcher.addEventListener('click', () => setOpen(!root.classList.contains('is-open')));
    closeBtn.addEventListener('click', () => setOpen(false));

    form.addEventListener('submit', event => {
      event.preventDefault();
      const value = input.value;
      input.value = '';
      ask(value);
    });

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape' && root.classList.contains('is-open')) setOpen(false);
    });
  })();
</script>
