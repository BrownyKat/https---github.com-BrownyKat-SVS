<%
  const chatbotContextValue = typeof chatbotContext === 'string' && chatbotContext ? chatbotContext : 'general';
  const chatbotPageLabelValue = typeof chatbotPageLabel === 'string' && chatbotPageLabel ? chatbotPageLabel : 'this page';
  const chatbotPromptsValue = Array.isArray(chatbotPrompts) && chatbotPrompts.length
    ? chatbotPrompts
    : [
        'How do I use this page?',
        'What should I do if I am not sure what to enter?',
        'When should I use SOS instead?',
      ];
%>

<section
  id="svsChatbot"
  class="svs-chatbot"
  data-context="<%= chatbotContextValue %>"
  data-page-label="<%= chatbotPageLabelValue %>"
>
  <style>
    .svs-chatbot{
      position:fixed;
      right:1rem;
      bottom:1rem;
      z-index:70;
      font-family:inherit;
    }
    .svs-chatbot.is-open{
      width:min(24rem,calc(100vw - 1.5rem));
    }
    .svs-chatbot__launcher{
      display:inline-flex;
      align-items:center;
      gap:.75rem;
      border:1px solid rgba(249,115,22,.35);
      border-radius:999px;
      background:linear-gradient(135deg,#f97316,#dc2626);
      color:#fff;
      box-shadow:0 20px 42px rgba(220,38,38,.28);
      cursor:pointer;
      padding:.85rem 1rem;
      transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }
    .svs-chatbot__launcher:hover,
    .svs-chatbot__launcher:focus-visible{
      transform:translateY(-1px);
      box-shadow:0 24px 50px rgba(220,38,38,.34);
      outline:none;
    }
    .svs-chatbot__launcher-badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:2.65rem;
      height:2.65rem;
      border-radius:999px;
      background:linear-gradient(135deg,#facc15,#f97316);
      border:1px solid rgba(255,255,255,.22);
      flex-shrink:0;
      color:#1f2937;
    }
    .svs-chatbot__launcher-copy{
      min-width:0;
      text-align:left;
    }
    .svs-chatbot__launcher-copy strong{
      display:block;
      font-size:.92rem;
      font-weight:900;
      letter-spacing:.01em;
    }
    .svs-chatbot__launcher-copy span{
      display:block;
      margin-top:.12rem;
      font-size:.72rem;
      color:rgba(255,255,255,.92);
      line-height:1.35;
    }
    .svs-chatbot__panel{
      position:fixed;
      right:1rem;
      bottom:1rem;
      width:min(24rem,calc(100vw - 1.5rem));
      max-height:calc(100dvh - var(--header-h, 88px) - 1.5rem - 1rem);
      display:none;
      flex-direction:column;
      overflow:hidden;
      border:1px solid rgba(249,115,22,.8);
      border-radius:1.8rem;
      background:linear-gradient(180deg,#fff7ed 0%,#ffedd5 45%,#fef3c7 100%);
      box-shadow:0 28px 72px rgba(120,55,0,.22);
      backdrop-filter:blur(18px);
    }
    .svs-chatbot.is-open .svs-chatbot__launcher{display:none;}
    .svs-chatbot.is-open .svs-chatbot__panel{display:flex;}
    .svs-chatbot__header{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:1rem;
      padding:1rem 1rem .8rem;
      border-bottom:1px solid rgba(249,115,22,.35);
      background:linear-gradient(180deg,rgba(249,115,22,.14),rgba(255,255,255,.92));
    }
    .svs-chatbot__eyebrow{
      font-size:.68rem;
      font-weight:900;
      letter-spacing:.18em;
      text-transform:uppercase;
      color:#c2410c;
    }
    .svs-chatbot__title{
      margin-top:.35rem;
      font-size:1rem;
      font-weight:900;
      color:#7c2d12;
    }
    .svs-chatbot__subtitle{
      margin-top:.25rem;
      font-size:.78rem;
      line-height:1.5;
      color:#92400e;
    }
    .svs-chatbot__icon-btn{
      border:1px solid rgba(226,232,240,.9);
      background:#fff;
      color:#7c2d12;
      width:2rem;
      height:2rem;
      border-radius:999px;
      font-weight:900;
      cursor:pointer;
      flex-shrink:0;
    }
    .svs-chatbot__body{
      padding:1rem;
      background:linear-gradient(180deg,rgba(255,255,255,.95),rgba(255,247,237,.97));
      display:flex;
      flex:1;
      min-height:0;
      flex-direction:column;
    }
    .svs-chatbot__messages{
      flex:1;
      min-height:0;
      overflow:auto;
      display:flex;
      flex-direction:column;
      gap:.75rem;
      padding-right:.2rem;
    }
    .svs-chatbot__message{
      max-width:92%;
      border-radius:1.15rem;
      padding:.8rem .95rem;
      font-size:.88rem;
      line-height:1.6;
      white-space:pre-wrap;
      word-break:break-word;
    }
    .svs-chatbot__message--bot{
      align-self:flex-start;
      background:#fff4e6;
      border:1px solid rgba(251,146,60,.32);
      color:#7c2d12;
      box-shadow:0 10px 24px rgba(120,55,0,.08);
    }
    .svs-chatbot__message--user{
      align-self:flex-end;
      background:linear-gradient(135deg,#f97316,#dc2626);
      color:#fff;
      box-shadow:0 14px 28px rgba(220,38,38,.22);
    }
    .svs-chatbot__message-links{
      display:flex;
      flex-wrap:wrap;
      gap:.45rem;
      margin-top:.7rem;
    }
    .svs-chatbot__message-links a{
      display:inline-flex;
      align-items:center;
      border:1px solid rgba(249,115,22,.85);
      border-radius:999px;
      background:#ffedd5;
      padding:.38rem .72rem;
      font-size:.76rem;
      font-weight:800;
      color:#c2410c;
      text-decoration:none;
    }
    .svs-chatbot__prompts{
      display:flex;
      flex-wrap:wrap;
      gap:.55rem;
      margin-top:.9rem;
    }
    .svs-chatbot__prompt{
      border:1px solid rgba(249,115,22,.9);
      border-radius:999px;
      background:#fff2dd;
      color:#b45309;
      padding:.45rem .8rem;
      font-size:.74rem;
      font-weight:800;
      cursor:pointer;
    }
    .svs-chatbot__composer{
      display:flex;
      gap:.6rem;
      margin-top:.95rem;
    }
    .svs-chatbot__input{
      flex:1;
      min-width:0;
      border:1px solid rgba(196,78,12,.45);
      border-radius:1rem;
      background:#fff;
      color:#1f2937;
      padding:.8rem .9rem;
      font-size:.86rem;
      outline:none;
    }
    .svs-chatbot__input:focus{
      border-color:#f97316;
      box-shadow:0 0 0 4px rgba(249,115,22,.2);
    }
    .svs-chatbot__send{
      border:0;
      border-radius:1rem;
      background:#c2410c;
      color:#fff;
      padding:.8rem 1rem;
      font-size:.8rem;
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
      cursor:pointer;
    }
    .svs-chatbot__send:hover,
    .svs-chatbot__send:focus-visible{
      background:#ea580c;
      outline:none;
    }
    .svs-chatbot__footnote{
      margin-top:.75rem;
      font-size:.72rem;
      line-height:1.5;
      color:#92400e;
    }
    @media (max-width: 640px){
      .svs-chatbot{right:.75rem;bottom:.75rem;}
      .svs-chatbot.is-open{
        width:calc(100vw - 1.5rem);
      }
      .svs-chatbot__launcher-copy span{display:none;}
      .svs-chatbot__panel{
        right:.75rem;
        left:.75rem;
        bottom:.75rem;
        width:auto;
        max-height:calc(100dvh - var(--header-h, 88px) - 1.5rem);
      }
    }
  </style>

  <button
    type="button"
    class="svs-chatbot__launcher"
    aria-expanded="false"
    aria-controls="svsChatbotPanel"
  >
    <span class="svs-chatbot__launcher-badge" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.9">
        <path d="M12 4.5c-4.136 0-7.5 3.364-7.5 7.5S7.864 19.5 12 19.5 19.5 16.136 19.5 12 16.136 4.5 12 4.5Z"/>
        <path d="M12 8.5v4.5" stroke-linecap="round"/>
        <path d="M12 15.5h.01" stroke-linecap="round"/>
      </svg>
    </span>
    <span class="svs-chatbot__launcher-copy">
      <strong>MDRRMO Help</strong>
      <span>Ask about <%= chatbotPageLabelValue %></span>
    </span>
  </button>

  <div id="svsChatbotPanel" class="svs-chatbot__panel" role="dialog" aria-modal="false" aria-label="MDRRMO help chatbot">
    <div class="svs-chatbot__header">
      <div>
        <div class="svs-chatbot__eyebrow">MDRRMO Assistant</div>
        <div class="svs-chatbot__title">Questions about <%= chatbotPageLabelValue %>?</div>
        <p class="svs-chatbot__subtitle">This MDRRMO helper gives fast guidance for the current page and emergency procedures.</p>
      </div>
      <button type="button" class="svs-chatbot__icon-btn" data-chatbot-close aria-label="Close assistant">×</button>
    </div>

    <div class="svs-chatbot__body">
      <div class="svs-chatbot__messages" aria-live="polite" aria-label="Chat messages"></div>
      <div class="svs-chatbot__prompts"></div>
      <form class="svs-chatbot__composer">
        <input class="svs-chatbot__input" type="text" maxlength="180" placeholder="Ask a question..." aria-label="Ask the chatbot a question">
        <button class="svs-chatbot__send" type="submit">Ask</button>
      </form>
      <p class="svs-chatbot__footnote">For active danger or life-threatening emergencies, users should still use `SOS` and call `911` when possible. MDRRMO guidance is supplemental and not a substitute for immediate response.</p>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.getElementById('svsChatbot');
    if (!root || root.dataset.bound === '1') return;
    root.dataset.bound = '1';

    const launcher = root.querySelector('.svs-chatbot__launcher');
    const panel = root.querySelector('.svs-chatbot__panel');
    const closeBtn = root.querySelector('[data-chatbot-close]');
    const messages = root.querySelector('.svs-chatbot__messages');
    const promptsWrap = root.querySelector('.svs-chatbot__prompts');
    const form = root.querySelector('.svs-chatbot__composer');
    const input = root.querySelector('.svs-chatbot__input');
    const context = root.dataset.context || 'general';
    const pageLabel = root.dataset.pageLabel || 'this page';
    const prompts = <%- JSON.stringify(chatbotPromptsValue) %>;

    const sharedEntries = [
      {
        keywords: ['sos', 'panic', 'urgent', 'immediate', 'life threat', 'danger'],
        answer: 'Use SOS when there is immediate danger and you need the fastest alert. The report form is better when it is safe to provide more details first.',
        links: [
          { href: '/sos', label: 'Open SOS' },
          { href: '/report', label: 'Open Report' }
        ]
      },
      {
        keywords: ['report id', 'tracking', 'track', 'follow up', 'status', 'check progress'],
        answer: 'After a successful SOS or report submission, SVS stores the latest report ID locally and you can also use the ID shown on screen to check progress in Track.',
        links: [
          { href: '/track', label: 'Track a report' }
        ]
      },
      {
        keywords: ['gps', 'location', 'barangay', 'landmark', 'street', 'pinpoint'],
        answer: 'SVS works best with GPS plus clear location details like barangay, landmark, and street notes. If GPS is weak, manual details still help dispatch find the scene faster.'
      },
      {
        keywords: ['911', 'hotline', 'call', 'emergency number', 'phone'],
        answer: 'For life-threatening emergencies, users should still call 911 when possible even if they also use SVS.'
      },
      {
        keywords: ['helpline', 'hotlines', 'contact hotline', 'contact numbers', 'who do i call', 'need assistance', 'phone number'],
        answer: 'Use the About page for verified local hotline numbers (e.g., MDRRMO, BFP, PNP, ambulance). In any urgent, unclear situation, also call 911 right away.',
        links: [
          { href: '/about', label: 'View hotline list' }
        ]
      },
      {
        keywords: ['internet', 'wifi', 'data', 'connection', 'network', 'offline', 'no signal', 'available offline', 'works offline', 'without internet'],
        answer: 'SVS requires an internet connection to send alerts initially. However, if your connection drops during submission, reports can be queued locally and will retry automatically when connection is restored. For immediate danger, call 911 directly.'
      },
      {
        keywords: ['mobile data', 'phone carrier', 'signal', 'connectivity'],
        answer: 'SVS works with mobile data (3G, 4G, 5G, LTE) and WiFi. Make sure your internet connection is working before sending a critical alert.'
      },
      {
        keywords: ['response time', 'how long', 'when will help arrive', 'how fast'],
        answer: 'Response time depends on the incident type, location, and available responder units. SVS helps get clearer location and incident data to dispatchers faster, but always call 911 as well for the most urgent situations.'
      },
      { 
        keywords: ['prank', 'false alarm', 'not real', 'fake emergency'],
        answer: 'Prank or false reports waste critical resources and can result in penalties. SVS reduces false reports through phone verification and dispatcher review. Always submit only genuine emergencies.'
      },
      {
        keywords: ['contact number', 'callback', 'phone number', 'mobile number', 'why number'],
        answer: 'A working contact number helps SVS verify reports and gives dispatch a way to call back if they need to confirm urgent details or clarify the scene. It also helps reduce false reports.'
      }
    ];

    const pageEntries = {
      sos: [
        {
          keywords: ['callback', 'contact', 'phone', 'number', 'save', 'dial'],
          answer: 'On SOS, the saved callback number should be a working Philippine mobile number. Dispatch uses that number first if they need to verify the emergency or if GPS is incomplete.'
        },
        {
          keywords: ['send sos', 'tap', 'button', 'panic sos', 'press', 'activate'],
          answer: 'Tapping the PANIC SOS button tries to get a live GPS fix first, then posts the alert to dispatch with the saved callback number and the best available location.'
        },
        {
          keywords: ['invalid', 'ph mobile', '+63', 'format', 'wrong number'],
          answer: 'The SOS page accepts Philippine mobile formats that normalize to `+63 9XXXXXXXXX`. If the number is invalid, save a valid mobile number first before sending.'
        },
        {
          keywords: ['gps taking time', 'acquiring gps', 'gps slow', 'location slow', 'gps delay'],
          answer: 'GPS can take a few seconds to acquire a fix, especially indoors or with poor sky view. You can still send SOS even if GPS is still acquiring — dispatch will use the last known location plus your callback number.'
        },
        {
          keywords: ['gps fail', 'gps not working', 'no location', 'cant get location'],
