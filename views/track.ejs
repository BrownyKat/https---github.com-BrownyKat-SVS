<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/favicon') %>
  <title>SVS - Track Report</title>
  <%- include('partials/typography') %>
  <script src="https://cdn.tailwindcss.com"></script>
  <%- include('partials/public-motion-head') %>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(37,99,235,0.11),_transparent_34%),radial-gradient(circle_at_bottom_right,_rgba(239,68,68,0.11),_transparent_30%),linear-gradient(180deg,#f3f8ff_0%,#fff7ef_82%,#ffffff_100%)] text-slate-900 antialiased">
  <%- include('partials/navbar', { active: 'track', timeId: 'trackTime' }) %>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <section data-animate="zoom-in" class="overflow-hidden rounded-[2.2rem] border border-slate-200/80 bg-[linear-gradient(145deg,rgba(255,255,255,0.95),rgba(236,244,255,0.92))] shadow-[0_28px_70px_rgba(15,23,42,0.12)]">
      <div class="grid gap-8 px-6 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-center">
        <div data-animate="fade-right" style="--animate-order:0">
          <div class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-white/90 px-3 py-1 font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-blue-700">
            Track Report
          </div>
          <h1 class="mt-5 max-w-3xl text-3xl font-black leading-[1.02] tracking-tight text-slate-950 sm:text-[3.35rem]">
            See your report progress without guessing what happens next.
          </h1>
          <p class="mt-5 max-w-3xl text-base leading-8 text-slate-700 sm:text-lg">
            Enter your report ID to check its current status, the dispatcher currently handling it, the time passed since submission, and the location tied to the report.
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="rounded-full border border-blue-200 bg-blue-50 px-3 py-1.5 text-sm font-black text-blue-700">Report ID lookup</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">Live status</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">Current dispatcher</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700">Location summary</span>
          </div>
        </div>

        <div data-animate="fade-left" style="--animate-order:1" class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)] backdrop-blur">
          <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-slate-500">Search</div>
          <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950">Enter your report ID</h2>
          <p class="mt-3 text-sm leading-7 text-slate-700 sm:text-base">
            Use the ID shown after submission, such as <span class="font-black text-blue-700">RPT-0001</span> or <span class="font-black text-red-600">SOS-0001</span>.
          </p>

          <form id="trackForm" class="mt-5 space-y-4">
            <div>
              <label class="mb-2 block text-xs font-black uppercase tracking-[0.22em] text-slate-500" for="trackIdInput">Report ID</label>
              <input
                id="trackIdInput"
                name="reportId"
                type="text"
                value="<%= initialId %>"
                maxlength="32"
                autocomplete="off"
                placeholder="RPT-0001"
                class="w-full rounded-[1.4rem] border border-slate-300 bg-white px-4 py-4 text-base font-black uppercase tracking-[0.08em] text-slate-900 outline-none transition focus:border-blue-400 focus:ring-4 focus:ring-blue-100"
              >
            </div>
            <button data-shimmer class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-slate-900 px-5 py-3 text-sm font-black uppercase tracking-[0.18em] text-white transition hover:-translate-y-0.5" type="submit">
              Track progress
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </button>
          </form>

          <button id="useLastIdBtn" class="mt-4 hidden w-full rounded-2xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm font-black uppercase tracking-[0.16em] text-blue-700 transition hover:border-blue-300 hover:bg-blue-100" type="button">
            Use last submitted ID
          </button>
          <p id="trackLookupHint" class="mt-4 text-sm leading-7 text-slate-500">
            Tracking is read-only and will not change your report.
          </p>
        </div>
      </div>
    </section>

    <section id="trackIdleState" data-animate="fade-up" style="--animate-order:2" class="mt-8 rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)] sm:p-8">
      <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-blue-700">Waiting for lookup</div>
      <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950 sm:text-3xl">Enter a report ID to load the progress view.</h2>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-700 sm:text-base">
        Once a valid report ID is entered, this page will show the current status, the dispatcher handling the case, the location summary, and how much time has passed since submission.
      </p>
    </section>

    <div id="trackErrorState" class="mt-8 hidden rounded-[1.8rem] border border-red-200 bg-red-50 px-5 py-4 text-sm font-bold text-red-700 shadow-[0_14px_28px_rgba(239,68,68,0.08)]"></div>

    <section id="trackResult" class="mt-8 hidden space-y-6">
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <article data-animate="fade-up" style="--animate-order:0" class="rounded-[1.7rem] border border-slate-200 bg-white/90 p-5 shadow-[0_18px_38px_rgba(15,23,42,0.1)]">
          <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Report ID</div>
          <div id="trackReportId" class="mt-3 text-2xl font-black tracking-tight text-slate-950">-</div>
          <p class="mt-3 text-sm leading-7 text-slate-600">Use this ID for future follow-up and status checks.</p>
        </article>

        <article data-animate="fade-up" style="--animate-order:1" class="rounded-[1.7rem] border border-slate-200 bg-white/90 p-5 shadow-[0_18px_38px_rgba(15,23,42,0.1)]">
          <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Current Status</div>
          <div id="trackStatusWrap" class="mt-3 inline-flex rounded-full border px-3 py-1.5 text-sm font-black uppercase tracking-[0.16em]">
            <span id="trackStatus">-</span>
          </div>
          <p class="mt-3 text-sm leading-7 text-slate-600">Status updates reflect the latest dispatcher workflow state.</p>
        </article>

        <article data-animate="fade-up" style="--animate-order:2" class="rounded-[1.7rem] border border-slate-200 bg-white/90 p-5 shadow-[0_18px_38px_rgba(15,23,42,0.1)]">
          <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Current Dispatcher</div>
          <div id="trackDispatcher" class="mt-3 text-2xl font-black tracking-tight text-slate-950">-</div>
          <div id="trackDispatcherUser" class="mt-2 text-sm font-bold uppercase tracking-[0.16em] text-blue-700">-</div>
          <p class="mt-3 text-sm leading-7 text-slate-600">If the report is reassigned, this card shows the latest dispatcher handling it.</p>
        </article>

        <article data-animate="fade-up" style="--animate-order:3" class="rounded-[1.7rem] border border-slate-200 bg-white/90 p-5 shadow-[0_18px_38px_rgba(15,23,42,0.1)]">
          <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Time Passed</div>
          <div id="trackElapsed" class="mt-3 text-2xl font-black tracking-tight text-slate-950">-</div>
          <div id="trackSubmittedAt" class="mt-2 text-sm font-semibold text-slate-500">-</div>
          <p class="mt-3 text-sm leading-7 text-slate-600">This timer updates in real time based on the original report timestamp.</p>
        </article>
      </div>

      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)]">
        <section data-animate="fade-up" style="--animate-order:4" class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#eff6ff_0%,#ffffff_100%)] p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)] sm:p-8">
          <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-blue-700">Location</div>
          <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950">Reported location</h2>
          <div id="trackLocation" class="mt-4 rounded-[1.5rem] border border-slate-200 bg-white px-5 py-5 text-base font-black leading-8 text-slate-950 shadow-[0_12px_24px_rgba(15,23,42,0.08)]">
            -
          </div>
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            <div class="rounded-[1.3rem] border border-slate-200 bg-white px-4 py-4">
              <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Barangay</div>
              <div id="trackBarangay" class="mt-2 text-sm font-bold leading-7 text-slate-800">-</div>
            </div>
            <div class="rounded-[1.3rem] border border-slate-200 bg-white px-4 py-4">
              <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Landmark / Street</div>
              <div id="trackLandmarkStreet" class="mt-2 text-sm font-bold leading-7 text-slate-800">-</div>
            </div>
          </div>
        </section>

        <aside class="space-y-6">
          <section data-animate="fade-up" style="--animate-order:5" class="rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)]">
            <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-red-600">Handling</div>
            <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950">Dispatcher activity</h2>
            <div class="mt-4 space-y-4">
              <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 px-4 py-4">
                <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Current dispatcher</div>
                <div id="trackHandlingName" class="mt-2 text-lg font-black text-slate-950">Waiting for dispatcher</div>
              </div>
              <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 px-4 py-4">
                <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Transfer count</div>
                <div id="trackPassCount" class="mt-2 text-lg font-black text-slate-950">0</div>
              </div>
              <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 px-4 py-4">
                <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">Last handoff</div>
                <div id="trackLastPassed" class="mt-2 text-sm font-bold leading-7 text-slate-800">No reassignment yet.</div>
              </div>
            </div>
          </section>

          <section data-animate="fade-up" style="--animate-order:6" class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#f8fbff_0%,#ffffff_100%)] p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)]">
            <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-blue-700">Timeline</div>
            <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950">Progress timeline</h2>
            <ol id="trackTimeline" class="mt-4 space-y-3"></ol>
          </section>

          <section data-animate="fade-up" style="--animate-order:7" class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#fff8ef_0%,#ffffff_100%)] p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)]">
            <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-amber-600">Report info</div>
            <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950">Submitted details</h2>
            <div class="mt-4 space-y-3 text-sm leading-7 text-slate-700">
              <div class="rounded-[1.4rem] border border-slate-200 bg-white px-4 py-3">
                <span class="font-black text-slate-950">Reporter:</span>
                <span id="trackReporterName">-</span>
              </div>
              <div class="rounded-[1.4rem] border border-slate-200 bg-white px-4 py-3">
                <span class="font-black text-slate-950">Type:</span>
                <span id="trackEmergencyType">-</span>
              </div>
              <div class="rounded-[1.4rem] border border-slate-200 bg-white px-4 py-3">
                <span class="font-black text-slate-950">GPS:</span>
                <span id="trackGps">Not available</span>
              </div>
            </div>
          </section>
        </aside>
      </div>
    </section>
  </main>

  <%- include('partials/help-chatbot', {
    chatbotContext: 'track',
    chatbotPageLabel: 'Track Report',
    chatbotPrompts: [
      'Where do I get my report ID?',
      'What does the status here mean?',
      'Can I edit a report from this page?'
    ]
  }) %>
  <%- include('partials/footer') %>
  <%- include('partials/public-motion-script') %>

  <script>
    const INITIAL_TRACK_ID = <%- JSON.stringify(initialId || '') %>;
    const TRACK_STORAGE_KEY = 'svs_last_report_id';
    const trackState = { report: null };

    function updateTime(elId){
      const el=document.getElementById(elId); if(!el) return;
      const clock=el.querySelector('.clock-text'); const date=el.querySelector('.date-text');
      const now=new Date(); const pad=n=>String(n).padStart(2,'0'); const h24=now.getHours(); const h=h24%12||12; const ampm=h24>=12?'PM':'AM';
      clock.textContent=`${pad(h)}:${pad(now.getMinutes())}:${pad(now.getSeconds())} ${ampm}`;
      const days=['SUN','MON','TUE','WED','THU','FRI','SAT'];
      date.textContent=`${days[now.getDay()]} ${pad(now.getMonth()+1)}/${pad(now.getDate())}/${now.getFullYear()}`;
    }
    updateTime('trackTime'); setInterval(()=>updateTime('trackTime'),1000);

    function normalizeTrackId(value){
      return String(value || '').trim().toUpperCase().replace(/\s+/g, '');
    }

    function formatDateTime(value){
      if (!value) return 'Time unavailable';
      const dt = new Date(value);
      if (Number.isNaN(dt.getTime())) return 'Time unavailable';
      return dt.toLocaleString([], {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
      });
    }

    function formatElapsed(value){
      if (!value) return 'Just now';
      const started = new Date(value).getTime();
      if (!Number.isFinite(started)) return 'Just now';
      const diffMs = Math.max(0, Date.now() - started);
      const totalMinutes = Math.floor(diffMs / 60000);
      const totalHours = Math.floor(totalMinutes / 60);
      const totalDays = Math.floor(totalHours / 24);
      const minutes = totalMinutes % 60;
      const hours = totalHours % 24;

      if (totalDays > 0) return `${totalDays}d ${hours}h ${minutes}m`;
      if (totalHours > 0) return `${totalHours}h ${minutes}m`;
      return `${Math.max(0, totalMinutes)}m`;
    }

    function setStatusTone(status){
      const wrap = document.getElementById('trackStatusWrap');
      const tones = {
        new: 'border-blue-200 bg-blue-50 text-blue-700',
        verifying: 'border-amber-200 bg-amber-50 text-amber-700',
        dispatched: 'border-red-200 bg-red-50 text-red-700',
        resolved: 'border-emerald-200 bg-emerald-50 text-emerald-700',
        'false-report': 'border-slate-300 bg-slate-100 text-slate-700',
      };
      wrap.className = `mt-3 inline-flex rounded-full border px-3 py-1.5 text-sm font-black uppercase tracking-[0.16em] ${tones[status] || tones.new}`;
    }

    function buildTrackTimeline(report){
      const items = [];
      items.push({
        label: 'Report submitted',
        detail: report.reporterName ? `Filed by ${report.reporterName}` : 'Submission received',
        time: report.submittedAt,
        tone: 'blue',
      });
      if (report.assignedAt) {
        items.push({
          label: 'Dispatcher assigned',
          detail: report.currentDispatcher || 'Dispatcher handling started',
          time: report.assignedAt,
          tone: 'amber',
        });
      }
      if (report.lastPassedAt) {
        items.push({
          label: 'Report passed',
          detail: report.lastPassedBy || 'Dispatcher handoff recorded',
          time: report.lastPassedAt,
          tone: 'red',
        });
      }
      items.push({
        label: 'Current status',
        detail: report.statusLabel || 'Status updated',
        time: report.lastPassedAt || report.assignedAt || report.submittedAt,
        tone: report.status === 'resolved' ? 'emerald' : report.status === 'dispatched' ? 'red' : 'blue',
      });
      return items;
    }

    function renderTrackTimeline(report){
      const timeline = document.getElementById('trackTimeline');
      if (!timeline) return;
      const toneClasses = {
        blue: 'border-blue-200 bg-blue-50 text-blue-700',
        amber: 'border-amber-200 bg-amber-50 text-amber-700',
        red: 'border-red-200 bg-red-50 text-red-700',
        emerald: 'border-emerald-200 bg-emerald-50 text-emerald-700',
      };
      timeline.innerHTML = buildTrackTimeline(report).map(item => `
        <li class="rounded-[1.3rem] border border-slate-200 bg-white px-4 py-4 shadow-[0_10px_22px_rgba(15,23,42,0.06)]">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border ${toneClasses[item.tone] || toneClasses.blue}">&#9679;</span>
            <div class="min-w-0">
              <div class="text-sm font-black uppercase tracking-[0.16em] text-slate-500">${item.label}</div>
              <div class="mt-1 text-base font-black text-slate-950">${item.detail}</div>
              <div class="mt-2 text-sm font-semibold text-slate-500">${formatDateTime(item.time)}</div>
            </div>
          </div>
        </li>
      `).join('');
    }

    function showError(message){
      document.getElementById('trackIdleState').classList.add('hidden');
      document.getElementById('trackResult').classList.add('hidden');
      const el = document.getElementById('trackErrorState');
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearError(){
      const el = document.getElementById('trackErrorState');
      el.textContent = '';
      el.classList.add('hidden');
    }

    function renderTrack(report){
      trackState.report = report;
      clearError();
      document.getElementById('trackIdleState').classList.add('hidden');
      const trackResult = document.getElementById('trackResult');
      trackResult.classList.remove('hidden');

      document.getElementById('trackReportId').textContent = report.id || '-';
      document.getElementById('trackStatus').textContent = report.statusLabel || '-';
      setStatusTone(report.status);

      const dispatcherDisplay = report.currentDispatcher || 'Waiting for dispatcher';
      const dispatcherUsername = report.dispatcherUsername ? `@${report.dispatcherUsername}` : 'No dispatcher username yet';
      document.getElementById('trackDispatcher').textContent = dispatcherDisplay;
      document.getElementById('trackDispatcherUser').textContent = dispatcherUsername;
      document.getElementById('trackHandlingName').textContent = dispatcherDisplay;

      document.getElementById('trackSubmittedAt').textContent = `Submitted ${formatDateTime(report.submittedAt)}`;
      document.getElementById('trackReporterName').textContent = report.reporterName || '-';
      document.getElementById('trackEmergencyType').textContent = report.emergencyType || '-';
      document.getElementById('trackLocation').textContent = report.location || 'Location pending confirmation';
      document.getElementById('trackBarangay').textContent = report.locationParts && report.locationParts.barangay ? report.locationParts.barangay : 'Not available';

      const landmarkStreet = [report.locationParts && report.locationParts.landmark, report.locationParts && report.locationParts.street]
        .filter(Boolean)
        .join(' | ');
      document.getElementById('trackLandmarkStreet').textContent = landmarkStreet || 'Not available';
      document.getElementById('trackGps').textContent = report.locationParts && report.locationParts.gps ? report.locationParts.gps : 'Not available';

      document.getElementById('trackPassCount').textContent = String(report.passCount || 0);
      const lastPassedText = report.passCount > 0
        ? `${report.lastPassedBy || 'Dispatcher reassigned the report'} on ${formatDateTime(report.lastPassedAt)}`
        : 'No reassignment yet.';
      document.getElementById('trackLastPassed').textContent = lastPassedText;
      renderTrackTimeline(report);

      try { localStorage.setItem(TRACK_STORAGE_KEY, report.id || ''); } catch (_e) {}
      const animatedCards = trackResult.querySelectorAll('[data-animate]');
      animatedCards.forEach(el => el.classList.remove('is-visible'));
      requestAnimationFrame(() => {
        animatedCards.forEach(el => el.classList.add('is-visible'));
      });
      refreshElapsed();
    }

    function refreshElapsed(){
      if (!trackState.report) return;
      document.getElementById('trackElapsed').textContent = formatElapsed(trackState.report.submittedAt);
    }

    async function lookupTrack(id){
      const normalized = normalizeTrackId(id);
      if (!normalized) {
        showError('Enter a valid report ID first.');
        return;
      }

      clearError();
      document.getElementById('trackLookupHint').textContent = 'Loading tracking details...';

      try {
        const resp = await fetch(`/api/report-track/${encodeURIComponent(normalized)}`);
        const data = await resp.json().catch(() => ({}));
        if (!resp.ok || !data.success || !data.report) {
          throw new Error(data.error || 'Could not find that report ID.');
        }
        document.getElementById('trackIdInput').value = normalized;
        document.getElementById('trackLookupHint').textContent = 'Tracking details loaded successfully.';
        history.replaceState({}, '', `/track?id=${encodeURIComponent(normalized)}`);
        renderTrack(data.report);
      } catch (err) {
        document.getElementById('trackLookupHint').textContent = 'Tracking lookup failed.';
        showError(err && err.message ? err.message : 'Could not find that report ID.');
      }
    }

    document.getElementById('trackForm').addEventListener('submit', (event) => {
      event.preventDefault();
      lookupTrack(document.getElementById('trackIdInput').value);
    });

    const lastIdBtn = document.getElementById('useLastIdBtn');
    let lastSavedId = '';
    try { lastSavedId = normalizeTrackId(localStorage.getItem(TRACK_STORAGE_KEY) || ''); } catch (_e) {}
    if (lastSavedId) {
      lastIdBtn.hidden = false;
      lastIdBtn.classList.remove('hidden');
      lastIdBtn.textContent = `Use last submitted ID (${lastSavedId})`;
      lastIdBtn.addEventListener('click', () => lookupTrack(lastSavedId));
    }

    setInterval(refreshElapsed, 1000);

    if (INITIAL_TRACK_ID) {
      lookupTrack(INITIAL_TRACK_ID);
    }
  </script>
</body>
</html>
