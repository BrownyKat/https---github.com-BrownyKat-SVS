<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SVS — About</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    :root {
      --bg:#f8fafc;
      --surface:#ffffff;
      --text:#0f172a;
      --muted:#475569;
      --border:#e2e8f0;
      --accent:#0f6fff;
      --accent-strong:#0b54c2;
      --amber:#f59e0b;
      --green:#16a34a;
      --red:#dc2626;
      --shadow-sm:0 6px 18px rgba(15,23,42,0.06);
      --shadow-md:0 12px 28px rgba(15,23,42,0.08);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { 
      font-family: 'Outfit', sans-serif; 
      background: var(--bg); 
      color: var(--text); 
      line-height: 1.6; 
      -webkit-font-smoothing: antialiased; 
    }
    a { color: var(--accent); text-decoration: none; transition: 0.2s; }
    a:hover { color: var(--accent-strong); }
    
    /* Header */
    header { 
      position: sticky; top: 0; z-index: 100; 
      background: var(--surface); border-bottom: 1px solid var(--border); 
      box-shadow: 0 4px 16px rgba(15,23,42,.04); 
      display: flex; align-items: center; justify-content: space-between; 
      padding: 1rem 1.5rem; gap: 1rem; 
    }
    .brand { display: flex; align-items: center; gap: .75rem; color: var(--text); }
    .brand img { width: 50px; height: 50px; object-fit: contain; }
    .brand-text { line-height: 1.05; }
    .brand-name { font-weight: 800; font-size: 1.2rem; letter-spacing: -.1px; }
    .brand-sub { font-family: 'JetBrains Mono', monospace; font-size: .72rem; color: var(--muted); }
    .header-right { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; justify-content: flex-end; }
    .nav-links { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
    .nav-btn { 
      display: inline-flex; align-items: center; padding: .55rem 1rem; 
      border: 1px solid transparent; border-radius: 10px; 
      color: var(--text); font-weight: 600; transition: all .15s ease; 
    }
    .nav-btn:hover { background: #eef2f7; border-color: var(--border); }
    .nav-btn.active { color: var(--accent); border-color: var(--accent); background: #e8f1ff; }
    .main-datetime { 
      display: flex; align-items: center; gap: .75rem; padding: .65rem 1rem; 
      border: 1px solid var(--border); border-radius: 12px; background: var(--surface); 
    }
    .main-datetime svg { width: 20px; height: 20px; stroke: var(--accent); fill: none; stroke-width: 2; }
    .time-block { display: flex; flex-direction: column; line-height: 1.05; }
    .clock-text { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 0.9rem; }
    .date-text { font-family: 'JetBrains Mono', monospace; font-size: .7rem; color: var(--muted); }

    /* Layout */
    .page-wrap { max-width: 1180px; margin: 0 auto; padding: 2.2rem 1.25rem; }

    /* Hero Section */
    .hero { 
      display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2rem; 
      padding: 2.5rem; border: 1px solid var(--border); border-radius: 24px; 
      background: var(--surface); box-shadow: var(--shadow-md); align-items: center;
    }
    .hero h1 { font-size: 2.8rem; line-height: 1.1; letter-spacing: -1.5px; margin-bottom: 1.2rem; }
    .hero p { color: var(--muted); font-size: 1.1rem; margin-bottom: 2rem; max-width: 500px; }
    
    .pill { 
      display: inline-flex; align-items: center; padding: .4rem 1rem; 
      border-radius: 999px; background: #e8f1ff; color: var(--accent); 
      font-weight: 700; font-size: .8rem; margin-bottom: 1rem;
    }

    .cta-row { display: flex; gap: 1rem; }
    .btn { 
      padding: .85rem 1.5rem; border-radius: 12px; font-weight: 700; 
      cursor: pointer; transition: 0.2s; border: 1px solid transparent; 
    }
    .btn.primary { background: var(--accent); color: white; }
    .btn.primary:hover { background: var(--accent-strong); transform: translateY(-2px); }
    .btn.secondary { background: white; color: var(--accent); border-color: var(--accent); }

    .summary-card { 
      background: #f8fafc; border: 1px solid var(--border); 
      border-radius: 20px; padding: 1.5rem; 
    }
    .summary-card h3 { margin-bottom: 1rem; }
    .summary-card ul { list-style: none; color: var(--muted); }
    .summary-card li { margin-bottom: .8rem; position: relative; padding-left: 1.5rem; }
    .summary-card li::before { content: "✓"; position: absolute; left: 0; color: var(--green); font-weight: 800; }

    /* Process Cards */
    .cards { margin: 3rem 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 1.5rem; box-shadow: var(--shadow-sm); }
    .card.step::before { 
      content: attr(data-step); display: block; width: 32px; height: 32px; 
      background: var(--accent); color: white; border-radius: 8px; 
      text-align: center; line-height: 32px; font-weight: 800; margin-bottom: 1rem;
    }

    /* Map Section */
    #map { height: 450px; border-radius: 20px; border: 1px solid var(--border); margin: 2rem 0; box-shadow: var(--shadow-sm); }

    .my-label { 
        font-weight: bold; 
        background: white; 
        border: 1px solid #d32f2f; 
        color: #d32f2f;
        padding: 2px 5px;
        border-radius: 4px;
    }

    /* Disaster Info */
    .hazard-grid { display: grid; gap: 1rem; margin-top: 2rem; }
    .hazard-accordion { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .hazard-accordion summary { padding: 1.2rem; cursor: pointer; font-weight: 700; display: flex; align-items: center; justify-content: space-between; }
    .hazard-content { padding: 1.2rem; background: #fcfcfd; border-top: 1px solid var(--border); }
    .hazard-group { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem; }
    .hazard-item { background: white; padding: 1rem; border: 1px solid var(--border); border-radius: 8px; }
    .hazard-label { font-size: 0.7rem; text-transform: uppercase; font-weight: 800; display: block; margin-bottom: 0.3rem; color: var(--accent); }

    /* Footer */
    footer { padding: 3rem 1.5rem; background: white; border-top: 1px solid var(--border); margin-top: 4rem; }
    .footer-grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; }

    @media (max-width: 800px) {
      .hero { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <header>
    <a class="brand" href="/about">
      <img src="/images/logo.png" alt="SVS logo"> <div class="brand-text">
        <div class="brand-name">SVS</div>
        <div class="brand-sub">Smart Verification System</div>
      </div>
    </a>
    <div class="header-right">
      <nav class="nav-links">
        <a class="nav-btn" href="/sos">SOS</a>
        <a class="nav-btn" href="/report">Report</a>
        <a class="nav-btn active" href="/about">About Us</a>
        <a class="nav-btn" href="/faq">FAQ</a>
      </nav>
      <div class="main-datetime" id="aboutTime">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 6v6l4 2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div class="time-block">
          <span class="clock-text">00:00:00 AM</span>
          <span class="date-text">Loading Date...</span>
        </div>
      </div>
    </div>
  </header>

  <main class="page-wrap">
    <section class="hero">
      <div>
        <div class="pill">The problem → The solution</div>
        <h1>From clogged hotlines to clear, verified emergency reports.</h1>
        <p>Emergency lines used to drown in prank calls, vague landmarks, and dropped signals. SVS was built with responders to verify callers, pin locations automatically, and keep genuine emergencies moving fast.</p>
        <div class="cta-row">
          <a class="btn primary" href="/report">File an Emergency Report</a>
          <a class="btn secondary" href="/sos">Quick SOS options</a>
        </div>
      </div>
      <div class="summary-card">
        <div class="summary-eyebrow">Site overview</div>
        <h3>Everything in one place.</h3>
        <ul>
          <li>Learn the history of the emergency-reporting bottleneck.</li>
          <li>See the solution: GPS-first SOS, verification, and offline queueing.</li>
          <li>Trigger an SOS or file a verified report when seconds matter.</li>
        </ul>
      </div>
    </section>

    <section class="cards">
      <div class="card step" data-step="01">
        <h3>Before SVS</h3>
        <p>Hotlines were flooded with prank calls, vague landmarks, and no GPS, slowing real dispatch work.</p>
      </div>
      <div class="card step" data-step="02">
        <h3>What had to change</h3>
        <p>We needed caller verification, automatic location capture, and a way to keep signals alive when networks drop.</p>
      </div>
      <div class="card step" data-step="03">
        <h3>Our Solution</h3>
        <p>GPS-first SOS, identity checks, and offline queueing send clean, verified reports to dispatchers in seconds.</p>
      </div>
      <div class="card step" data-step="04">
        <h3>Results for Teams</h3>
        <p>Faster triage, fewer false alarms, clearer routes, and better focus on life-saving responses.</p>
      </div>
    </section>

    <div class="inline-cta">Need immediate help? Go to the <a href="/sos">SOS page</a> or file a <a href="/report">report</a>.</div>

    <section class="disaster-wrap">
      <div class="disaster-head">
        <div class="tag-pill">Disaster Ready</div>
        <h2>Natural disasters: causes, effects, and what to do</h2>
        <p>Quick reference for the most common hazards. Follow the before / during / after guidance and respect the do / don't reminders.</p>
      </div>
      <div class="hazard-grid">
        <details class="hazard-accordion" open>
          <summary>
            <div class="hazard-title">
              <div class="hazard-icon"><svg viewBox="0 0 24 24"><path d="M3 12h18M5 9l7-6 7 6M7 12v7m10-7v7M9 19h6"/></svg></div>
              <span>Typhoon / Cyclone</span>
            </div>
            <div class="hazard-tags"><span class="hazard-tag">Wind · Surge · Rain</span></div>
            <svg class="hazard-chevron" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="hazard-content">
            <div class="hazard-section">
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label cause">Cause</span><p class="hazard-text">Low-pressure system over warm ocean driving severe winds and rain.</p></div>
                <div class="hazard-item"><span class="hazard-label effects">Effects</span><p class="hazard-text">Storm surge, flooding, power loss, flying debris.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label before">Before</span><p class="hazard-text">Secure loose items, charge phones, prep go-bag, know evacuation routes.</p></div>
                <div class="hazard-item"><span class="hazard-label during">During</span><p class="hazard-text">Stay indoors away from windows; monitor official alerts; avoid floodwater.</p></div>
                <div class="hazard-item"><span class="hazard-label after">After</span><p class="hazard-text">Watch for downed lines, avoid standing water, document damage safely.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label do">Do</span><p class="hazard-text">Evacuate when ordered; keep radio/phone for updates.</p></div>
                <div class="hazard-item"><span class="hazard-label dont">Don't</span><p class="hazard-text">Drive through floodwater; go outside during the eye.</p></div>
              </div>
            </div>
          </div>
        </details>

        <details class="hazard-accordion">
          <summary>
            <div class="hazard-title">
              <div class="hazard-icon"><svg viewBox="0 0 24 24"><path d="M3 6h18M5 10h14M7 14h10M9 18h6"/></svg></div>
              <span>Flood</span>
            </div>
            <div class="hazard-tags"><span class="hazard-tag">Water · Surge</span></div>
            <svg class="hazard-chevron" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="hazard-content">
            <div class="hazard-section">
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label cause">Cause</span><p class="hazard-text">Heavy rain, storm surge, dam release, clogged drainage.</p></div>
                <div class="hazard-item"><span class="hazard-label effects">Effects</span><p class="hazard-text">Rapid water rise, contamination, electrocution risk, landslide triggers.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label before">Before</span><p class="hazard-text">Move valuables up high, prep sandbags, plan high-ground paths.</p></div>
                <div class="hazard-item"><span class="hazard-label during">During</span><p class="hazard-text">Get to higher ground fast; turn off main power if safe.</p></div>
                <div class="hazard-item"><span class="hazard-label after">After</span><p class="hazard-text">Avoid wading; treat water as contaminated; use PPE for clean-up.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label do">Do</span><p class="hazard-text">Follow LGU evacuation cues and text alerts.</p></div>
                <div class="hazard-item"><span class="hazard-label dont">Don't</span><p class="hazard-text">Walk or drive through moving water; return home until cleared.</p></div>
              </div>
            </div>
          </div>
        </details>

        <details class="hazard-accordion">
          <summary>
            <div class="hazard-title">
              <div class="hazard-icon"><svg viewBox="0 0 24 24"><path d="M12 3v18M5 12h14M4 8l8-4 8 4"/></svg></div>
              <span>Earthquake</span>
            </div>
            <div class="hazard-tags"><span class="hazard-tag">Shake · Aftershocks</span></div>
            <svg class="hazard-chevron" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="hazard-content">
            <div class="hazard-section">
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label cause">Cause</span><p class="hazard-text">Sudden release of tectonic stress along faults.</p></div>
                <div class="hazard-item"><span class="hazard-label effects">Effects</span><p class="hazard-text">Ground shaking, structural collapse, liquefaction, aftershocks.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label before">Before</span><p class="hazard-text">Bolt shelves, secure breakables, practice Drop-Cover-Hold drills.</p></div>
                <div class="hazard-item"><span class="hazard-label during">During</span><p class="hazard-text">Drop, Cover, Hold On; stay away from glass; outside: move to open space.</p></div>
                <div class="hazard-item"><span class="hazard-label after">After</span><p class="hazard-text">Expect aftershocks; check gas leaks; avoid damaged structures.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label do">Do</span><p class="hazard-text">Use stairs, not elevators, when exiting after shaking.</p></div>
                <div class="hazard-item"><span class="hazard-label dont">Don't</span><p class="hazard-text">Run during shaking; stand under doorways or near windows.</p></div>
              </div>
            </div>
          </div>
        </details>

        <details class="hazard-accordion">
          <summary>
            <div class="hazard-title">
              <div class="hazard-icon"><svg viewBox="0 0 24 24"><path d="M6 20h12M8 20c0-4 2-8 4-10 2 2 4 6 4 10M10 12c0-1.5.5-3 2-4"/></svg></div>
              <span>Fire / Urban Blaze</span>
            </div>
            <div class="hazard-tags"><span class="hazard-tag">Heat · Smoke</span></div>
            <svg class="hazard-chevron" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="hazard-content">
            <div class="hazard-section">
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label cause">Cause</span><p class="hazard-text">Faulty wiring, open flames, cooking accidents, arson.</p></div>
                <div class="hazard-item"><span class="hazard-label effects">Effects</span><p class="hazard-text">Smoke inhalation, burns, structural failure, toxic fumes.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label before">Before</span><p class="hazard-text">Check exits, keep extinguishers, avoid overloading outlets.</p></div>
                <div class="hazard-item"><span class="hazard-label during">During</span><p class="hazard-text">Stay low under smoke, feel doors for heat, evacuate—do not re-enter.</p></div>
                <div class="hazard-item"><span class="hazard-label after">After</span><p class="hazard-text">Call authorities, get medical check for smoke, do not switch power back on.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label do">Do</span><p class="hazard-text">Stop-Drop-Roll if clothes ignite.</p></div>
                <div class="hazard-item"><span class="hazard-label dont">Don't</span><p class="hazard-text">Use elevators; open hot doors; waste time gathering items.</p></div>
              </div>
            </div>
          </div>
        </details>

        <details class="hazard-accordion">
          <summary>
            <div class="hazard-title">
              <div class="hazard-icon"><svg viewBox="0 0 24 24"><path d="M4 18l8-12 8 12M4 18h16M9 18l3-4 3 4"/></svg></div>
              <span>Landslide</span>
            </div>
            <div class="hazard-tags"><span class="hazard-tag">Slope · Soil</span></div>
            <svg class="hazard-chevron" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="hazard-content">
            <div class="hazard-section">
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label cause">Cause</span><p class="hazard-text">Saturated slopes after heavy rain, earthquakes, or excavation.</p></div>
                <div class="hazard-item"><span class="hazard-label effects">Effects</span><p class="hazard-text">Rapid ground movement, buried roads/houses, blocked rivers.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label before">Before</span><p class="hazard-text">Note cracks, leaning trees, recent slope cuts; prepare to relocate.</p></div>
                <div class="hazard-item"><span class="hazard-label during">During</span><p class="hazard-text">Evacuate uphill and away from the slide path; alert neighbors.</p></div>
                <div class="hazard-item"><span class="hazard-label after">After</span><p class="hazard-text">Avoid area until cleared; watch for secondary slides.</p></div>
              </div>
              <div class="hazard-group">
                <div class="hazard-item"><span class="hazard-label do">Do</span><p class="hazard-text">Heed slope warnings; keep go-bag ready in rainy season.</p></div>
                <div class="hazard-item"><span class="hazard-label dont">Don't</span><p class="hazard-text">Build or camp at the base of unstable slopes.</p></div>
              </div>
            </div>
          </div>
        </details>
      </div>
    </section>

    <h2 style="margin-top: 3rem; margin-bottom: 1rem;">Evacuation & Response Centers</h2>
    <iframe 
        id="mapFrame"
        title="Mapandan Map"
        style="border: none; border-radius: 8px; width: 100%; height: 500px; margin: 2rem 0; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
    </iframe>
  </main>

  <script>
    // Initialize Map in iframe
    const mapFrame = document.getElementById('mapFrame');
    const mapHTML = `<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"><\/script>
    <style>
        body, html { margin: 0; padding: 0; height: 100%; width: 100%; overflow: hidden; }
        #map { height: 100%; width: 100%; }
        .my-label { 
            font-weight: bold; 
            background: white; 
            border: 1px solid #d32f2f; 
            color: #d32f2f;
            padding: 2px 5px;
            border-radius: 4px;
        }
    <\/style>
</head>
<body>
    <div id="map"><\/div>
    <script>
        var map = L.map("map").setView([16.0285, 120.4517], 13);
        L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png", {
            attribution: "&copy; CARTO"
        }).addTo(map);

        var centers = [
            { name: "Mapandan Central School", lat: 16.0298, lng: 120.4526 },
            { name: "Aloha Building", lat: 16.0278, lng: 120.4515 },
            { name: "Cong. Tulagan Gym", lat: 16.0275, lng: 120.4510 },
            { name: "Coral Barangay Hall", lat: 16.0264, lng: 120.4716 },
            { name: "Primicias Elem/High School", lat: 15.9898, lng: 120.4568 },
            { name: "Sta. Maria Elementary School", lat: 16.0425, lng: 120.4678 },
            { name: "Baloling Elementary School", lat: 16.0475, lng: 120.4580 },
            { name: "Nilombot Elementary School", lat: 16.0125, lng: 120.4428 },
            { name: "Torres Elementary School", lat: 16.0465, lng: 120.4285 },
            { name: "Golden Elementary School", lat: 16.0195, lng: 120.4320 },
            { name: "Jimenez Elementary School", lat: 16.0020, lng: 120.4655 },
            { name: "Lambayan Elementary School", lat: 16.0350, lng: 120.4410 }
        ];

        centers.forEach(function(center) {
            var marker = L.marker([center.lat, center.lng]).addTo(map);
            marker.bindTooltip(center.name, {
                permanent: true,
                direction: "top",
                className: "my-label"
            }).openTooltip();
        });
    <\/script>
</body>
</html>`;

    mapFrame.setAttribute('srcdoc', mapHTML);

    // Time Update Script
    function updateTime() {
      const clock = document.querySelector('.clock-text');
      const dateEl = document.querySelector('.date-text');
      const now = new Date();
      
      clock.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      dateEl.textContent = now.toLocaleDateString([], { weekday: 'short', month: '2-digit', day: '2-digit', year: 'numeric' });
    }
    setInterval(updateTime, 1000);
    updateTime();

    // Accordion logic: only one open at a time
    const accordions = document.querySelectorAll('.hazard-accordion');
    accordions.forEach(acc => {
      acc.addEventListener('toggle', () => {
        if (acc.open) {
          accordions.forEach(other => { if (other !== acc) other.open = false; });
        }
      });
    });
  </script>

