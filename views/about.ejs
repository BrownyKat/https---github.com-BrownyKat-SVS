<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SVS - About</title>
  <%- include('partials/typography') %>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(37,99,235,0.1),_transparent_34%),radial-gradient(circle_at_bottom_right,_rgba(239,68,68,0.1),_transparent_28%),linear-gradient(180deg,#f4f7ff_0%,#fff8ef_80%,#ffffff_100%)] text-slate-900 antialiased">
  <%
    const pillars = [
      {
        title: 'Verified intake',
        body: 'SVS trims noise from emergency channels by encouraging complete, credible reports with working contact details and clearer scene information.',
      },
      {
        title: 'Location-aware dispatch',
        body: 'GPS capture, barangay details, and landmarks help responders spend less time searching and more time acting.',
      },
      {
        title: 'Resilient reporting',
        body: 'When signal quality drops, SVS keeps the report usable with fallback details, manual fields, and retry-friendly flows.',
      },
    ];
    const statCards = [
      { value: '3', label: 'Core platform strengths' },
      { value: '5', label: 'Disaster guides restored' },
      { value: '2', label: 'Fast response paths: SOS and Report' },
    ];
    const journey = [
      {
        step: '01',
        title: 'The problem',
        body: 'Traditional hotlines lose time to prank calls, vague directions, and fragmented scene details.',
      },
      {
        step: '02',
        title: 'What changed',
        body: 'We designed a cleaner reporting flow that guides citizens to submit structured, actionable information quickly.',
      },
      {
        step: '03',
        title: 'What responders gain',
        body: 'Dispatch teams receive sharper location context, clearer severity signals, and fewer dead-end reports.',
      },
    ];
    const hazards = [
      {
        title: 'Typhoon / Cyclone',
        tag: 'Wind / Surge / Rain',
        what: 'A powerful low-pressure weather system that brings intense wind, heavy rain, and possible storm surge.',
        when: 'Risk rises during tropical storm season, especially with PAGASA wind signals, coastal warnings, and nonstop rainfall.',
        before: 'Secure loose items, charge phones, prepare a go-bag, and confirm your evacuation route.',
        during: 'Stay indoors away from windows, monitor official alerts, and avoid floodwater or exposed shorelines.',
        after: 'Watch for downed power lines, unstable debris, and standing water before moving around.',
        do: 'Evacuate immediately when authorities order it and keep a radio or phone ready for updates.',
        dont: 'Do not drive through floodwater or go outside just because conditions seem calmer during the eye.',
      },
      {
        title: 'Flood',
        tag: 'Water / Surge',
        what: 'Overflowing water caused by heavy rain, storm surge, dam release, or blocked drainage.',
        when: 'Risk rises after hours of strong rain, near rivers and low-lying roads, or when water levels climb fast.',
        before: 'Move important items higher, prepare sandbags when possible, and identify the nearest safe high ground.',
        during: 'Get to higher ground quickly and switch off main power only if it is safe to do so.',
        after: 'Treat floodwater as contaminated, wear protection during cleanup, and return only when the area is cleared.',
        do: 'Follow LGU alerts, evacuation texts, and barangay instructions.',
        dont: 'Do not walk or drive through moving water or rush back into a flooded home.',
      },
      {
        title: 'Earthquake',
        tag: 'Shake / Aftershocks',
        what: 'Sudden ground shaking caused by movement along faults beneath the earth.',
        when: 'It can happen without warning, and aftershocks may continue after the main quake.',
        before: 'Secure shelves and breakables, identify safe spots, and practice Drop, Cover, and Hold On.',
        during: 'Drop, Cover, and Hold On. Stay away from glass, and if outside move to an open area.',
        after: 'Expect aftershocks, check for gas leaks or structural damage, and avoid unsafe buildings.',
        do: 'Use stairs instead of elevators when leaving after the shaking stops.',
        dont: 'Do not run during shaking or stand near windows, facades, or falling objects.',
      },
      {
        title: 'Fire / Urban Blaze',
        tag: 'Heat / Smoke',
        what: 'A fast-spreading structural or urban fire that creates extreme heat, smoke, and collapse risk.',
        when: 'Risk rises around faulty wiring, overloaded outlets, open flames, and tightly packed structures.',
        before: 'Check exits, keep extinguishers ready, and avoid overloading electrical outlets.',
        during: 'Stay low under smoke, feel doors for heat, evacuate fast, and do not re-enter the structure.',
        after: 'Call authorities, get checked for smoke exposure, and wait for professionals before restoring power.',
        do: 'Use Stop, Drop, and Roll if clothing catches fire.',
        dont: 'Do not use elevators, open hot doors, or waste time gathering belongings.',
      },
      {
        title: 'Landslide',
        tag: 'Slope / Soil',
        what: 'Rapid downhill movement of soil, rocks, and debris that can bury homes, roads, and waterways.',
        when: 'Risk rises after prolonged rain, earthquakes, slope excavation, or visible cracks on unstable ground.',
        before: 'Watch for leaning trees, fresh cracks, and slope cuts, and prepare to move early.',
        during: 'Evacuate uphill and away from the slide path as quickly as possible and warn nearby residents.',
        after: 'Stay out of the area until cleared and watch for secondary slides or blocked drainage.',
        do: 'Heed slope warnings and keep a ready go-bag during rainy periods.',
        dont: 'Do not stay, build, or camp below unstable slopes or newly eroded hillsides.',
      },
    ];
    const contacts = [
      { label: 'National hotline', value: '911', note: 'For immediate life-threatening emergencies.' },
      { label: 'SVS operations', value: '+63 917 000 0000', note: 'Sample office line configured in the project footer.' },
      { label: 'Support email', value: 'support@svs.local', note: 'General questions and platform support.' },
    ];
  %>

  <%- include('partials/navbar', { active: 'about', timeId: 'aboutTime' }) %>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <section class="overflow-hidden rounded-[2.2rem] border border-slate-200/80 bg-[linear-gradient(145deg,rgba(255,255,255,0.94),rgba(236,244,255,0.9))] shadow-[0_28px_70px_rgba(15,23,42,0.12)]">
      <div class="grid gap-8 px-6 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)] lg:items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-white/90 px-3 py-1 font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-blue-700">
            About SVS
          </div>
          <h1 class="mt-5 max-w-3xl text-3xl font-black leading-[1.02] tracking-tight text-slate-950 sm:text-[3.5rem]">
            Built to turn stressful emergency reporting into clear, usable action.
          </h1>
          <p class="mt-5 max-w-3xl text-base leading-8 text-slate-700 sm:text-lg">
            Smart Verification System exists to help citizens report emergencies with stronger location details and help responders receive cleaner information faster. The goal is simple: reduce confusion at the point where every second matters.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/report" class="inline-flex items-center gap-2 rounded-2xl bg-slate-900 px-5 py-3 text-sm font-black text-white shadow-[0_14px_32px_rgba(15,23,42,0.18)] transition hover:-translate-y-0.5">
              File a report
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M13 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="/sos" class="inline-flex items-center gap-2 rounded-2xl border border-red-200 bg-red-50 px-5 py-3 text-sm font-black text-red-600 transition hover:border-red-300 hover:bg-red-100">
              Open SOS
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 9v4m0 4h.01"/>
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)] backdrop-blur">
          <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-slate-500">Platform focus</div>
          <div class="mt-4 grid gap-4">
            <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-5 py-4">
              <div class="text-sm font-black uppercase tracking-[0.2em] text-blue-600">Faster triage</div>
              <p class="mt-2 text-sm leading-7 text-slate-700">Responders receive better context earlier, which helps them prioritize real incidents faster.</p>
            </div>
            <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-5 py-4">
              <div class="text-sm font-black uppercase tracking-[0.2em] text-blue-600">Cleaner location data</div>
              <p class="mt-2 text-sm leading-7 text-slate-700">GPS, barangay, street, and landmark fields work together so the scene is easier to find.</p>
            </div>
            <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-5 py-4">
              <div class="text-sm font-black uppercase tracking-[0.2em] text-blue-600">Calmer citizen UX</div>
              <p class="mt-2 text-sm leading-7 text-slate-700">The interface is designed to stay readable and usable on mobile when people are under pressure.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <% pillars.forEach(function(pillar) { %>
        <article class="rounded-[1.8rem] border border-slate-200 bg-white/90 p-6 shadow-[0_18px_38px_rgba(15,23,42,0.1)]">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-blue-50 text-blue-700 ring-1 ring-blue-100">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"/>
              <path d="M12 5v14"/>
            </svg>
          </div>
          <h2 class="mt-4 text-xl font-black text-slate-950"><%= pillar.title %></h2>
          <p class="mt-3 text-sm leading-7 text-slate-700 sm:text-base"><%= pillar.body %></p>
        </article>
      <% }) %>
    </section>

    <section class="mt-6 grid gap-4 sm:grid-cols-3">
      <% statCards.forEach(function(stat) { %>
        <div class="rounded-[1.5rem] border border-slate-200 bg-white/85 px-5 py-5 text-center shadow-[0_14px_28px_rgba(15,23,42,0.08)]">
          <div class="text-3xl font-black tracking-tight text-slate-950"><%= stat.value %></div>
          <div class="mt-2 text-sm font-bold uppercase tracking-[0.16em] text-slate-500"><%= stat.label %></div>
        </div>
      <% }) %>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.9fr)]">
      <div class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#eff6ff_0%,#ffffff_100%)] p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)] sm:p-8">
        <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-blue-700">Why it matters</div>
        <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950 sm:text-3xl">Emergency reporting should not create more emergency.</h2>
        <div class="mt-6 grid gap-4">
          <% journey.forEach(function(item) { %>
            <div class="rounded-[1.5rem] border border-white/80 bg-white/90 px-5 py-5 shadow-[0_12px_24px_rgba(15,23,42,0.08)]">
              <div class="flex items-start gap-4">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-slate-900 font-mono text-sm font-black text-white"><%= item.step %></div>
                <div>
                  <h3 class="text-lg font-black text-slate-950"><%= item.title %></h3>
                  <p class="mt-2 text-sm leading-7 text-slate-700 sm:text-base"><%= item.body %></p>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <aside class="rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)] sm:p-8">
        <div class="font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-red-600">Quick contacts</div>
        <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950">Keep these close when every second counts.</h2>
        <div class="mt-6 space-y-4">
          <% contacts.forEach(function(contact) { %>
            <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 px-5 py-4">
              <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500"><%= contact.label %></div>
              <div class="mt-2 text-xl font-black text-slate-950"><%= contact.value %></div>
              <p class="mt-2 text-sm leading-7 text-slate-600"><%= contact.note %></p>
            </div>
          <% }) %>
        </div>
        <div class="mt-6 rounded-[1.4rem] border border-amber-200 bg-amber-50 px-5 py-4 text-sm leading-7 text-slate-700">
          Use the <a href="/report" class="font-black text-blue-700">report page</a> when you can safely give more detail. Use <a href="/sos" class="font-black text-red-600">SOS</a> when you need dispatch attention immediately.
        </div>
      </aside>
    </section>

    <section class="mt-8 rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#f8fbff_0%,#ffffff_100%)] p-6 shadow-[0_20px_44px_rgba(15,23,42,0.1)] sm:p-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-white px-3 py-1 font-mono text-[0.68rem] font-extrabold uppercase tracking-[0.24em] text-blue-700">
          Disaster Ready
        </div>
        <h2 class="mt-4 text-2xl font-black tracking-tight text-slate-950 sm:text-3xl">Natural disasters: what they are, when risk rises, and how to respond.</h2>
        <p class="mt-3 text-sm leading-7 text-slate-700 sm:text-base">
          The preparedness guide is back here as a quick-reference companion to SVS. Open each hazard to review what it is, when it becomes more dangerous, and what to do before, during, and after.
        </p>
      </div>

      <div class="mt-6 space-y-4">
        <% hazards.forEach(function(hazard, index) { %>
          <details class="group overflow-hidden rounded-[1.6rem] border border-slate-200 bg-white/90 shadow-[0_14px_30px_rgba(15,23,42,0.08)]" <%= index === 0 ? 'open' : '' %>>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 sm:px-6">
              <div>
                <div class="text-lg font-black text-slate-950"><%= hazard.title %></div>
                <div class="mt-2 inline-flex rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-black uppercase tracking-[0.18em] text-blue-700"><%= hazard.tag %></div>
              </div>
              <div class="shrink-0 rounded-full border border-slate-200 bg-slate-50 p-2 text-slate-500 transition group-open:rotate-180">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </div>
            </summary>
            <div class="border-t border-slate-100 px-5 py-5 sm:px-6">
              <div class="grid gap-3 md:grid-cols-2">
                <div class="rounded-[1.2rem] border border-slate-200 bg-slate-50 px-4 py-4">
                  <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">What</div>
                  <p class="mt-2 text-sm leading-7 text-slate-700"><%= hazard.what %></p>
                </div>
                <div class="rounded-[1.2rem] border border-slate-200 bg-slate-50 px-4 py-4">
                  <div class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">When</div>
                  <p class="mt-2 text-sm leading-7 text-slate-700"><%= hazard.when %></p>
                </div>
              </div>

              <div class="mt-4 grid gap-3 lg:grid-cols-3">
                <div class="rounded-[1.2rem] border border-amber-200 bg-amber-50 px-4 py-4">
                  <div class="text-xs font-black uppercase tracking-[0.18em] text-amber-800">Before</div>
                  <p class="mt-2 text-sm leading-7 text-slate-700"><%= hazard.before %></p>
                </div>
                <div class="rounded-[1.2rem] border border-sky-200 bg-sky-50 px-4 py-4">
                  <div class="text-xs font-black uppercase tracking-[0.18em] text-sky-800">During</div>
                  <p class="mt-2 text-sm leading-7 text-slate-700"><%= hazard.during %></p>
                </div>
                <div class="rounded-[1.2rem] border border-emerald-200 bg-emerald-50 px-4 py-4">
                  <div class="text-xs font-black uppercase tracking-[0.18em] text-emerald-800">After</div>
                  <p class="mt-2 text-sm leading-7 text-slate-700"><%= hazard.after %></p>
                </div>
              </div>

              <div class="mt-4 grid gap-3 md:grid-cols-2">
                <div class="rounded-[1.2rem] border border-emerald-200 bg-emerald-50 px-4 py-4">
                  <div class="text-xs font-black uppercase tracking-[0.18em] text-emerald-800">Do</div>
                  <p class="mt-2 text-sm leading-7 text-slate-700"><%= hazard.do %></p>
                </div>
                <div class="rounded-[1.2rem] border border-rose-200 bg-rose-50 px-4 py-4">
                  <div class="text-xs font-black uppercase tracking-[0.18em] text-rose-800">Don't</div>
                  <p class="mt-2 text-sm leading-7 text-slate-700"><%= hazard.dont %></p>
                </div>
              </div>
            </div>
          </details>
        <% }) %>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    function updateTime(elId){
      const el=document.getElementById(elId);
      if(!el) return;
      const clock=el.querySelector('.clock-text');
      const date=el.querySelector('.date-text');
      const now=new Date();
      const pad=n=>String(n).padStart(2,'0');
      const h24=now.getHours(); const h=h24%12||12;
      const ampm=h24>=12?'PM':'AM';
      clock.textContent=`${pad(h)}:${pad(now.getMinutes())}:${pad(now.getSeconds())} ${ampm}`;
      const days=['SUN','MON','TUE','WED','THU','FRI','SAT'];
      date.textContent=`${days[now.getDay()]} ${pad(now.getMonth()+1)}/${pad(now.getDate())}/${now.getFullYear()}`;
    }
    updateTime('aboutTime'); setInterval(()=>updateTime('aboutTime'),1000);
  </script>
</body>
</html>
