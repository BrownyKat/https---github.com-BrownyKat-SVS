MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/mdrrmo?retryWrites=true&w=majority
# Optional if your DB name is not already included in the URI path above.
MONGODB_DB=mdrrmo

# Strong random secret for session signing.
SESSION_SECRET=replace-with-a-long-random-secret

# Local admin bootstrap credentials.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Optional Firebase push notification config.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional Supabase storage config for report photo uploads.
# Use a public storage bucket if you want the saved URLs to be directly viewable.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_BUCKET=svs_photo
